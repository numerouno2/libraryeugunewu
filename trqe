-- ─────────────────────────────────────────────
-- HELPERS
-- ─────────────────────────────────────────────
local function isMobile()
	return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

local function getScreen()
	local cam = workspace.CurrentCamera
	return cam and cam.ViewportSize or Vector2.new(1920, 1080)
end

local tw = function(obj, props, t, style, dir)
	t = t or 0.22
	style = style or Enum.EasingStyle.Quint
	dir = dir or Enum.EasingDirection.Out
	return TweenService:Create(obj, TweenInfo.new(t, style, dir), props)
end

-- Instant-set shorthand
local function set(obj, props)
	for k, v in pairs(props) do obj[k] = v end
end

-- Create instance shorthand
local function make(class, props, parent)
	local i = Instance.new(class)
	if parent then i.Parent = parent end
	for k, v in pairs(props or {}) do
		if k ~= "Parent" then i[k] = v end
	end
	return i
end

local function corner(obj, r)
	make("UICorner", {CornerRadius = UDim.new(0, r or 8)}, obj)
end

local function stroke(obj, color, thick, trans)
	make("UIStroke", {
		Color = color or Theme.Border,
		Thickness = thick or 1,
		Transparency = trans or 0,
	}, obj)
end

local function pad(obj, l, r, t, b)
	make("UIPadding", {
		PaddingLeft   = UDim.new(0, l or 0),
		PaddingRight  = UDim.new(0, r or 0),
		PaddingTop    = UDim.new(0, t or 0),
		PaddingBottom = UDim.new(0, b or 0),
	}, obj)
end

local function gradient(obj, colors, rotation)
	local kp = {}
	for i, c in ipairs(colors) do
		kp[#kp+1] = ColorSequenceKeypoint.new((i-1)/(#colors-1), c)
	end
	make("UIGradient", {
		Color = ColorSequence.new(kp),
		Rotation = rotation or 90,
	}, obj)
end

-- ─────────────────────────────────────────────
-- MAIN CONSTRUCTOR
-- ─────────────────────────────────────────────
function NexusLib.new(config)
	local self = setmetatable({}, NexusLib)

	self.Title          = config.Title or "Nexus Hub"
	self.Subtitle       = config.Subtitle or ""
	self.Tabs           = {}
	self.TabButtons     = {}
	self.TabPages       = {}
	self.ActiveTab      = nil
	self.UpdateCBs      = {}
	self.IsMobile       = isMobile()
	self._minimized     = false
	self._resizing      = false

	-- Window sizing
	local screen = getScreen()
	if config.Size then
		self.Size = config.Size
	elseif self.IsMobile then
		self.Size = UDim2.new(0, math.min(screen.X-20, 420), 0, math.min(screen.Y-60, 340))
	else
		self.Size = UDim2.new(0, 560, 0, 340)
	end

	-- Layout metrics
	self.SideW    = self.IsMobile and 110 or 148
	self.TitleH   = self.IsMobile and 44  or 52
	self.TabH     = self.IsMobile and 34  or 38
	self.TabGap   = self.IsMobile and 38  or 42
	self.ElemH    = self.IsMobile and 32  or 38
	self.FS       = { -- font sizes
		title = self.IsMobile and 13 or 15,
		tab   = self.IsMobile and 11 or 12,
		elem  = self.IsMobile and 11 or 12,
		small = self.IsMobile and  9 or 10,
	}

	-- Destroy old
	local old = game.CoreGui:FindFirstChild("NexusLib_GUI")
	if old then old:Destroy() end

	-- ScreenGui
	self.SG = make("ScreenGui", {
		Name = "NexusLib_GUI",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	}, game.CoreGui)

	-- ── Drop Shadow (layered)
	self.Shadow = make("ImageLabel", {
		AnchorPoint = Vector2.new(0.5, 0.5),
		BackgroundTransparency = 1,
		Position = UDim2.new(0.5,0,0.5,0),
		Size = self.Size + UDim2.new(0,60,0,60),
		Image = "rbxassetid://5554236805",
		ImageColor3 = Color3.fromRGB(0,0,0),
		ImageTransparency = 0.5,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(23,23,277,277),
	}, self.SG)

	-- ── Main Frame (glass base)
	self.Main = make("Frame", {
		Name = "NexusMain",
		AnchorPoint = Vector2.new(0.5,0.5),
		BackgroundColor3 = Theme.BG1,
		BorderSizePixel = 0,
		Position = UDim2.new(0.5,0,0.5,0),
		Size = self.Size,
		ClipsDescendants = true,
	}, self.SG)
	corner(self.Main, 14)
	stroke(self.Main, Theme.BorderLt, 1, 0.4)

	-- Subtle inner gradient
	local bgGrad = make("Frame", {
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BackgroundTransparency = 0.97,
		BorderSizePixel = 0,
		Size = UDim2.new(1,0,0.5,0),
	}, self.Main)
	gradient(bgGrad, {Color3.fromRGB(180,160,255), Color3.fromRGB(0,200,255)}, 135)

	self:_setupDrag()
	self:_buildTitleBar()
	self:_buildSidebar()
	self:_buildContent()
	self:_buildNotifyBar()
	self:_setupResize()
	self:_startAntiAFK()
	self:_startUpdateLoop()

	-- ── Open animation
	self.Main.Size = UDim2.new(0,0,0,0)
	self.Main.BackgroundTransparency = 1
	self.Shadow.ImageTransparency = 1
	tw(self.Main, {Size=self.Size, BackgroundTransparency=0}, 0.55, Enum.EasingStyle.Back):Play()
	tw(self.Shadow, {ImageTransparency=0.5}, 0.55):Play()

	return self
end

