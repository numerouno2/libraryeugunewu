function NexusLib._SecM:AddButtonGrid(cfg)
	self._e=self._e+1
	local lib=self.Lib
	local items=cfg.Items or {}
	local cb=cfg.Callback or function()end
	local sel=cfg.Default or (items[1] and items[1].name)
	local bW=cfg.ButtonWidth or (lib.Mobile and 56 or 68)
	local gh=lib.Mobile and 46 or 54

	local sf=inst("ScrollingFrame",self.W,{
		BackgroundTransparency=1,
		BorderSizePixel=0,
		Size=UDim2.new(1,0,0,gh),
		ScrollBarThickness=2,
		ScrollBarImageColor3=T.BdrL,
		AutomaticCanvasSize=Enum.AutomaticSize.X,
		CanvasSize=UDim2.new(0,0,0,0),
		LayoutOrder=cfg.Order or self._e,
	})
	listLayout(sf,lib.Mobile and 4 or 5,Enum.FillDirection.Horizontal)

	local btns={}
	for i,item in ipairs(items) do
		local ac=(item.name==sel)
		local ic=item.color or T.Acc

		local b=inst("TextButton",sf,{
			BackgroundColor3=ac and ic or T.BG5,
			BackgroundTransparency=ac and 0.18 or 0,
			BorderSizePixel=0,
			Size=UDim2.new(0,bW,0,gh-3),
			Text="",AutoButtonColor=false,
			LayoutOrder=i,
		})
		corner(b,7)
		if ac then stroke(b,ic,1,0.45) end

		inst("TextLabel",b,{
			BackgroundTransparency=1,
			Size=UDim2.new(1,0,0,gh*.52),
			Text=item.icon or "□",
			TextSize=lib.Mobile and 15 or 19,
			Font=T.FH,
			TextColor3=ac and ic or T.TX2,
		})
		inst("TextLabel",b,{
			BackgroundTransparency=1,
			Position=UDim2.new(0,0,0,gh*.52),
			Size=UDim2.new(1,0,0,gh*.4),
			Text=item.label or item.name,
			TextSize=lib.FS.small,
			Font=T.FM,
			TextColor3=ac and T.TX0 or T.TX2,
			TextTruncate=Enum.TextTruncate.AtEnd,
		})
		btns[item.name]=b

		b.MouseButton1Click:Connect(function()
			sel=item.name
			for n2,b2 in pairs(btns) do
				local it2; for _,x in ipairs(items) do if x.name==n2 then it2=x; break end end
				local c2=it2 and (it2.color or T.Acc) or T.Acc
				local a2=(n2==sel)
				tw(b2,{BackgroundColor3=a2 and c2 or T.BG5,BackgroundTransparency=a2 and 0.18 or 0},.18):Play()
				local ch=b2:GetChildren()
				if ch[1] then tw(ch[1],{TextColor3=a2 and c2 or T.TX2},.18):Play() end
				if ch[2] then tw(ch[2],{TextColor3=a2 and T.TX0 or T.TX2},.18):Play() end
			end
			cb(item)
		end)
	end
	return {Frame=sf,Buttons=btns,GetSelected=function()return sel end}
end

