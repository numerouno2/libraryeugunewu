	self._tabIndex = self._tabIndex + 1
	local index = self._tabIndex

	-- Tab button
	local btn = Instance.new("TextButton", self.TabBar)
	btn.Name = tabName
	btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	btn.BackgroundTransparency = 0.4
	btn.BorderSizePixel = 0
	btn.Size = UDim2.new(0, 100, 0, 36)
	btn.Text = ""
	btn.AutoButtonColor = false
	btn.LayoutOrder = index
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

	-- Bottom indicator
	local indicator = Instance.new("Frame", btn)
	indicator.Name = "Indicator"
	indicator.BackgroundColor3 = Color3.fromRGB(120, 160, 255)
	indicator.BackgroundTransparency = 1
	indicator.BorderSizePixel = 0
	indicator.Position = UDim2.new(0, 0, 1, -3)
	indicator.Size = UDim2.new(1, 0, 0, 3)
	Instance.new("UICorner", indicator).CornerRadius = UDim.new(1, 0)

	-- Icon
	local icon = Instance.new("TextLabel", btn)
	icon.Name = "Icon"
	icon.BackgroundTransparency = 1
	icon.Size = UDim2.new(1, 0, 0.5, 2)
	icon.Font = Enum.Font.GothamBold
	icon.Text = tabIcon
	icon.TextColor3 = Color3.fromRGB(170, 170, 190)
	icon.TextSize = 16
	icon.TextYAlignment = Enum.TextYAlignment.Bottom

	-- Label
	local label = Instance.new("TextLabel", btn)
	label.Name = "Label"
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 0, 0.5, -2)
	label.Size = UDim2.new(1, 0, 0.5, 2)
	label.Font = Enum.Font.GothamSemibold
	label.Text = tabName
	label.TextColor3 = Color3.fromRGB(170, 170, 190)
	label.TextSize = 11
	label.TextYAlignment = Enum.TextYAlignment.Top
	label.TextTruncate = Enum.TextTruncate.AtEnd

	-- Content page
	local page = Instance.new("ScrollingFrame", self.ContentArea)
	page.Name = tabName
	page.BackgroundTransparency = 1
	page.BorderSizePixel = 0
	page.Position = UDim2.new(0, 16, 0, 16)
	page.Size = UDim2.new(1, -32, 1, -32)
	page.ScrollBarThickness = 4
	page.ScrollBarImageColor3 = Color3.fromRGB(120, 160, 255)
	page.ScrollBarImageTransparency = 0.5
	page.CanvasSize = UDim2.new(0, 0, 0, 0)
	page.AutomaticCanvasSize = Enum.AutomaticSize.Y
	page.Visible = false

	local layout = Instance.new("UIListLayout", page)
	layout.Padding = UDim.new(0, 12)
	layout.SortOrder = Enum.SortOrder.LayoutOrder

	self.TabButtons[tabName] = btn
	self.TabPages[tabName] = page

	btn.MouseButton1Click:Connect(function()
		self:SwitchTab(tabName)
	end)

	if index == 1 then
		task.defer(function()
			self:SwitchTab(tabName)
		end)
	end

	local tab = {
		Name = tabName,
		Page = page,
		Library = self,
		_sectionOrder = 0
	}
	setmetatable(tab, {__index = UILib._TabMethods})
	table.insert(self.Tabs, tab)
	return tab
end

--=============================================
-- SWITCH TAB
--=============================================
function UILib:SwitchTab(name)
	if self.ActiveTab == name then return end
	self.ActiveTab = name

	for tabName, btn in pairs(self.TabButtons) do
		local ind = btn:FindFirstChild("Indicator")
		local lbl = btn:FindFirstChild("Label")
		local ico = btn:FindFirstChild("Icon")

		if tabName == name then
			TweenService:Create(btn, TweenInfo.new(0.3), {
				BackgroundColor3 = Color3.fromRGB(45, 50, 70),
				BackgroundTransparency = 0
			}):Play()
			if lbl then TweenService:Create(lbl, TweenInfo.new(0.3), {TextColor3 = Color3.new(1, 1, 1)}):Play() end
			if ico then TweenService:Create(ico, TweenInfo.new(0.3), {TextColor3 = Color3.new(1, 1, 1)}):Play() end
			if ind then TweenService:Create(ind, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play() end
		else
			TweenService:Create(btn, TweenInfo.new(0.3), {
				BackgroundColor3 = Color3.fromRGB(30, 30, 40),
				BackgroundTransparency = 0.4
			}):Play()
			if lbl then TweenService:Create(lbl, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(170, 170, 190)}):Play() end
			if ico then TweenService:Create(ico, TweenInfo.new(0.3), {TextColor3 = Color3.fromRGB(170, 170, 190)}):Play() end
			if ind then TweenService:Create(ind, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play() end
		end
	end

	for tabName, page in pairs(self.TabPages) do
		page.Visible = (tabName == name)
	end
end

--=============================================
-- DRAG SYSTEM
--=============================================
function UILib:_setupDrag()
	local dragging, dragInput, dragStart, startPos

	self.Main.InputBegan:Connect(function(input)
		if self._resizing then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = self.Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.Main.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging and not self._resizing then
			local delta = input.Position - dragStart
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			self.Main.Position = newPos
			self.Shadow.Position = newPos
		end
	end)
end

--=============================================
-- RESIZE SYSTEM
--=============================================
function UILib:_setupResize()
	local handle = Instance.new("Frame", self.Main)
	handle.Name = "ResizeHandle"
	handle.BackgroundTransparency = 1
	handle.Position = UDim2.new(1, -20, 1, -20)
	handle.Size = UDim2.new(0, 20, 0, 20)
	handle.ZIndex = 10

	for i = 0, 2 do
		local dot = Instance.new("Frame", handle)
		dot.BackgroundColor3 = Color3.fromRGB(120, 140, 200)
		dot.BackgroundTransparency = 0.5
		dot.BorderSizePixel = 0
		dot.Size = UDim2.new(0, 3, 0, 3)
		dot.Position = UDim2.new(1, -(4 + i * 5), 1, -(4 + i * 5))
		dot.AnchorPoint = Vector2.new(1, 1)
		Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
	end

	local btn = Instance.new("TextButton", handle)
	btn.BackgroundTransparency = 1
	btn.Size = UDim2.new(1, 16, 1, 16)
	btn.Position = UDim2.new(0, -8, 0, -8)
	btn.Text = ""

	local resizing = false
	local resizeStart, startSize, startPos

	btn.InputBegan:Connect(function(input)
		if self._minimized then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			self._resizing = true
			resizeStart = input.Position
			startSize = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
			startPos = self.Main.Position
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			resizing = false
			self._resizing = false
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local newW = math.clamp(startSize.X + delta.X, 400, 1400)
			local newH = math.clamp(startSize.Y + delta.Y, self.HeaderTotal + 200, 1000)

			local deltaW = newW - startSize.X
			local deltaH = newH - startSize.Y

			self.Main.Size = UDim2.new(0, newW, 0, newH)
			self.Main.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + deltaW / 2,
				startPos.Y.Scale, startPos.Y.Offset + deltaH / 2
			)
			self.Size = UDim2.new(0, newW, 0, newH)
			self.Shadow.Size = UDim2.new(0, newW + 40, 0, newH + 40)
			self.Shadow.Position = self.Main.Position
		end
	end)

	self.ResizeHandle = handle
end

--=============================================
-- ANTI-AFK SYSTEM
--=============================================
function UILib:_startAntiAFK()
	local player = Players.LocalPlayer
	if player then
		player.Idled:Connect(function()
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			end)
		end)
	end

	self._antiAfkActive = true
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			task.wait(60)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F13, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F13, false, game)
			end)
		end
	end)

	-- Anti-AFK Indicator
	local indicator = Instance.new("Frame", self.TitleBar)
	indicator.BackgroundColor3 = Color3.fromRGB(60, 220, 120)
	indicator.BackgroundTransparency = 0.2
	indicator.BorderSizePixel = 0
	indicator.Position = UDim2.new(0, 330, 0.5, -11)
	indicator.Size = UDim2.new(0, 90, 0, 22)
	Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 11)

	local dot = Instance.new("Frame", indicator)
	dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	dot.BorderSizePixel = 0
	dot.Position = UDim2.new(0, 7, 0.5, -4)
	dot.Size = UDim2.new(0, 8, 0, 8)
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	local label = Instance.new("TextLabel", indicator)
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 20, 0, 0)
	label.Size = UDim2.new(1, -20, 1, 0)
	label.Font = Enum.Font.GothamBold
	label.Text = "Anti-AFK"
	label.TextColor3 = Color3.new(1, 1, 1)
	label.TextSize = 10
	label.TextXAlignment = Enum.TextXAlignment.Left

	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {BackgroundTransparency = 0.7}):Play()
			task.wait(1)
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {BackgroundTransparency = 0}):Play()
			task.wait(1)
		end
	end)
end

