-- PUBLIC: CreateToggleButton
-- ─────────────────────────────────────────────
function NexusLib:CreateToggleButton(config)
	config = config or {}
	local icon = config.Icon or "⚡"
	local old = game.CoreGui:FindFirstChild("NexusLib_Toggle")
	if old then old:Destroy() end

	local sg = make("ScreenGui", {Name="NexusLib_Toggle", ResetOnSpawn=false, ZIndexBehavior=Enum.ZIndexBehavior.Sibling}, game.CoreGui)
	local sz = self.IsMobile and 40 or 48

	local outer = make("Frame", {
		AnchorPoint = Vector2.new(0.5,0.5),
		BackgroundColor3 = Theme.BG2,
		BorderSizePixel = 0,
		Position = UDim2.new(0, sz/2+8, 0.5, 0),
