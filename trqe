--=============================================
-- DRAG
--=============================================
function UILib:_setupDrag()
	local dragging, dragInput, dragStart, startPos

	self.Main.InputBegan:Connect(function(input)
		if self._resizing then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = self.Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.Main.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging and not self._resizing then
			local delta = input.Position - dragStart
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			TweenService:Create(self.Main, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
				Position = newPos
			}):Play()
			self.Shadow.Position = newPos
		end
	end)
end

--=============================================
-- RESIZE
--=============================================
function UILib:_setupResize()
	local handleSize = 22
	local minW = 320
	local minH = 200
	local screen = getScreenSize()
	local maxW = math.min(screen.X - 10, 1200)
	local maxH = math.min(screen.Y - 20, 900)

	local handle = Instance.new("Frame", self.Main)
	handle.Name = "ResizeHandle"
	handle.BackgroundTransparency = 1
	handle.Position = UDim2.new(1, -handleSize, 1, -handleSize)
	handle.Size = UDim2.new(0, handleSize, 0, handleSize)
	handle.ZIndex = 10

	-- Grip dots
	local gripDots = {}
	for row = 0, 2 do
		for col = 0, 2 - row do
			local dot = Instance.new("Frame", handle)
			dot.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
			dot.BackgroundTransparency = 0.3
			dot.BorderSizePixel = 0
			dot.Size = UDim2.new(0, 2, 0, 2)
			dot.Position = UDim2.new(1, -(3 + col * 5), 1, -(3 + row * 5))
			dot.AnchorPoint = Vector2.new(1, 1)
			dot.ZIndex = 10
			Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
			table.insert(gripDots, dot)
		end
	end

	local btn = Instance.new("TextButton", handle)
	btn.BackgroundTransparency = 1
	btn.Position = UDim2.new(0, -8, 0, -8)
	btn.Size = UDim2.new(1, 16, 1, 16)
	btn.Text = ""
	btn.ZIndex = 11
	btn.Active = true
	btn.AutoButtonColor = false

	local resizing = false
	local resizeStart, startSize, startPos

	local function setDotColor(color, trans)
		for _, d in ipairs(gripDots) do
			if d and d.Parent then
				TweenService:Create(d, TweenInfo.new(0.2), {
					BackgroundColor3 = color, BackgroundTransparency = trans
				}):Play()
			end
		end
	end

	btn.InputBegan:Connect(function(input)
		if self._minimized then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			self._resizing = true
			resizeStart = input.Position
			startSize = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
			startPos = self.Main.Position
			setDotColor(Color3.fromRGB(210, 210, 210), 0)
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					resizing = false
					self._resizing = false
					setDotColor(Color3.fromRGB(80, 80, 80), 0.3)
				end
			end)
		end
	end)

	btn.MouseEnter:Connect(function()
		if not resizing then setDotColor(Color3.fromRGB(150, 150, 150), 0) end
	end)
	btn.MouseLeave:Connect(function()
		if not resizing then setDotColor(Color3.fromRGB(80, 80, 80), 0.3) end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local newW = math.clamp(startSize.X + delta.X, minW, maxW)
			local newH = math.clamp(startSize.Y + delta.Y, minH, maxH)
			local deltaW = newW - startSize.X
			local deltaH = newH - startSize.Y
			local newSize = UDim2.new(0, newW, 0, newH)
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + deltaW / 2,
				startPos.Y.Scale, startPos.Y.Offset + deltaH / 2
			)
			self.Main.Size = newSize
			self.Main.Position = newPos
			self.Size = newSize
			self.Shadow.Size = newSize + UDim2.new(0, 46, 0, 46)
			self.Shadow.Position = newPos
		end
	end)

	self.ResizeHandle = handle
end

--=============================================
-- ANTI-AFK
--=============================================
function UILib:_startAntiAFK()
	local player = Players.LocalPlayer
	if player then
		self._antiAfkIdleConnection = player.Idled:Connect(function()
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
				task.wait(0.12)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			end)
		end)
	end

	self._antiAfkActive = true

	self._antiAfkThread = task.spawn(function()
		while self._antiAfkActive do
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			task.wait(50)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F13, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F13, false, game)
			end)
		end
	end)

	self._antiAfkMouseThread = task.spawn(function()
		while self._antiAfkActive do
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			task.wait(90)
			if not self._antiAfkActive then break end
			pcall(function()
				local x, y = math.random(200, 600), math.random(200, 600)
				VirtualInputManager:SendMouseMoveEvent(x, y, game)
				task.wait(0.05)
				VirtualInputManager:SendMouseMoveEvent(x + 1, y + 1, game)
			end)
		end
	end)

	self._antiAfkHeartbeat = task.spawn(function()
		while self._antiAfkActive do
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			task.wait(180)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.RightShift, false, game)
				task.wait(0.05)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.RightShift, false, game)
			end)
		end
	end)

	self:_createAntiAfkIndicator()
end

function UILib:_createAntiAfkIndicator()
	-- Small pill next to title
	local indicator = Instance.new("Frame", self.TitleBar)
	indicator.Name = "AntiAfk"
	indicator.BackgroundColor3 = Color3.fromRGB(0, 146, 214)
	indicator.BackgroundTransparency = 0.85
	indicator.BorderSizePixel = 0
	indicator.ZIndex = 7

	-- Position it after title but before buttons
	indicator.AnchorPoint = Vector2.new(0, 0.5)
	indicator.Position = UDim2.new(0, self.IsMobile and 130 or 180, 0.5, 0)
	indicator.Size = UDim2.new(0, 46, 0, 18)
	Instance.new("UICorner", indicator).CornerRadius = UDim.new(1, 0)

	local dotSize = 5
	local dot = Instance.new("Frame", indicator)
	dot.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
	dot.BorderSizePixel = 0
	dot.Position = UDim2.new(0, 6, 0.5, -dotSize / 2)
	dot.Size = UDim2.new(0, dotSize, 0, dotSize)
	dot.ZIndex = 8
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	local label = Instance.new("TextLabel", indicator)
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, dotSize + 10, 0, 0)
	label.Size = UDim2.new(1, -(dotSize + 14), 1, 0)
	label.Font = Enum.Font.GothamBold
	label.Text = "AFK"
	label.TextColor3 = Color3.fromRGB(0, 200, 100)
	label.TextSize = 8
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 8

	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			if dot and dot.Parent then
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {BackgroundTransparency = 0.6}):Play()
				task.wait(1)
				if not (dot and dot.Parent) then break end
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {BackgroundTransparency = 0}):Play()
				task.wait(1)
			else break end
		end
	end)
end

