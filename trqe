--=============================================
-- FUNGSI UTAMA: Buat Window
--=============================================
function UILib.new(config)
	local self = setmetatable({}, UILib)

	self.Title = config.Title or "My Hub"
	self.Tabs = {}
	self.TabButtons = {}
	self.TabPages = {}
	self.ActiveTab = nil
	self.UpdateCallbacks = {}
	self.IsMobile = isMobile()
	self.Scale = getScale()

	-- Rayfield-style sizing
	local screen = getScreenSize()
	if config.Size then
		self.Size = config.Size
	else
		if self.IsMobile then
			local w = math.clamp(screen.X * 0.88, 320, 520)
			local h = math.clamp(screen.Y * 0.55, 260, 380)
			self.Size = UDim2.new(0, w, 0, h)
		else
			self.Size = UDim2.new(0, 580, 0, 460)
		end
	end

	-- Layout dimensions
	if self.IsMobile then
		self.SidebarWidth = 105
		self.TitleBarHeight = 36
		self.FontTitle = 13
		self.FontTab = 10
		self.FontElement = 11
		self.FontSmall = 9
		self.ElementHeight = 30
		self.SectionPadding = 8
		self.TabButtonHeight = 30
		self.TabButtonSpacing = 34
	else
		self.SidebarWidth = 150
		self.TitleBarHeight = 44
		self.FontTitle = 16
		self.FontTab = 12
		self.FontElement = 13
		self.FontSmall = 10
		self.ElementHeight = 36
		self.SectionPadding = 12
		self.TabButtonHeight = 34
		self.TabButtonSpacing = 40
	end

	self.TopBarH = 2
	self.HeaderTotal = self.TopBarH + self.TitleBarHeight

	self._resizing = false
	self._minimized = false
	self._antiAfkConnections = {}

	-- Cleanup old
	local oldGui = game.CoreGui:FindFirstChild("UILib_Main")
	if oldGui then oldGui:Destroy() end

	-- ScreenGui
	self.ScreenGui = Instance.new("ScreenGui")
	self.ScreenGui.Name = "UILib_Main"
	self.ScreenGui.Parent = game.CoreGui
	self.ScreenGui.ResetOnSpawn = false
	self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

	-- Shadow (softer)
	self.Shadow = Instance.new("ImageLabel", self.ScreenGui)
	self.Shadow.AnchorPoint = Vector2.new(0.5, 0.5)
	self.Shadow.BackgroundTransparency = 1
	self.Shadow.Position = UDim2.new(0.5, 0, 0.5, 0)
	self.Shadow.Size = self.Size + UDim2.new(0, 40, 0, 40)
	self.Shadow.Image = "rbxassetid://5554236805"
	self.Shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
	self.Shadow.ImageTransparency = 0.55
	self.Shadow.ScaleType = Enum.ScaleType.Slice
	self.Shadow.SliceCenter = Rect.new(23, 23, 277, 277)

	-- Main Frame
	self.Main = Instance.new("Frame", self.ScreenGui)
	self.Main.Name = "Main"
	self.Main.AnchorPoint = Vector2.new(0.5, 0.5)
	self.Main.BackgroundColor3 = Colors.Background
	self.Main.BorderSizePixel = 0
	self.Main.Position = UDim2.new(0.5, 0, 0.5, 0)
	self.Main.Size = self.Size
	self.Main.ClipsDescendants = true

	local corner = Instance.new("UICorner", self.Main)
	corner.CornerRadius = UDim.new(0, self.IsMobile and 10 or 12)

	local stroke = Instance.new("UIStroke", self.Main)
	stroke.Color = Colors.BorderAccent
	stroke.Thickness = 1
	stroke.Transparency = 0.6

	-- Subtle inner glow
	local innerGlow = Instance.new("Frame", self.Main)
	innerGlow.Name = "InnerGlow"
	innerGlow.BackgroundTransparency = 1
	innerGlow.Size = UDim2.new(1, 0, 1, 0)
	innerGlow.ZIndex = 0

	-- Drag
	self:_setupDrag()

	-- Animated top bar
	self:_createAnimatedBar()

	-- Title Bar
	self:_createTitleBar()

	-- Sidebar
	self:_createSidebar()

	-- Content Area
	self.ContentArea = Instance.new("Frame", self.Main)
	self.ContentArea.BackgroundColor3 = Colors.SurfaceLight
	self.ContentArea.BorderSizePixel = 0
	self.ContentArea.Position = UDim2.new(0, self.SidebarWidth, 0, self.HeaderTotal)
	self.ContentArea.Size = UDim2.new(1, -self.SidebarWidth, 1, -self.HeaderTotal)

	-- Subtle gradient on content area
	local contentGrad = Instance.new("UIGradient", self.ContentArea)
	contentGrad.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(24, 24, 34)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 20, 28))
	}
	contentGrad.Rotation = 180

	-- Notification Bar
	self:_createNotifyBar()

	-- Status Labels
	self.StatusLabels = {}
	self:_createStatusArea()

	-- Resize Handle
	self:_setupResize()

	-- Anti-AFK (improved)
	self:_startAntiAFK()

	-- Open animation
	self.Main.Size = UDim2.new(0, 0, 0, 0)
	self.Main.BackgroundTransparency = 0.5
	self.Shadow.ImageTransparency = 1

	TweenService:Create(self.Main, TweenInfo.new(0.45, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = self.Size,
		BackgroundTransparency = 0
	}):Play()
	TweenService:Create(self.Shadow, TweenInfo.new(0.5), {
		ImageTransparency = 0.55
	}):Play()

	-- Start update loop
	self:_startUpdateLoop()

	return self
end

--=============================================
-- INTERNAL: Anti-AFK System (Improved - Multi-layer)
--=============================================
function UILib:_startAntiAFK()
	self._antiAfkActive = true

	-- Layer 1: Idled event handler
	local player = Players.LocalPlayer
	if player then
		local idleConn = player.Idled:Connect(function()
			if not self._antiAfkActive then return end
			pcall(function()
				VirtualUser:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
				task.wait(0.1)
				VirtualUser:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
			end)
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
				task.wait(0.05)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			end)
		end)
		table.insert(self._antiAfkConnections, idleConn)
	end

	-- Layer 2: Periodic key simulation (every 45s)
	self._antiAfkThread1 = task.spawn(function()
		while self._antiAfkActive do
			task.wait(45)
			if not self._antiAfkActive then break end
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F13, false, game)
				task.wait(0.05)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F13, false, game)
			end)
		end
	end)

	-- Layer 3: Periodic mouse jiggle (every 90s)
	self._antiAfkThread2 = task.spawn(function()
		while self._antiAfkActive do
			task.wait(90)
			if not self._antiAfkActive then break end
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			pcall(function()
				local x = math.random(200, 600)
				local y = math.random(200, 400)
				VirtualInputManager:SendMouseMoveEvent(x, y, game)
				task.wait(0.05)
				VirtualInputManager:SendMouseMoveEvent(x + 1, y + 1, game)
			end)
		end
	end)

	-- Layer 4: VirtualUser heartbeat (most reliable)
	self._antiAfkHeartbeat = RunService.Heartbeat:Connect(function()
		if not self._antiAfkActive then return end
		-- VirtualUser CaptureController keeps the game thinking we're active
		pcall(function()
			VirtualUser:CaptureController()
		end)
	end)
	table.insert(self._antiAfkConnections, self._antiAfkHeartbeat)

	-- Layer 5: Periodic VirtualUser click (every 120s)
	self._antiAfkThread3 = task.spawn(function()
		while self._antiAfkActive do
			task.wait(120)
			if not self._antiAfkActive then break end
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			pcall(function()
				VirtualUser:Button1Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
				task.wait(0.05)
				VirtualUser:Button1Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
			end)
		end
	end)

	-- Create indicator
	self:_createAntiAfkIndicator()
end

--=============================================
-- INTERNAL: Anti-AFK Indicator (cleaner)
--=============================================
function UILib:_createAntiAfkIndicator()
	local dotSize = self.IsMobile and 5 or 6
	local fontSize = self.IsMobile and 7 or 8
	local offsetX = self.IsMobile and -80 or -110

	local indicator = Instance.new("Frame", self.TitleBar)
	indicator.Name = "AntiAfkIndicator"
	indicator.BackgroundTransparency = 1
	indicator.Position = UDim2.new(1, offsetX, 0.5, -8)
	indicator.Size = UDim2.new(0, 40, 0, 16)

	local dot = Instance.new("Frame", indicator)
	dot.Name = "Dot"
	dot.BackgroundColor3 = Colors.Success
	dot.BorderSizePixel = 0
	dot.Position = UDim2.new(0, 0, 0.5, -dotSize / 2)
	dot.Size = UDim2.new(0, dotSize, 0, dotSize)
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	-- Glow ring around dot
	local dotGlow = Instance.new("UIStroke", dot)
	dotGlow.Color = Colors.Success
	dotGlow.Thickness = 1
	dotGlow.Transparency = 0.5

	local label = Instance.new("TextLabel", indicator)
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, dotSize + 4, 0, 0)
	label.Size = UDim2.new(0, 28, 1, 0)
	label.Font = Enum.Font.GothamBold
	label.Text = "AFK"
	label.TextColor3 = Colors.Success
	label.TextSize = fontSize
	label.TextXAlignment = Enum.TextXAlignment.Left

	self._antiAfkDot = dot
	self._antiAfkDotGlow = dotGlow

	-- Pulse animation
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			if dot and dot.Parent then
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
					BackgroundTransparency = 0.5
				}):Play()
				TweenService:Create(dotGlow, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
					Transparency = 0.8
				}):Play()
				task.wait(1)
				if not (dot and dot.Parent) then break end
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
					BackgroundTransparency = 0
				}):Play()
				TweenService:Create(dotGlow, TweenInfo.new(1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
					Transparency = 0.4
				}):Play()
				task.wait(1)
			else
				break
			end
		end
	end)
end

--=============================================
-- INTERNAL: Drag System
--=============================================
function UILib:_setupDrag()
	local dragging, dragInput, dragStart, startPos

	self.Main.InputBegan:Connect(function(input)
		if self._resizing then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = self.Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.Main.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging and not self._resizing then
			local delta = input.Position - dragStart
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			self.Main.Position = newPos
			self.Shadow.Position = newPos
		end
	end)
end

--=============================================
-- INTERNAL: Resize System (smoother)
--=============================================
function UILib:_setupResize()
	local handleSize = self.IsMobile and 22 or 20
	local dotSize = self.IsMobile and 2 or 2
	local dotGap = self.IsMobile and 3 or 3

	local minW = self.SidebarWidth + (self.IsMobile and 90 or 160)
	local minH = self.HeaderTotal + (self.IsMobile and 70 or 100)
	local screen = getScreenSize()
	local maxW = math.min(screen.X - 10, 1200)
	local maxH = math.min(screen.Y - 20, 900)

	local handle = Instance.new("Frame", self.Main)
	handle.Name = "ResizeHandle"
	handle.BackgroundTransparency = 1
	handle.Position = UDim2.new(1, -handleSize, 1, -handleSize)
	handle.Size = UDim2.new(0, handleSize, 0, handleSize)
	handle.ZIndex = 10

	local gripDots = {}
	for row = 0, 2 do
		for col = 0, 2 - row do
			local dot = Instance.new("Frame", handle)
			dot.Name = "GripDot"
			dot.BackgroundColor3 = Colors.TextMuted
			dot.BackgroundTransparency = 0.4
			dot.BorderSizePixel = 0
			dot.Size = UDim2.new(0, dotSize, 0, dotSize)
			dot.Position = UDim2.new(
				1, -(2 + col * (dotSize + dotGap)),
				1, -(2 + row * (dotSize + dotGap))
			)
			dot.AnchorPoint = Vector2.new(1, 1)
			dot.ZIndex = 10
			Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
			table.insert(gripDots, dot)
		end
	end

	local hitPad = self.IsMobile and 12 or 8
	local btn = Instance.new("TextButton", handle)
	btn.Name = "ResizeBtn"
	btn.BackgroundTransparency = 1
	btn.Position = UDim2.new(0, -hitPad, 0, -hitPad)
	btn.Size = UDim2.new(1, hitPad * 2, 1, hitPad * 2)
	btn.Text = ""
	btn.ZIndex = 11
	btn.Active = true
	btn.AutoButtonColor = false

	local resizing = false
	local resizeStart, startSize, startPos

	local function setDotStyle(color, transparency)
		for _, d in ipairs(gripDots) do
			if d and d.Parent then
				TweenService:Create(d, TweenInfo.new(0.15), {
					BackgroundColor3 = color,
					BackgroundTransparency = transparency
				}):Play()
			end
		end
	end

	btn.InputBegan:Connect(function(input)
		if self._minimized then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			self._resizing = true
			resizeStart = input.Position
			startSize = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
			startPos = self.Main.Position

			setDotStyle(Colors.AccentGlow, 0)

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					resizing = false
					self._resizing = false
					setDotStyle(Colors.TextMuted, 0.4)
				end
			end)
		end
	end)

	btn.MouseEnter:Connect(function()
		if not resizing then
			setDotStyle(Colors.AccentLight, 0.1)
		end
	end)
	btn.MouseLeave:Connect(function()
		if not resizing then
			setDotStyle(Colors.TextMuted, 0.4)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local newW = math.clamp(startSize.X + delta.X, minW, maxW)
			local newH = math.clamp(startSize.Y + delta.Y, minH, maxH)

			local deltaW = newW - startSize.X
			local deltaH = newH - startSize.Y

			local newSize = UDim2.new(0, newW, 0, newH)
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + deltaW / 2,
				startPos.Y.Scale, startPos.Y.Offset + deltaH / 2
			)

			self.Main.Size = newSize
			self.Main.Position = newPos
			self.Size = newSize
			self.Shadow.Size = newSize + UDim2.new(0, 40, 0, 40)
			self.Shadow.Position = newPos
		end
	end)

	self.ResizeHandle = handle
end

--=============================================
-- INTERNAL: Animated Bar (cleaner gradient)
--=============================================
function UILib:_createAnimatedBar()
	local bar = Instance.new("Frame", self.Main)
	bar.BackgroundColor3 = Color3.new(1, 1, 1)
	bar.BorderSizePixel = 0
	bar.Size = UDim2.new(1, 0, 0, self.TopBarH)

	local gradient = Instance.new("UIGradient", bar)
	gradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Colors.GradientStart),
		ColorSequenceKeypoint.new(0.5, Colors.GradientMid),
		ColorSequenceKeypoint.new(1, Colors.GradientEnd)
	}

	task.spawn(function()
		local t = 0
		while self.ScreenGui and self.ScreenGui.Parent do
			t = t + 0.008
			if t > 1 then t = t - 2 end
			gradient.Offset = Vector2.new(math.abs(t), 0)
			task.wait(0.03)
		end
	end)
end

