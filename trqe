--=============================================
-- SWITCH TAB
--=============================================
function UILib:SwitchTab(name)
	if self.ActiveTab == name then return end
	self.ActiveTab = name

	for tabName, btn in pairs(self.TabButtons) do
		local lbl = btn:FindFirstChild("Title")
		local shadow = btn:FindFirstChild("Shadow")
		local stroke = btn:FindFirstChildOfClass("UIStroke")

		if tabName == name then
			TweenService:Create(btn, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
				BackgroundColor3 = Color3.fromRGB(210, 210, 210),
				BackgroundTransparency = 0
			}):Play()
			if lbl then
				TweenService:Create(lbl, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
					TextColor3 = Color3.fromRGB(50, 50, 50),
					TextTransparency = 0
				}):Play()
			end
			if stroke then
				TweenService:Create(stroke, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {Transparency = 1}):Play()
			end
			if shadow then
				TweenService:Create(shadow, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {ImageTransparency = 0.9}):Play()
			end
		else
			TweenService:Create(btn, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
				BackgroundColor3 = Color3.fromRGB(80, 80, 80),
				BackgroundTransparency = 0.7
			}):Play()
			if lbl then
				TweenService:Create(lbl, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
					TextColor3 = Color3.fromRGB(240, 240, 240),
					TextTransparency = 0.2
				}):Play()
			end
			if stroke then
				TweenService:Create(stroke, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {Transparency = 0}):Play()
			end
			if shadow then
				TweenService:Create(shadow, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {ImageTransparency = 0.7}):Play()
			end
		end
	end

	for tabName, page in pairs(self.TabPages) do
		page.Visible = (tabName == name)
	end
end

--=============================================
-- UPDATE LOOP
--=============================================
function UILib:OnUpdate(callback)
	table.insert(self.UpdateCallbacks, callback)
end

function UILib:_startUpdateLoop()
	task.spawn(function()
		while self.ScreenGui and self.ScreenGui.Parent do
			for _, cb in ipairs(self.UpdateCallbacks) do pcall(cb) end
			task.wait(0.5)
		end
	end)
end

