		Size=UDim2.new(1,-52,1,0),
		Font=T.FM,
		Text=cfg.Text or "Toggle",
		TextColor3=T.TX1,
		TextSize=lib.FS.elem,
		TextXAlignment=Enum.TextXAlignment.Left,
		TextTruncate=Enum.TextTruncate.AtEnd,
	})

	local tW=lib.Mobile and 34 or 38
	local tH=lib.Mobile and 18 or 21
	local kS=tH-5

	local track=inst("Frame",row,{
		BackgroundColor3=val and T.Acc or T.BG5,
		BorderSizePixel=0,
		Position=UDim2.new(1,-(tW+2),.5,-tH/2),
		Size=UDim2.new(0,tW,0,tH),
	})
	corner(track,99)
	stroke(track,T.Bdr,1,0)

	local knob=inst("Frame",track,{
		BackgroundColor3=Color3.new(1,1,1),
		BorderSizePixel=0,
		Position=val and UDim2.new(1,-(kS+2),.5,-kS/2) or UDim2.new(0,2,.5,-kS/2),
		Size=UDim2.new(0,kS,0,kS),
	})
	corner(knob,99)

	local active=val
	local function refresh()
		tw(track,{BackgroundColor3=active and T.Acc or T.BG5},.2):Play()
		tw(knob,{Position=active and UDim2.new(1,-(kS+2),.5,-kS/2) or UDim2.new(0,2,.5,-kS/2)},.2,Enum.EasingStyle.Back):Play()
	end

	local ca=inst("TextButton",row,{BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text=""})
	ca.MouseButton1Click:Connect(function() active=not active; refresh(); cb(active) end)

	return {
		Frame=row,
		SetValue=function(_,v) active=v; refresh() end,
		GetValue=function() return active end,
	}
end

