		Size     = UDim2.new(0,kS,0,kS),
	}, track)
	corner(knob, 99)

	local active = val
	local function refresh()
		tw(track, {BackgroundColor3 = active and Theme.Accent or Theme.BG4}, 0.2):Play()
		tw(knob,  {Position = active and UDim2.new(1,-(kS+3),0.5,-kS/2) or UDim2.new(0,3,0.5,-kS/2)}, 0.2):Play()
