		if isActive then stroke(b, c, 1, 0.4) end

		make("TextLabel", {
			BackgroundTransparency = 1,
			Size = UDim2.new(1,0,0,gh*.5),
			Text = item.icon or "□",
			TextSize = lib.IsMobile and 16 or 22,
			Font = Theme.FontH,
			TextColor3 = isActive and c or Theme.Text2,
