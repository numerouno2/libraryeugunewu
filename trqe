-- AddToggle
function UILib._SectionMethods:AddToggle(config)
	self._elementOrder = self._elementOrder + 1
	local text     = config.Text     or "Toggle"
	local default  = config.Default  or false
	local callback = config.Callback or function()end
	local order    = config.Order    or self._elementOrder
	local lib      = self.Library
	local h        = lib.ElementHeight

	local row = N("Frame", W(self), {
		BackgroundTransparency = 1,
		BorderSizePixel        = 0,
		Size        = UDim2.new(1,0,0,h),
		LayoutOrder = order,
	})
	N("TextLabel", row, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,0,0,0),
		Size     = UDim2.new(1,-52,1,0),
		Font     = D.FSB,
		Text     = text,
		TextColor3 = D.T1,
		TextSize   = lib.FontElement,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate   = Enum.TextTruncate.AtEnd,
	})

	local tW = lib.IsMobile and 34 or 38
	local tH = lib.IsMobile and 18 or 21
	local kS = tH - 5

	local track = N("Frame", row, {
		BackgroundColor3 = default and D.ACC or D.BG5,
		BorderSizePixel  = 0,
		Position = UDim2.new(1,-(tW+2),.5,-tH/2),
		Size     = UDim2.new(0,tW,0,tH),
	})
	corner(track, 99)
	stroke(track, D.BD, 1, 0)

	local knob = N("Frame", track, {
		BackgroundColor3 = Color3.new(1,1,1),
		BorderSizePixel  = 0,
		Position = default and UDim2.new(1,-(kS+2),.5,-kS/2) or UDim2.new(0,2,.5,-kS/2),
		Size     = UDim2.new(0,kS,0,kS),
	})
	corner(knob, 99)

	local active = default
	local function refresh()
		T(track, {BackgroundColor3 = active and D.ACC or D.BG5}, .2):Play()
		T(knob, {Position = active
			and UDim2.new(1,-(kS+2),.5,-kS/2)
			or  UDim2.new(0,2,.5,-kS/2)}, .2, Enum.EasingStyle.Back):Play()
	end

	local ca = N("TextButton", row, {BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Text=""})
	ca.MouseButton1Click:Connect(function() active=not active; refresh(); callback(active) end)
	if active then refresh() end

	return {
		Frame    = row,
		SetValue = function(_, v) active=v; refresh() end,
		GetValue = function() return active end,
	}
end

