function UILib:_createNotifyBar()
	self.NotifyBar = Instance.new("TextLabel", self.Main)
	self.NotifyBar.BackgroundColor3 = Color3.fromRGB(60, 180, 100)
	self.NotifyBar.BackgroundTransparency = 1
	self.NotifyBar.Position = UDim2.new(0, 12, 1, -35)
	self.NotifyBar.Size = UDim2.new(1, -24, 0, 28)
	self.NotifyBar.Font = Enum.Font.GothamSemibold
	self.NotifyBar.Text = ""
	self.NotifyBar.TextColor3 = Color3.new(1, 1, 1)
	self.NotifyBar.TextSize = 12
	self.NotifyBar.TextXAlignment = Enum.TextXAlignment.Left
	self.NotifyBar.TextTransparency = 1
	Instance.new("UICorner", self.NotifyBar).CornerRadius = UDim.new(0, 8)
	Instance.new("UIPadding", self.NotifyBar).PaddingLeft = UDim.new(0, 12)
	self._notifyDebounce = false
end

function UILib:Notify(msg, color)
	if self._notifyDebounce then return end
	self._notifyDebounce = true

	self.NotifyBar.Text = msg
	self.NotifyBar.BackgroundColor3 = color or Color3.fromRGB(60, 180, 100)
	TweenService:Create(self.NotifyBar, TweenInfo.new(0.3), {TextTransparency = 0, BackgroundTransparency = 0.2}):Play()
	
	task.delay(2.5, function()
		if self.NotifyBar then
			TweenService:Create(self.NotifyBar, TweenInfo.new(0.5), {TextTransparency = 1, BackgroundTransparency = 1}):Play()
		end
		self._notifyDebounce = false
	end)
end

--=============================================
-- UPDATE LOOP
--=============================================
function UILib:OnUpdate(callback)
	table.insert(self.UpdateCallbacks, callback)
end

function UILib:_startUpdateLoop()
	task.spawn(function()
		while self.ScreenGui and self.ScreenGui.Parent do
			for _, cb in ipairs(self.UpdateCallbacks) do
				pcall(cb)
			end
			task.wait(0.5)
		end
	end)
end

