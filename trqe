	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextTruncate = Enum.TextTruncate.AtEnd

	local toggleW = 36
	local toggleH = 20
	local knobSize = 14

	local bg = Instance.new("Frame", frame)
	bg.BackgroundColor3 = Color3.fromRGB(42, 42, 58)
	bg.BorderSizePixel = 0
	bg.Position = UDim2.new(1, -(toggleW + 10), 0.5, -toggleH / 2)
	bg.Size = UDim2.new(0, toggleW, 0, toggleH)
	Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("Frame", bg)
	knob.BackgroundColor3 = Color3.fromRGB(130, 130, 155)
	knob.BorderSizePixel = 0
	knob.Position = UDim2.new(0, 3, 0.5, -knobSize / 2)
	knob.Size = UDim2.new(0, knobSize, 0, knobSize)
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local active = default

	local function updateVisual(animate)
		local info = animate ~= false and TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out) or TweenInfo.new(0)
		if active then
			TweenService:Create(bg, info, { BackgroundColor3 = Color3.fromRGB(48, 175, 105) }):Play()
			TweenService:Create(knob, info, {
				Position = UDim2.new(1, -(knobSize + 3), 0.5, -knobSize / 2),
				BackgroundColor3 = Color3.new(1, 1, 1)
			}):Play()
		else
			TweenService:Create(bg, info, { BackgroundColor3 = Color3.fromRGB(42, 42, 58) }):Play()
			TweenService:Create(knob, info, {
				Position = UDim2.new(0, 3, 0.5, -knobSize / 2),
				BackgroundColor3 = Color3.fromRGB(130, 130, 155)
			}):Play()
		end
	end

	frame.MouseEnter:Connect(function()
		TweenService:Create(frame, TweenInfo.new(0.12), { BackgroundTransparency = 0 }):Play()
	end)
	frame.MouseLeave:Connect(function()
		TweenService:Create(frame, TweenInfo.new(0.12), { BackgroundTransparency = 0.15 }):Play()
	end)

	local clickBtn = Instance.new("TextButton", frame)
	clickBtn.BackgroundTransparency = 1
	clickBtn.Size = UDim2.new(1, 0, 1, 0)
	clickBtn.Text = ""
	clickBtn.ZIndex = 2

	clickBtn.MouseButton1Click:Connect(function()
		active = not active
		updateVisual(true)
		callback(active)
	end)

	if active then updateVisual(false) end

	return {
		Frame = frame,
		SetValue = function(_, val) active = val; updateVisual(true) end,
		GetValue = function() return active end
	}
end

