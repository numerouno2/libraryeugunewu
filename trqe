UILib._InternalTabs = {} -- Store references

-- Create Table Metatable
local NewTable = function(library, tabObject)
	local meta = {}
	meta.Library = library
	meta.TabName = tabObject.TabName
	meta.Page = tabObject.Page
	meta._order = 0
	
	function meta:AddSection(cfg)
		cfg = cfg or {}
		local title = cfg.Title or "Section"
		self._order += 1
		
		local sec = Instance.new("Frame", self.Page)
		sec.BackgroundTransparency = 1
		sec.Size = UDim2.new(1, 0, 0, 0)
		sec.AutomaticSize = Enum.AutomaticSize.Y
		sec.LayoutOrder = self._order
		
		local inner = Instance.new("Frame", sec)
		inner.BackgroundColor3 = THEME.Background
		inner.BorderSizePixel = 0
		inner.Size = UDim2.new(1, 0, 0, 0)
		inner.AutomaticSize = Enum.AutomaticSize.Y
		inner.LayoutOrder = self._order
		Instance.new("UICorner", inner).CornerRadius = UDim.new(0, 12)

		local stroke = Instance.new("UIStroke", inner)
		stroke.Color = THEME.AccentDark
		stroke.Transparency = 0.7
		stroke.Thickness = 1
		
		local pad = Instance.new("UIPadding", inner)
		pad.PaddingLeft = UDim.new(0, 20)
		pad.PaddingRight = UDim.new(0, 20)
		pad.PaddingTop = UDim.new(0, 20)
		pad.PaddingBottom = UDim.new(0, 20)
		
		local layout = Instance.new("UIListLayout", inner)
		layout.Padding = UDim.new(0, 12)
		layout.SortOrder = Enum.SortOrder.LayoutOrder

		local tlbl = Instance.new("TextLabel", inner)
		tlbl.BackgroundTransparency = 1
		tlbl.Size = UDim2.new(1, 0, 0, self.Library.ElementH - 8)
		tlbl.Font = Enum.Font.GothamBold
		tlbl.Text = title
		tlbl.TextColor3 = THEME.TextSecondary
		tlbl.TextSize = self.Library.Font.Element
		tlbl.LayoutOrder = -1
		tlbl.TextXAlignment = Enum.TextXAlignment.Left
		
		local secMeta = {
			Frame = inner,
			Tab = self,
			Library = self.Library,
			_order = 0
		}
		setmetatable(secMeta, {__index = UILib._SecMethods})
		return secMeta
	end
	
	return meta
end

setmetatable(meta = {}, {
	__index = function(t, k)
		local mt = getmetatable(t)
		if mt and mt.Library then
			return mt.Library[_SecMethods][k] or mt.Library._SecMethods[k]
		end
	end
})

-- Assign global metatables
UILib._SecMethods = {}
UILib._TabMethods = NewTable(UILib, {})
setmetatable(UILib._TabMethods, {__index = function(t, k)
	if not UILib._SecMethods[k] then return end
	local base = t.Library._InternalTabs
	local currentTab = base[1]
	return currentTab[k](currentTab, ...) -- Call dynamically
end})
setmetatable(UILib._SecMethods, {
	__index = function(t, k)
		if k == "AddToggle" then return UILib._CreateToggle end
		if k == "AddButton" then return UILib._CreateButton end
		if k == "AddLabel" then return UILib._CreateLabel end
		if k == "AddTextBox" then return UILib._CreateTextBox end
		if k == "AddNote" then return UILib._CreateNote end
	end
})

-- Helper Constructors for UI Elements (Cleaner than previous inline)
UILib._CreateToggle = function(self, config)
	config = config or {}
	local label = config.Text or "Toggle"
	local def = config.Default or false
	local func = config.Callback or function() end
	self._order += 1

	local f = Instance.new("Frame", self.Frame)
	f.BackgroundColor3 = THEME.Background
	f.BorderSizePixel = 0
	f.Size = UDim2.new(1, 0, 0, self.Library.ElementH)
	f.LayoutOrder = self._order
	Instance.new("UICorner", f).CornerRadius = UDim.new(0, 8)
	local stroke = Instance.new("UIStroke", f)
	stroke.Color = THEME.AccentDark
	stroke.Transparency = 0.7
	stroke.Thickness = 1

	local txt = Instance.new("TextLabel", f)
	txt.BackgroundTransparency = 1
	txt.Size = UDim2.new(1, -60, 1, 0)
	txt.Position = UDim2.new(0, 15, 0, 0)
	txt.Font = Enum.Font.GothamSemibold
	txt.Text = label
	txt.TextColor3 = THEME.TextSecondary
	txt.TextSize = self.Library.Font.Element
	txt.TextXAlignment = Enum.TextXAlignment.Left

	local w = self.Library.IsMobile and 32 or 42
	local h = self.Library.IsMobile and 18 or 22
	local knw = self.Library.IsMobile and 12 or 16

	local bg = Instance.new("Frame", f)
	bg.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
	bg.BorderSizePixel = 0
	bg.Position = UDim2.new(1, -w - 10, 0.5, 0)
	bg.Size = UDim2.new(0, w, 0, h)
	Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)
	
	local knob = Instance.new("Frame", bg)
	knob.BackgroundColor3 = THEME.TextSecondary
	knob.BorderSizePixel = 0
	knob.Size = UDim2.new(0, knw, 0, knw)
	knob.Position = UDim2.new(0, 3, 0.5, -knw/2)
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local active = def
	local function update()
		if active then
			TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = THEME.Accent}):Play()
			TweenService:Create(knob, TweenInfo.new(0.2), {BackgroundColor3 = Color3.new(1,1,1), Position = UDim2.new(1, -(knw + 3), 0.5, 0)}):Play()
		else
			TweenService:Create(bg, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(45, 45, 60)}):Play()
			TweenService:Create(knob, TweenInfo.new(0.2), {BackgroundColor3 = THEME.TextSecondary, Position = UDim2.new(0, 3, 0.5, -knw/2)}):Play()
		end
	end
	
	local btn = Instance.new("TextButton", f)
	btn.BackgroundTransparency = 1
	btn.Size = UDim2.new(1, 0, 1, 0)
	btn.Text = ""
	btn.MouseButton1Click:Connect(function()
		active = not active
		update()
		func(active)
	end)

	update()
	return {SetValue = function(_, val) active=val; update(); func(val); end, GetValue=function() return active end}
end

UILib._CreateButton = function(self, config)
	config = config or {}
	local text = config.Text or "Execute"
	local col = config.Color or THEME.Accent
	local func = config.Callback or function() end
	self._order += 1
	
	local b = Instance.new("TextButton", self.Frame)
	b.BackgroundTransparency = 1
	b.Size = UDim2.new(1, 0, 0, self.Library.ElementH)
	b.LayoutOrder = self._order
	b.Text = text
	b.TextColor3 = col
	b.Font = Enum.Font.GothamBold
	b.TextSize = 14
	b.TextXAlignment = Enum.TextXAlignment.Left
	b.Position = UDim2.new(0, 15, 0, 0)
	b.BackgroundTransparency = 1 -- Use Frame wrapper below for bg
	b.TextTransparency = 0
	b.AutoButtonColor = false

	local wrap = Instance.new("Frame", b)
	wrap.BackgroundTransparency = 1
	wrap.Size = b.Size
	wrap.Position = b.Position
	
	-- Actual Clickable Area
	local clickB = Instance.new("TextButton", self.Frame)
	clickB.BackgroundTransparency = 1
	clickB.Size = UDim2.new(1, 0, 0, self.Library.ElementH)
	clickB.LayoutOrder = self._order
	clickB.Text = ""
	clickB.MouseButton1Click:Connect(func)

	local rect = Instance.new("Frame", clickB)
	rect.BackgroundTransparency = 1
	rect.Size = clickB.Size
	rect.BackgroundColor3 = col
	rect.ZIndex = -1

	local round = Instance.new("UICorner", rect)
	round.CornerRadius = UDim.new(0, 6)

	b.TextTransparency = 0
	return b
end

UILib._CreateLabel = function(self, config)
	config = config or {}
	local text = config.Text or ""
	local size = config.Height or (self.Library.IsMobile and 24 or 30)
	self._order += 1
	
	local l = Instance.new("TextLabel", self.Frame)
	l.BackgroundTransparency = 1
	l.Size = UDim2.new(1, 0, 0, size)
	l.LayoutOrder = self._order
	l.Text = text
	l.TextColor3 = THEME.TextSecondary
	l.TextSize = self.Library.Font.Element
	l.TextWrapped = true
	l.TextXAlignment = Enum.TextXAlignment.Left
	l.Font = Enum.Font.GothamSemibold
	return l
end

UILib._CreateTextBox = function(self, config)
	config = config or {}
	local ph = config.Placeholder or "..."
	local def = config.Default or ""
	local func = config.Callback or function(v) end
	self._order += 1
	
	local f = Instance.new("Frame", self.Frame)
	f.BackgroundTransparency = 1
	f.Size = UDim2.new(1, 0, 0, self.Library.ElementH)
	f.LayoutOrder = self._order
	
	local txt = Instance.new("TextBox", f)
	txt.BackgroundTransparency = 1
	txt.Size = UDim2.new(1, 0, 1, 0)
	txt.Text = def
	txt.PlaceholderText = ph
	txt.TextColor3 = THEME.TextPrimary
	txt.TextSize = self.Library.Font.Element
	txt.Font = Enum.Font.Gotham
	txt.TextXAlignment = Enum.TextXAlignment.Left
	
	local bg = Instance.new("Frame", f)
	bg.BackgroundTransparency = 1
	bg.Size = UDim2.new(1, 0, 1, 0)
	local stroke = Instance.new("UIStroke", bg)
	stroke.Color = THEME.AccentDark
	stroke.Transparency = 0.5
	
	txt.FocusLost:Connect(function() func(txt.Text) end)
	return txt
end

UILib._CreateNote = function(self, config)
	config = config or {}
	local txt = config.Text or ""
	self._order += 1
	
	local f = Instance.new("TextLabel", self.Frame)
	f.BackgroundTransparency = 1
	f.Size = UDim2.new(1, 0, 0, 0)
	f.AutomaticSize = Enum.AutomaticSize.Y
	f.LayoutOrder = self._order
	f.Text = txt
	f.TextColor3 = THEME.TextSecondary
	f.TextSize = self.Library.Font.Element
	f.Font = Enum.Font.Gotham
	f.TextWrapped = true
	f.TextXAlignment = Enum.TextXAlignment.Left
	return f
end


-- =============================================
-- ANTI-AFK SYSTEM (WORKING)
-- =============================================
function UILib:_startAntiAFK()
	local player = Players.LocalPlayer
	if not player then return end

	-- 1. Idle Detector (Space Key Spam)
	local idleConn = player.Idled:Connect(function()
		pcall(function()
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
			task.wait(0.05)
			VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
		end)
	end)

	-- 2. Mouse Movement (Random jitter)
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			task.wait(120) -- Long interval to avoid detection
			if not self.ScreenGui or not self.ScreenGui.Parent then break end
			if self._minimized then task.wait(5) continue end -- Skip if minimized sometimes
			pcall(function()
				local mx, my = math.random(10, 500), math.random(10, 500)
				VirtualInputManager:SendMouseMoveEvent(mx, my, game)
			end)
		end
	end)

	-- 3. Visual Indicator (Dot)
	local size = self.IsMobile and 4 or 5
	local dot = Instance.new("Frame", self.ScreenGui)
	dot.Name = "AntiAFK_Dot"
	dot.BackgroundColor3 = Color3.fromRGB(0, 255, 136)
	dot.BackgroundTransparency = 0.2
	dot.BorderSizePixel = 0
	dot.Size = UDim2.new(0, size, 0, size)
	dot.AnchorPoint = Vector2.new(1, 1)
	dot.Position = UDim2.new(1, -size-20, 1, -size-20)
	dot.Visible = true
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
	
	-- Glow effect simulation
	local glow = Instance.new("ImageLabel", dot)
	glow.BackgroundTransparency = 1
	glow.Image = "rbxassetid://2869721769"
	glow.ImageColor3 = Color3.fromRGB(0, 255, 136)
	glow.Size = UDim2.new(0, size*2, 0, size*2)
	glow.AnchorPoint = Vector2.new(0.5, 0.5)
	glow.Position = UDim2.new(0.5, 0, 0.5, 0)
	glow.ImageTransparency = 0.5
	glow.ZIndex = -1

	self.AFK_Indicator = {dot = dot, glow = glow, idleConn = idleConn}

	-- Loop Pulse
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			TweenService:Create(dot.glow, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {ImageTransparency = 0.5}):Play()
			task.wait(0.5)
			TweenService:Create(dot.glow, TweenInfo.new(0.5, Enum.EasingStyle.Sine), {ImageTransparency = 0.2}):Play()
			task.wait(0.5)
		end
	end)
end

return UILib
