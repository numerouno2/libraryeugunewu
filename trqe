function UILib:AddTab(config)
	local tabName = config.Name or "Tab"
	local icon = config.Icon or "📁"

	self._tabOrder += 1
	
	local btn = Instance.new("TextButton", self.SidebarObj)
	btn.BackgroundTransparency = 1
	btn.Size = UDim2.new(1, -10, 0, self.ButtonH + 6)
	btn.Position = UDim2.new(0, 5, 0, 5 + (self._tabOrder - 1) * (self.ButtonH + 6))
	btn.Text = ""
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	btn.ZIndex = 20

	local ind = Instance.new("Frame", btn)
	ind.BackgroundColor3 = THEME.Accent
	ind.BackgroundTransparency = 1
	ind.Size = UDim2.new(0, 4, 1, 0)
	ind.Position = UDim2.new(0, -5, 0, 0)
	ind.ZIndex = 10
	Instance.new("UICorner", ind).CornerRadius = UDim.new(0, 2)

	local lbl = Instance.new("TextLabel", btn)
	lbl.BackgroundTransparency = 1
	lbl.Size = UDim2.new(1, -10, 1, 0)
	lbl.Position = UDim2.new(0, 10, 0, 0)
	lbl.Text = icon .. " " .. tabName
	lbl.TextColor3 = THEME.TextSecondary
	lbl.TextSize = self.Font.Tab
	lbl.Font = Enum.Font.GothamSemibold
	lbl.TextXAlignment = Enum.TextXAlignment.Left

	local page = Instance.new("Frame", self.ContentAreaObj)
	page.Name = tabName
	page.BackgroundTransparency = 1
	page.Size = UDim2.new(1, 0, 0, 0)
	page.AutomaticSize = Enum.AutomaticSize.Y
	page.Visible = false

	local layout = Instance.new("UIListLayout", page)
	layout.Padding = UDim.new(0, 10)
	layout.SortOrder = Enum.SortOrder.LayoutOrder

	self.TabButtons[tabName] = btn
	self.TabPages[tabName] = page
	table.insert(self.Tabs, tabName)

	btn.MouseButton1Click:Connect(function()
		self:SwitchTab(tabName)
	end)

	if #self.Tabs == 1 then
		task.wait(0.1)
		self:SwitchTab(tabName)
	end

	-- Create Meta Object for adding elements inside
	local tabObj = {
		Library = self,
		TabName = tabName,
		Page = page
	}
	setmetatable(tabObj, {__index = UILib._TabMethods})
	table.insert(self._InternalTabs, tabObj)
	
	return tabObj
end

function UILib:SwitchTab(name)
	self.ActiveTab = name
	for _, tName in ipairs(self.Tabs) do
		local btn = self.TabButtons[tName]
		local page = self.TabPages[tName]
		
		if tName == name then
			btn.BackgroundColor3 = THEME.Background -- Show selection context
			TweenService:Create(btn.FindFirstChild("Indicator"), TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
			TweenService:Create(btn.FindFirstChild("Label"), TweenInfo.new(0.2), {TextColor3 = THEME.TextPrimary}):Play()
			TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 50)}):Play()
			page.Visible = true
			
			-- Scroll to top
			self.ContentAreaObj.CanvasPosition = Vector2.new(0, 0)
		else
			TweenService:Create(btn.FindFirstChild("Indicator"), TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
			TweenService:Create(btn.FindFirstChild("Label"), TweenInfo.new(0.2), {TextColor3 = THEME.TextSecondary}):Play()
			TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Background}):Play()
			page.Visible = false
		end
	end
end

function UILib:Notify(msg, color)
	self.Notify.Text = msg
	self.Notify.TextColor3 = color or THEME.Accent
	self.Notify.Visible = true
	self Notify.BackgroundTransparency = 0
	self Notify.Size = UDim2.new(0, 200, 0, 24)
	TweenService:Create(self.Notify, TweenInfo.new(0.2), {BackgroundTransparency = 0}):Play()
	
	task.delay(2.5, function()
		if self.Notify and self.Notify.Parent then
			TweenService:Create(self.Notify, TweenInfo.new(0.3), {BackgroundTransparency = 1, Visible = false}):Play()
		end
	end)
end

function UILib:SetStatus(line, text, color)
	-- Placeholder status logic
	if not self.StatusLabels then return end
	if self.StatusLabels[line] then
		self.StatusLabels[line].Text = text
		if color then self.StatusLabels[line].TextColor3 = color end
	end
end

function UILib:OnUpdate(callback)
	table.insert(self.UpdateCallbacks, callback)
end

function UILib:_startUpdateLoop()
	task.spawn(function()
		while self.ScreenGui and self.ScreenGui.Parent do
			for _, cb in ipairs(self.UpdateCallbacks) do
				pcall(cb)
			end
			task.wait(0.5)
		end
	end)
end

function UILib:Destroy()
	self._antiAfkActive = false
	for k, v in pairs(self._connections or {}) do
		v:Disconnect()
	end
	if self.ScreenGui then self.ScreenGui:Destroy() end
end

