-- ─────────────────────────────────────
-- DRAG
-- ─────────────────────────────────────
function NexusLib:_drag()
	local drag, dinp, ds, sp = false
	self.Main.InputBegan:Connect(function(i)
		if self._rsz then return end
		if i.UserInputType==Enum.UserInputType.MouseButton1
		or i.UserInputType==Enum.UserInputType.Touch then
			drag=true; ds=i.Position; sp=self.Main.Position
			i.Changed:Connect(function()
				if i.UserInputState==Enum.UserInputState.End then drag=false end
			end)
		end
	end)
	self.Main.InputChanged:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseMovement
		or i.UserInputType==Enum.UserInputType.Touch then dinp=i end
	end)
	UIS.InputChanged:Connect(function(i)
		if i==dinp and drag and not self._rsz then
			local d=i.Position-ds
			local p=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
			self.Main.Position=p; self.Shadow.Position=p
		end
	end)
end

-- ─────────────────────────────────────
-- RESIZE
-- ─────────────────────────────────────
function NexusLib:_resize()
	local sc  = screen()
	local minW = self.SW + (self.Mobile and 100 or 160)
	local minH = self.TH  + (self.Mobile and 70  or 90)
	local maxW = math.min(sc.X-10, 1400)
	local maxH = math.min(sc.Y-20, 900)
	local hs   = self.Mobile and 22 or 20

	local rh = inst("Frame", self.Main, {
		BackgroundTransparency = 1,
		Position = UDim2.new(1,-hs,1,-hs),
		Size = UDim2.new(0,hs,0,hs),
		ZIndex = 20,
	})
	-- grip dots
	local dots = {}
	local ds = self.Mobile and 2 or 2
	local dg = 4
	for r=0,2 do for c=0,2-r do
		local d = inst("Frame", rh, {
			BackgroundColor3 = T.BdrL,
			BackgroundTransparency = 0.3,
			BorderSizePixel = 0,
			Size = UDim2.new(0,ds,0,ds),
			AnchorPoint = Vector2.new(1,1),
			Position = UDim2.new(1,-(2+c*(ds+dg)),1,-(2+r*(ds+dg))),
			ZIndex = 21,
		})
		corner(d, 99)
		dots[#dots+1]=d
	end end

	local hp = self.Mobile and 10 or 7
	local rbtn = inst("TextButton", rh, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,-hp,0,-hp),
		Size = UDim2.new(1,hp*2,1,hp*2),
		Text = "", ZIndex=22,
		AutoButtonColor=false,
	})

	local resz,rs,ssz,spos=false
	local function dotCol(c,t)
		for _,d in ipairs(dots) do tw(d,{BackgroundColor3=c,BackgroundTransparency=t},.15):Play() end
	end

	rbtn.InputBegan:Connect(function(i)
		if self._min then return end
		if i.UserInputType==Enum.UserInputType.MouseButton1
		or i.UserInputType==Enum.UserInputType.Touch then
			resz=true; self._rsz=true
			rs=i.Position
			ssz=Vector2.new(self.Main.Size.X.Offset,self.Main.Size.Y.Offset)
			spos=self.Main.Position
			dotCol(T.AccLt,0)
			i.Changed:Connect(function()
				if i.UserInputState==Enum.UserInputState.End then
					resz=false; self._rsz=false; dotCol(T.BdrL,0.3)
				end
			end)
		end
	end)
	rbtn.MouseEnter:Connect(function() if not resz then dotCol(T.Acc,0) end end)
	rbtn.MouseLeave:Connect(function() if not resz then dotCol(T.BdrL,0.3) end end)

	UIS.InputChanged:Connect(function(i)
		if resz and (i.UserInputType==Enum.UserInputType.MouseMovement
		or i.UserInputType==Enum.UserInputType.Touch) then
			local d=i.Position-rs
			local nw=math.clamp(ssz.X+d.X,minW,maxW)
			local nh=math.clamp(ssz.Y+d.Y,minH,maxH)
			local dw,dh=nw-ssz.X,nh-ssz.Y
			local ns=UDim2.new(0,nw,0,nh)
			local np=UDim2.new(spos.X.Scale,spos.X.Offset+dw/2,spos.Y.Scale,spos.Y.Offset+dh/2)
			self.Main.Size=ns; self.Main.Position=np
			self.Size=ns
			self.Shadow.Size=ns+UDim2.new(0,40,0,40)
			self.Shadow.Position=np
		end
	end)
	self.RH=rh
end

-- ─────────────────────────────────────
-- ANTI-AFK
-- ─────────────────────────────────────
function NexusLib:_antiAFK()
	local p=PLR.LocalPlayer
	if p then
		self._ic=p.Idled:Connect(function()
			pcall(function()
				VIM:SendKeyEvent(true,Enum.KeyCode.Space,false,game)
				task.wait(.1)
				VIM:SendKeyEvent(false,Enum.KeyCode.Space,false,game)
			end)
		end)
	end
	self._aa=true
	task.spawn(function()
		while self._aa and self.SG and self.SG.Parent do
			task.wait(60)
			pcall(function()
				VIM:SendKeyEvent(true,Enum.KeyCode.F13,false,game)
				task.wait(.1)
				VIM:SendKeyEvent(false,Enum.KeyCode.F13,false,game)
			end)
		end
	end)
	task.spawn(function()
		while self._aa and self.SG and self.SG.Parent do
			task.wait(120)
			pcall(function()
				VIM:SendMouseMoveEvent(math.random(100,500),math.random(100,500),game)
			end)
		end
	end)
	-- blink afk dot
	task.spawn(function()
		while self._aa and self.SG and self.SG.Parent do
			if self._afkDot and self._afkDot.Parent then
				tw(self._afkDot,{BackgroundTransparency=0.75},.85):Play()
				task.wait(.85)
				tw(self._afkDot,{BackgroundTransparency=0},.85):Play()
				task.wait(.85)
			else break end
		end
	end)
end

-- ─────────────────────────────────────
-- UPDATE LOOP
-- ─────────────────────────────────────
function NexusLib:_updateLoop()
	task.spawn(function()
		while self.SG and self.SG.Parent do
			for _,cb in ipairs(self.CBs) do pcall(cb) end
			task.wait(.5)
		end
	end)
end

-- ─────────────────────────────────────
-- PUBLIC: AddTab
-- ─────────────────────────────────────
function NexusLib:AddTab(cfg)
	local name = cfg.Name or "Tab"
	local icon = cfg.Icon or "○"
	self._tabIdx = self._tabIdx+1
	local idx = self._tabIdx
	local px = self.Mobile and 5 or 6

	-- Tab button
	local btn = inst("TextButton", self.Sidebar, {
		BackgroundColor3 = T.BG2,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(0,px,0,26+(idx-1)*self.TBG),
		Size = UDim2.new(1,-px*2,0,self.TBH),
		Text = "",
		AutoButtonColor = false,
	})
	corner(btn, 6)

	-- Active bar
	inst("Frame", btn, {
		Name = "Bar",
		BackgroundColor3 = T.Acc,
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(0,0,.15,0),
		Size = UDim2.new(0,2,.7,0),
	})

	-- Icon
	inst("TextLabel", btn, {
		Name = "Ico",
		BackgroundTransparency = 1,
		Position = UDim2.new(0,8,0,0),
		Size = UDim2.new(0,18,1,0),
		Font = T.FM,
		Text = icon,
		TextColor3 = T.TX2,
		TextSize = self.FS.tab+1,
	})

	-- Label
	inst("TextLabel", btn, {
		Name = "Lbl",
		BackgroundTransparency = 1,
		Position = UDim2.new(0,28,0,0),
		Size = UDim2.new(1,-32,1,0),
		Font = T.FM,
		Text = name,
		TextColor3 = T.TX2,
		TextSize = self.FS.tab,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd,
	})

	-- Page
	local page = inst("ScrollingFrame", self.CA, {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(0,0,0,0),
		Size = UDim2.new(1,0,1,0),
		ScrollBarThickness = 2,
		ScrollBarImageColor3 = T.BdrL,
		CanvasSize = UDim2.new(0,0,0,0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false,
	})
	inst("UIPadding", page, {
		PaddingLeft   = UDim.new(0,self.CP),
		PaddingRight  = UDim.new(0,self.CP+3),
		PaddingTop    = UDim.new(0,self.CP),
		PaddingBottom = UDim.new(0,self.CP+4),
	})
	listLayout(page, self.Mobile and 6 or 7)

	self.TBtns[name] = btn
	self.TPages[name] = page

	btn.MouseButton1Click:Connect(function() self:SwitchTab(name) end)
	btn.MouseEnter:Connect(function()
		if self.Active~=name then
			tw(btn,{BackgroundTransparency=0.86},.14):Play()
		end
	end)
	btn.MouseLeave:Connect(function()
		if self.Active~=name then
			tw(btn,{BackgroundTransparency=1},.14):Play()
		end
	end)

	if idx==1 then task.defer(function() self:SwitchTab(name) end) end

	local tab={Name=name,Page=page,Lib=self,_o=0}
	setmetatable(tab,{__index=NexusLib._TabM})
	table.insert(self.Tabs,tab)
	return tab
end

-- ─────────────────────────────────────
-- PUBLIC: SwitchTab
-- ─────────────────────────────────────
function NexusLib:SwitchTab(name)
	if self.Active==name then return end
	self.Active=name
	for n,btn in pairs(self.TBtns) do
		local act=(n==name)
		local lbl=btn:FindFirstChild("Lbl")
		local ico=btn:FindFirstChild("Ico")
		local bar=btn:FindFirstChild("Bar")
		tw(btn,{BackgroundTransparency=act and 0.88 or 1},.18):Play()
		if lbl then tw(lbl,{TextColor3=act and T.TX0 or T.TX2},.18):Play() end
		if ico then tw(ico,{TextColor3=act and T.AccLt or T.TX2},.18):Play() end
		if bar then tw(bar,{BackgroundTransparency=act and 0 or 1},.18):Play() end
	end
	for n,pg in pairs(self.TPages) do
		pg.Visible=(n==name)
	end
end

-- ─────────────────────────────────────
-- PUBLIC: Notify
-- ─────────────────────────────────────
function NexusLib:Notify(msg, col, icon)
	if self._nBusy then return end
	self._nBusy=true
	local c=col or T.Green
	self.NL.Text = (icon or "◆").."  "..msg
	self.NL.TextColor3=c
	tw(self.NF,{BackgroundTransparency=0.1},.18):Play()
	tw(self.NL,{TextTransparency=0},.18):Play()
	-- accent line
	local ln=inst("Frame",self.NF,{
		BackgroundColor3=c,BorderSizePixel=0,
		Position=UDim2.new(0,0,0,0),Size=UDim2.new(0,2,1,0),
	})
	corner(ln,99)
	task.delay(2.2,function()
		tw(self.NF,{BackgroundTransparency=1},.35):Play()
		tw(self.NL,{TextTransparency=1},.35):Play()
		task.delay(.35,function() pcall(function() ln:Destroy() end); self._nBusy=false end)
	end)
end

