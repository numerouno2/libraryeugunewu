-- │  AddTab  (same signature)           │
-- └─────────────────────────────────────┘
function UILib:AddTab(config)
	local tabName = config.Name or "Tab"
	local tabIcon = config.Icon or "○"

	self._tabIndex = self._tabIndex + 1
	local index = self._tabIndex
	local px    = self.IsMobile and 5 or 6

	-- Tab button
	local btn = N("TextButton", self.Sidebar, {
		BackgroundColor3     = D.BG2,
		BackgroundTransparency = 1,
		BorderSizePixel      = 0,
		Position = UDim2.new(0,px,0, 26+(index-1)*self.TabButtonSpacing),
		Size     = UDim2.new(1,-px*2,0,self.TabButtonHeight),
		Text     = "",
		AutoButtonColor = false,
	})
	corner(btn, 6)

	-- Active indicator (left edge bar)
	local indicator = N("Frame", btn, {
		Name             = "Indicator",
		BackgroundColor3 = D.ACC,
		BackgroundTransparency = 1,
		BorderSizePixel  = 0,
		Position = UDim2.new(0,0,.15,0),
		Size     = UDim2.new(0,2,.7,0),
	})
	corner(indicator, 99)

	-- Icon label
	N("TextLabel", btn, {
		Name               = "Icon",
		BackgroundTransparency = 1,
		Position = UDim2.new(0,8,0,0),
		Size     = UDim2.new(0,18,1,0),
		Font     = D.FSB,
		Text     = tabIcon,
		TextColor3 = D.T2,
		TextSize   = self.FontTab + 1,
	})

	-- Name label  (kept as "Label" for SwitchTab compat)
	N("TextLabel", btn, {
		Name               = "Label",
		BackgroundTransparency = 1,
		Position = UDim2.new(0,28,0,0),
		Size     = UDim2.new(1,-32,1,0),
		Font     = D.FSB,
		Text     = tabName,
		TextColor3 = D.T2,
		TextSize   = self.FontTab,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate   = Enum.TextTruncate.AtEnd,
	})

	-- Tab page (scrollable)
	local cp   = self.SectionPadding
	local page = N("ScrollingFrame", self.ContentArea, {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Position = UDim2.new(0,0,0,0),
		Size     = UDim2.new(1,0,1,0),
		ScrollBarThickness  = 2,
		ScrollBarImageColor3 = D.BDL,
		CanvasSize          = UDim2.new(0,0,0,0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible             = false,
	})
	padI(page, cp, cp+3, cp, cp)
	vList(page, self.IsMobile and 6 or 7)

	self.TabButtons[tabName] = btn
	self.TabPages[tabName]   = page

	btn.MouseButton1Click:Connect(function() self:SwitchTab(tabName) end)

	btn.MouseEnter:Connect(function()
		if self.ActiveTab ~= tabName then
			T(btn, {BackgroundTransparency=0.87}, .14):Play()
		end
	end)
	btn.MouseLeave:Connect(function()
		if self.ActiveTab ~= tabName then
			T(btn, {BackgroundTransparency=1}, .14):Play()
		end
	end)

	if index == 1 then task.defer(function() self:SwitchTab(tabName) end) end

	local tab = { Name=tabName, Page=page, Library=self, _sectionOrder=0 }
	setmetatable(tab, {__index = UILib._TabMethods})
	table.insert(self.Tabs, tab)
	return tab
end

-- ┌─────────────────────────────────────┐
-- │  SwitchTab  (same logic, new style) │
-- └─────────────────────────────────────┘
function UILib:SwitchTab(name)
	if self.ActiveTab == name then return end
	self.ActiveTab = name

	for tabName, btn in pairs(self.TabButtons) do
		local ind  = btn:FindFirstChild("Indicator")
		local lbl  = btn:FindFirstChild("Label")
		local ico  = btn:FindFirstChild("Icon")
		local act  = (tabName == name)

		T(btn, {BackgroundTransparency = act and 0.88 or 1}, .18):Play()
		if lbl then T(lbl, {TextColor3 = act and D.T0  or D.T2}, .18):Play() end
		if ico then T(ico, {TextColor3 = act and D.ACL or D.T2}, .18):Play() end
		if ind then T(ind, {BackgroundTransparency = act and 0 or 1}, .18):Play() end
	end

	for tabName, page in pairs(self.TabPages) do
		page.Visible = (tabName == name)
	end
end

-- ┌─────────────────────────────────────┐
-- │  OnUpdate / Update Loop  (same)     │
-- └─────────────────────────────────────┘
function UILib:OnUpdate(callback)
	table.insert(self.UpdateCallbacks, callback)
end

function UILib:_startUpdateLoop()
	task.spawn(function()
		while self.ScreenGui and self.ScreenGui.Parent do
			for _, cb in ipairs(self.UpdateCallbacks) do pcall(cb) end
			task.wait(0.5)
		end
	end)
end

