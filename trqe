	self.TitleBar.BackgroundColor3 = Colors.Surface
	self.TitleBar.BorderSizePixel = 0
	self.TitleBar.Position = UDim2.new(0, 0, 0, self.TopBarH)
	self.TitleBar.Size = UDim2.new(1, 0, 0, self.TitleBarHeight)

	-- Subtle bottom border
	local bottomLine = Instance.new("Frame", self.TitleBar)
	bottomLine.BackgroundColor3 = Colors.Border
	bottomLine.BackgroundTransparency = 0.5
	bottomLine.BorderSizePixel = 0
	bottomLine.Position = UDim2.new(0, 0, 1, -1)
	bottomLine.Size = UDim2.new(1, 0, 0, 1)

	local titleLabel = Instance.new("TextLabel", self.TitleBar)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Position = UDim2.new(0, 14, 0, 0)
	titleLabel.Size = UDim2.new(0, self.IsMobile and 130 or 220, 1, 0)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.Text = self.Title
	titleLabel.TextColor3 = Colors.TextPrimary
	titleLabel.TextSize = self.FontTitle
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextTruncate = Enum.TextTruncate.AtEnd

	local btnSize = self.IsMobile and 22 or 26
	local btnFont = self.IsMobile and 10 or 12
	local btnGap = btnSize + 6

	-- Close Button
	local closeBtn = Instance.new("TextButton", self.TitleBar)
	closeBtn.BackgroundColor3 = Colors.Error
	closeBtn.BackgroundTransparency = 0.85
	closeBtn.BorderSizePixel = 0
	closeBtn.Position = UDim2.new(1, -(btnSize + 10), 0.5, -btnSize / 2)
	closeBtn.Size = UDim2.new(0, btnSize, 0, btnSize)
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Text = "✕"
	closeBtn.TextColor3 = Colors.Error
	closeBtn.TextSize = btnFont
	closeBtn.AutoButtonColor = false
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)

	closeBtn.MouseEnter:Connect(function()
		TweenService:Create(closeBtn, TweenInfo.new(0.15), {
			BackgroundTransparency = 0.1, TextColor3 = Color3.new(1, 1, 1)
		}):Play()
	end)
	closeBtn.MouseLeave:Connect(function()
		TweenService:Create(closeBtn, TweenInfo.new(0.15), {
			BackgroundTransparency = 0.85, TextColor3 = Colors.Error
		}):Play()
	end)
	closeBtn.MouseButton1Click:Connect(function()
		self.ScreenGui.Enabled = false
	end)

	-- Minimize Button
	local minBtn = Instance.new("TextButton", self.TitleBar)
	minBtn.BackgroundColor3 = Colors.Warning
	minBtn.BackgroundTransparency = 0.85
	minBtn.BorderSizePixel = 0
	minBtn.Position = UDim2.new(1, -(btnSize + 10 + btnGap), 0.5, -btnSize / 2)
	minBtn.Size = UDim2.new(0, btnSize, 0, btnSize)
	minBtn.Font = Enum.Font.GothamBold
	minBtn.Text = "—"
	minBtn.TextColor3 = Colors.Warning
	minBtn.TextSize = btnFont
	minBtn.AutoButtonColor = false
	Instance.new("UICorner", minBtn).CornerRadius = UDim.new(0, 6)

	minBtn.MouseEnter:Connect(function()
		TweenService:Create(minBtn, TweenInfo.new(0.15), {
			BackgroundTransparency = 0.1, TextColor3 = Color3.new(1, 1, 1)
		}):Play()
	end)
	minBtn.MouseLeave:Connect(function()
		TweenService:Create(minBtn, TweenInfo.new(0.15), {
			BackgroundTransparency = 0.85, TextColor3 = Colors.Warning
		}):Play()
	end)

	minBtn.MouseButton1Click:Connect(function()
		self._minimized = not self._minimized
		if self._minimized then
			TweenService:Create(self.Main, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Size = UDim2.new(0, self.Size.X.Offset, 0, self.HeaderTotal)
			}):Play()
			TweenService:Create(self.Shadow, TweenInfo.new(0.25), {
				Size = UDim2.new(0, self.Size.X.Offset + 40, 0, self.HeaderTotal + 40)
			}):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = false end
		else
			TweenService:Create(self.Main, TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Size = self.Size
