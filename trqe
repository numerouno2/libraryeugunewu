		ScrollBarImageColor3 = D.BDL,
		AutomaticCanvasSize  = Enum.AutomaticSize.X,
		CanvasSize           = UDim2.new(0,0,0,0),
	})
	hList(sf, lib.IsMobile and 4 or 5)

	local buttons = {}
	for i, item in ipairs(items) do
		local ac  = (item.name == selected)
		local ic  = item.color or D.ACC

		local b = N("TextButton", sf, {
			BackgroundColor3     = ac and ic or D.BG5,
			BackgroundTransparency = ac and 0.18 or 0,
			BorderSizePixel      = 0,
			Size = UDim2.new(0,btnW,0,gridH-3),
			Text = "", AutoButtonColor=false,
			LayoutOrder = i,
		})
		corner(b, 7)
		if ac then stroke(b, ic, 1, 0.44) end

		N("TextLabel", b, {
			BackgroundTransparency = 1,
			Size = UDim2.new(1,0,0,gridH*.52),
			Text = item.icon or "□",
			TextSize = lib.IsMobile and 15 or 19,
			Font = D.FB,
			TextColor3 = ac and ic or D.T2,
		})
		N("TextLabel", b, {
			BackgroundTransparency = 1,
			Position = UDim2.new(0,0,0,gridH*.52),
			Size     = UDim2.new(1,0,0,gridH*.4),
			Text     = item.label or item.name,
			TextSize = lib.FontSmall,
			Font     = D.FSB,
			TextColor3 = ac and D.T0 or D.T2,
			TextTruncate = Enum.TextTruncate.AtEnd,
		})
		buttons[item.name] = b

		b.MouseButton1Click:Connect(function()
			selected = item.name
			for bName, bBtn in pairs(buttons) do
				local bItem
				for _, it in ipairs(items) do if it.name==bName then bItem=it; break end end
				local c2 = bItem and (bItem.color or D.ACC) or D.ACC
				local a2 = (bName == selected)
				T(bBtn,{BackgroundColor3=a2 and c2 or D.BG5, BackgroundTransparency=a2 and 0.18 or 0},.18):Play()
				local ch = bBtn:GetChildren()
				if ch[1] then T(ch[1],{TextColor3=a2 and c2 or D.T2},.18):Play() end
				if ch[2] then T(ch[2],{TextColor3=a2 and D.T0 or D.T2},.18):Play() end
			end
			callback(item)
		end)
	end

	return {
		Frame       = sf,
		Buttons     = buttons,
		GetSelected = function() return selected end,
		SetSelected = function(_, name)
			selected = name
			for bName, bBtn in pairs(buttons) do
				local bItem
				for _, it in ipairs(items) do if it.name==bName then bItem=it; break end end
				local c2 = bItem and (bItem.color or D.ACC) or D.ACC
				local a2 = (bName == selected)
				T(bBtn,{BackgroundColor3=a2 and c2 or D.BG5, BackgroundTransparency=a2 and 0.18 or 0},.18):Play()
				local ch = bBtn:GetChildren()
				if ch[1] then T(ch[1],{TextColor3=a2 and c2 or D.T2},.18):Play() end
				if ch[2] then T(ch[2],{TextColor3=a2 and D.T0 or D.T2},.18):Play() end
			end
		end,
	}
end

-- AddTextBox
function UILib._SectionMethods:AddTextBox(config)
	self._elementOrder = self._elementOrder + 1
	local placeholder = config.Placeholder or "Type here..."
	local default     = config.Default     or ""
	local callback    = config.Callback    or function()end
	local order       = config.Order       or self._elementOrder
	local lib         = self.Library
	local h           = lib.IsMobile and 30 or 34

	local frame = N("Frame", W(self), {
		BackgroundColor3 = D.BG5,
		BorderSizePixel  = 0,
		Size     = UDim2.new(1,0,0,h),
		LayoutOrder = order,
	})
	corner(frame, 6)
	local s = N("UIStroke", frame, {Color=D.BD, Thickness=1})

	local tb = N("TextBox", frame, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,8,0,0),
		Size     = UDim2.new(1,-16,1,0),
		Font     = D.FN,
		PlaceholderText   = placeholder,
		PlaceholderColor3 = D.T3,
		Text      = default,
		TextColor3 = D.T0,
		TextSize   = lib.FontElement,
		TextXAlignment = Enum.TextXAlignment.Left,
		ClearTextOnFocus = false,
	})

	tb.Focused:Connect(function()   T(s, {Color=D.ACC}, .18):Play() end)
	tb.FocusLost:Connect(function() T(s, {Color=D.BD},  .18):Play(); callback(tb.Text) end)
	return tb
end

-- AddQuantitySelector
function UILib._SectionMethods:AddQuantitySelector(config)
	self._elementOrder = self._elementOrder + 1
	local amounts  = config.Amounts  or {1,5,10,50,100}
	local default  = config.Default  or amounts[3] or 10
	local callback = config.Callback or function()end
	local order    = config.Order    or self._elementOrder
	local lib      = self.Library
	local btnW     = lib.IsMobile and 46 or 56
	local btnH     = lib.IsMobile and 25 or 29

	local sf = N("ScrollingFrame", W(self), {
		BackgroundTransparency = 1,
		BorderSizePixel        = 0,
		Size = UDim2.new(1,0,0,btnH+3),
		LayoutOrder = order,
		ScrollBarThickness  = 2,
		AutomaticCanvasSize = Enum.AutomaticSize.X,
		CanvasSize          = UDim2.new(0,0,0,0),
	})
	hList(sf, lib.IsMobile and 3 or 4)

	local selected = default
	local buttons  = {}

	for _, amt in ipairs(amounts) do
		local ac = (amt == default)
		local b  = N("TextButton", sf, {
			BackgroundColor3     = ac and D.GRN or D.BG5,
			BackgroundTransparency = ac and 0.15 or 0,
			BorderSizePixel      = 0,
			Size    = UDim2.new(0,btnW,0,btnH),
			Font    = D.FSB,
			Text    = "x" .. amt,
			TextColor3 = ac and D.T0 or D.T2,
			TextSize   = lib.FontElement,
			AutoButtonColor = false,
		})
		corner(b, 6)
		buttons[amt] = b

		b.MouseButton1Click:Connect(function()
			selected = amt
			for a2, b2 in pairs(buttons) do
				local a = (a2 == selected)
				T(b2,{
					BackgroundColor3     = a and D.GRN or D.BG5,
					BackgroundTransparency = a and 0.15 or 0,
					TextColor3           = a and D.T0  or D.T2,
				},.18):Play()
			end
			callback(amt)
		end)
	end

	return {
		Frame    = sf,
		GetValue = function() return selected end,
	}
end

return UILib
