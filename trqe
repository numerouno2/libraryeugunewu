local UILib = {}
UILib.__index = UILib

-- SERVICES
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting") -- Optional for glow effects if needed

-- COLORS & THEMES
local THEME = {
	Background = Color3.fromRGB(23, 23, 30),       -- Main BG
	Sidebar = Color3.fromRGB(27, 27, 35),          -- Left Panel
	Header = Color3.fromRGB(20, 20, 25),           -- Title Bar
	Accent = Color3.fromRGB(76, 138, 245),         -- Primary Highlight
	AccentDark = Color3.fromRGB(44, 95, 180),      -- Hover/Affirmative
	TextPrimary = Color3.fromRGB(220, 220, 230),   -- White text
	TextSecondary = Color3.fromRGB(150, 150, 165), -- Grey text
	DotColor = Color3.fromRGB(70, 90, 120)         -- Resize handle dots
}

local DEFAULT_SIZE = UDim2.new(0, 700, 0, 480) -- Rayfield-esque size
local MIN_WIDTH = 500
local MIN_HEIGHT = 300

--=============================================
-- HELPER: Detect Platform & Screen
--=============================================
local function isMobile()
	local success, result = pcall(function()
		return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
	end)
	if success then return result else return false end
end

local function getScreenSize()
	local camera = workspace.CurrentCamera
	if camera then
		return camera.ViewportSize
	end
	return Vector2.new(1920, 1080)
end

local function getScale()
	local screen = getScreenSize()
	local mobile = isMobile()
	if mobile then
		local shortSide = math.min(screen.X, screen.Y)
		if shortSide < 400 then return 0.50 end
		if shortSide < 550 then return 0.60 end
		if shortSide < 750 then return 0.70 end
		return 0.80
	end
	return 1
end

--=============================================
-- MAIN OBJECT
--=============================================
function UILib.new(config)
	local self = setmetatable({}, UILib)

	-- Configuration Defaults
	self.Title = config.Title or "Hub"
	self.Scale = getScale()
	self.IsMobile = isMobile()
	self.Tabs = {}
	self.TabButtons = {}
	self.TabPages = {}
	self.ActiveTab = nil
	self.UpdateCallbacks = {}
	
	-- Responsive sizing setup
	local w, h
	if self.IsMobile then
		local s = getScreenSize()
		w = math.min(s.X * self.Scale, 400)
		h = math.min(s.Y * self.Scale, 350)
	else
		w, h = DEFAULT_SIZE.X.Offset, DEFAULT_SIZE.Y.Offset
	end

	self.Size = UDim2.new(0, w, 0, h)
	
	-- Spacing Configurations
	if self.IsMobile then
		self.Margins = {Sidebar = 10, Title = 35, Content = 5}
		self.Font = {Title = 12, Tab = 11, Element = 11}
		self.ElementH = 32
		self.ButtonH = 30
	else
		self.Margins = {Sidebar = 10, Title = 50, Content = 15}
		self.Font = {Title = 18, Tab = 14, Element = 13}
		self.ElementH = 38
		self.ButtonH = 36
	end

	self.SidebarWidth = self.IsMobile and 100 or 170
	self.HeaderTotal = self.Margins.Title
	
	-- Flag States
	self._resizing = false
	self._minimized = false
	self._antiAfkActive = true
	self._screenGuiParent = nil

	-- Cleanup Old
	local oldGui = game.CoreGui:FindFirstChild("UIHub_Main")
	if oldGui then oldGui:Destroy() end

	-- ==========================================
	-- SCREEN GUI & BACKGROUND
	-- ==========================================
	self.ScreenGui = Instance.new("ScreenGui")
	self.ScreenGui.Name = "UIHub_Main"
	self.ScreenGui.Parent = game.CoreGui
	self.ScreenGui.ResetOnSpawn = false
	self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	self.ScreenGui.Enabled = true

	-- Main Window Frame (Centered)
	self.Main = Instance.new("Frame", self.ScreenGui)
	self.Main.Name = "Container"
	self.Main.AnchorPoint = Vector2.new(0.5, 0.5)
	self.Main.BackgroundColor3 = THEME.Background
	self.Main.BorderSizePixel = 0
	self.Main.Position = UDim2.new(0.5, 0, 0.5, 0)
	self.Main.Size = self.Size
	self.Main.ClipsDescendants = true

	Instance.new("UICorner", self.Main).CornerRadius = UDim.new(0, 16)
	Instance.new("UIStroke", self.Main).Color = THEME.AccentDark.Thickness = 1.5
	
	-- Shadow Behind Window
	self.Shadow = Instance.new("ImageLabel", self.ScreenGui)
	self.Shadow.Name = "ShadowLayer"
	self.Shadow.Image = "rbxassetid://5554236805"
	self.Shadow.BackgroundTransparency = 1
	self.Shadow.Position = self.Main.Position
	self.Shadow.Size = UDim2.new(0, self.Size.X.Offset + 40, 0, self.Size.Y.Offset + 40)
	self.Shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
	self.Shadow.ImageTransparency = 0.7
	self.Shadow.ScaleType = Enum.ScaleType.Slice
	self.Shadow.SliceCenter = Rect.new(40, 40, 240, 240)
	self.Shadow.ZIndex = self.Main.ZIndex - 1

	-- ==========================================
	-- UI COMPONENTS INITIALIZATION
	-- ==========================================
	self:_setupDragAndMinimize()
	self:_createAnimatedTopLine()
	self:_createTitleBar()
	self:_createSidebar()
	self:_createContentArea()
	self:_createNotification()
	self:_setupResizeHandle()

	-- Init Features
	self:_startAntiAFK()
	self:_startUpdateLoop()

	-- Entrance Animation
	self.Main.Size = UDim2.new(0, 0, 0, 0)
	self.Shadow.ImageTransparency = 1
	TweenService:Create(self.Main, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = self.Size}):Play()
	TweenService:Create(self.Shadow, TweenInfo.new(0.4), {ImageTransparency = 0.7}):Play()

	return self
end

--=============================================
-- RESIZE SYSTEM
--=============================================
function UILib:_setupResizeHandle()
	local hSize = self.IsMobile and 25 or 25
	local dotCount = 3
	
	local handle = Instance.new("Frame", self.Main)
	handle.Name = "ResizeHandle"
	handle.BackgroundTransparency = 1
	handle.Position = UDim2.new(1, -hSize, 1, -hSize)
	handle.Size = UDim2.new(0, hSize, 0, hSize)
	handle.ZIndex = 999

	-- Dots Pattern
	for r = 0, dotCount - 1 do
		for c = 0, dotCount - 1 do
			local dot = Instance.new("Frame", handle)
			dot.Name = "Dot" .. tostring(r*c)
			dot.BackgroundColor3 = THEME.DotColor
			dot.BackgroundTransparency = 0.4
			dot.BorderSizePixel = 0
			dot.Size = UDim2.new(0, 3, 0, 3)
			dot.AnchorPoint = Vector2.new(1, 1)
			dot.Position = UDim2.new(1, -c*5, 1, -r*5)
			Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
			
			-- Touch safety pad
			local btn = Instance.new("TextButton", handle)
			btn.Name = "TouchPad"
			btn.BackgroundTransparency = 1
			btn.Size = UDim2.new(0, 60, 0, 60)
			btn.Position = UDim2.new(1, -80, 1, -80)
			btn.Text = ""
			btn.ZIndex = 999
			
			-- Connect Input
			btn.InputBegan:Connect(function(inp)
				if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
					if self._minimized then return end
					self._resizing = true
					-- Highlight Dots
					for _, d in ipairs(handle:GetChildren()) do
						if d:IsA("Frame") and string.sub(d.Name, 1, 3) == "Dot" then
							TweenService:Create(d, TweenInfo.new(0.2), {BackgroundTransparency = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
						end
					end
					
					local startSize = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
					local startPos = self.Main.Position
					local startInput = inp.Position

					userInputChangedConn = UserInputService.InputChanged:Connect(function(ic)
						if ic.UserInputType ~= Enum.UserInputType.MouseMovement and ic.UserInputType ~= Enum.UserInputType.Touch then return end
						
						local diffX = ic.Position.X - startInput.X
						local diffY = ic.Position.Y - startInput.Y
						
						local newW = math.clamp(startSize.X + diffX, MIN_WIDTH, self:GetMaxSize().X)
						local newH = math.clamp(startSize.Y + diffY, MIN_HEIGHT, self:GetMaxSize().Y)
						
						-- Maintain center anchor during resize
						self.Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + diffX/2, startPos.Y.Scale, startPos.Y.Offset + diffY/2)
						self.Main.Size = UDim2.new(0, newW, 0, newH)
						
						-- Update Shadow
						self.Shadow.Size = UDim2.new(0, newW + 40, 0, newH + 40)
						self.Shadow.Position = self.Main.Position
						
						self.Size = self.Main.Size
					end)
					
					inputEndedConn = inp.Changed:Connect(function()
						if inp.UserInputState == Enum.UserInputState.End then
							self._resizing = false
							if userInputChangedConn then userInputChangedConn:Disconnect() end
							if inputEndedConn then inputEndedConn:Disconnect() end
							
							-- Restore Dots
							for _, d in ipairs(handle:GetChildren()) do
								if d:IsA("Frame") and string.sub(d.Name, 1, 3) == "Dot" then
									TweenService:Create(d, TweenInfo.new(0.3), {BackgroundTransparency = 0.4, BackgroundColor3 = THEME.DotColor}):Play()
								end
							end
						end
					end)
				end
			end)
		end
	end
	self.ResizeHandleObj = handle
end

function UILib:GetMaxSize()
	local screen = getScreenSize()
	return Vector2.new(math.max(MIN_WIDTH, screen.X - 40), math.max(MIN_HEIGHT, screen.Y - 40))
end

