	-- Knob shadow
	local knobShadow = Instance.new("ImageLabel", knob)
	knobShadow.BackgroundTransparency = 1
	knobShadow.Image = "rbxassetid://5554236805"
	knobShadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
