-- ┌─────────────────────────────────────┐
-- │  ANTI-AFK  (identical logic)        │
-- └─────────────────────────────────────┘
function UILib:_startAntiAFK()
	local player = Players.LocalPlayer
	if player then
		self._antiAfkIdleConnection = player.Idled:Connect(function()
			pcall(function()
				VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Space, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			end)
		end)
	end
	self._antiAfkActive = true
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			task.wait(60)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.F13, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F13, false, game)
			end)
		end
	end)
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			task.wait(120)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendMouseMoveEvent(math.random(100,500), math.random(100,500), game)
			end)
		end
	end)
	self:_createAntiAfkIndicator()
end

function UILib:_createAntiAfkIndicator()
	-- Built inline inside _createTitleBar; this just starts the blink loop.
	task.spawn(function()
		local dot = self._antiAfkDot
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			if dot and dot.Parent then
				T(dot, {BackgroundTransparency=0.78}, .85, Enum.EasingStyle.Sine):Play()
				task.wait(.85)
				T(dot, {BackgroundTransparency=0},    .85, Enum.EasingStyle.Sine):Play()
				task.wait(.85)
			else break end
		end
	end)
end

-- ┌─────────────────────────────────────┐
-- │  DRAG  (same logic)                 │
-- └─────────────────────────────────────┘
function UILib:_setupDrag()
	local dragging, dragInput, dragStart, startPos

	self.Main.InputBegan:Connect(function(input)
		if self._resizing then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			dragging  = true
			dragStart = input.Position
			startPos  = self.Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)

	self.Main.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging and not self._resizing then
			local d = input.Position - dragStart
			local p = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X,
			                    startPos.Y.Scale, startPos.Y.Offset+d.Y)
			self.Main.Position   = p
			self.Shadow.Position = p
		end
	end)
end

-- ┌─────────────────────────────────────┐
-- │  RESIZE  (same logic, better dots)  │
-- └─────────────────────────────────────┘
function UILib:_setupResize()
	local hs  = self.IsMobile and 22 or 20
	local ds  = 2
	local dg  = 4
	local scr = getScreenSize()
	local minW = self.SidebarWidth + (self.IsMobile and 100 or 180)
	local minH = self.HeaderTotal  + (self.IsMobile and 80  or 120)
	local maxW = math.min(scr.X-10, 1400)
	local maxH = math.min(scr.Y-20, 1000)

	local handle = N("Frame", self.Main, {
		Name                 = "ResizeHandle",
		BackgroundTransparency = 1,
		Position = UDim2.new(1,-hs,1,-hs),
		Size     = UDim2.new(0,hs,0,hs),
		ZIndex   = 10,
	})

	local dots = {}
	for row=0,2 do for col=0,2-row do
		local d = N("Frame", handle, {
			BackgroundColor3     = D.BDL,
			BackgroundTransparency = 0.25,
			BorderSizePixel      = 0,
			Size = UDim2.new(0,ds,0,ds),
			AnchorPoint = Vector2.new(1,1),
			Position = UDim2.new(1,-(2+col*(ds+dg)), 1,-(2+row*(ds+dg))),
			ZIndex = 10,
		})
		corner(d, 99)
		dots[#dots+1] = d
	end end

	local hp  = self.IsMobile and 10 or 6
	local btn = N("TextButton", handle, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,-hp,0,-hp),
		Size     = UDim2.new(1,hp*2,1,hp*2),
		Text     = "", ZIndex = 11,
		AutoButtonColor = false,
	})

	local resizing = false
	local resizeStart, startSize, startPos

	local function dotStyle(col, tr)
		for _,d in ipairs(dots) do
			if d and d.Parent then
				T(d, {BackgroundColor3=col, BackgroundTransparency=tr}, .15):Play()
			end
		end
	end

	btn.InputBegan:Connect(function(input)
		if self._minimized then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true; self._resizing = true
			resizeStart = input.Position
			startSize   = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
			startPos    = self.Main.Position
			dotStyle(D.ACX, 0)
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					resizing = false; self._resizing = false
					dotStyle(D.BDL, 0.25)
				end
			end)
		end
	end)
	btn.MouseEnter:Connect(function() if not resizing then dotStyle(D.ACL, 0) end end)
	btn.MouseLeave:Connect(function() if not resizing then dotStyle(D.BDL, 0.25) end end)

	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local nw    = math.clamp(startSize.X+delta.X, minW, maxW)
			local nh    = math.clamp(startSize.Y+delta.Y, minH, maxH)
			local dw, dh = nw-startSize.X, nh-startSize.Y
			local ns    = UDim2.new(0,nw,0,nh)
			local np    = UDim2.new(startPos.X.Scale, startPos.X.Offset+dw/2,
			                        startPos.Y.Scale, startPos.Y.Offset+dh/2)
			self.Main.Size     = ns
			self.Main.Position = np
			self.Size          = ns   -- so minimize restores correctly
			self.Shadow.Size   = ns + UDim2.new(0,44,0,44)
			self.Shadow.Position = np
		end
	end)

	self.ResizeHandle = handle
end

-- ┌─────────────────────────────────────┐
-- │  TITLE BAR  (premium macOS-style)   │
-- └─────────────────────────────────────┘
function UILib:_createTitleBar()
	self.TitleBar = N("Frame", self.Main, {
		BackgroundColor3 = D.BG2,
		BorderSizePixel  = 0,
		Position = UDim2.new(0,0,0,self.TopBarH),
		Size     = UDim2.new(1,0,0,self.TitleBarHeight),
	})
	-- Bottom separator line
	N("Frame", self.TitleBar, {
		BackgroundColor3 = D.BD,
		BorderSizePixel  = 0,
		Position = UDim2.new(0,0,1,-1),
		Size     = UDim2.new(1,0,0,1),
	})

	-- ── Accent pulse dot ───────────────────────────────────────
	local adot = N("Frame", self.TitleBar, {
		BackgroundColor3 = D.ACC,
		BorderSizePixel  = 0,
		Position = UDim2.new(0,11,.5,-4),
		Size     = UDim2.new(0,7,0,7),
	})
	corner(adot, 99)
	task.spawn(function()
		while self.ScreenGui and self.ScreenGui.Parent do
			T(adot, {BackgroundColor3=D.ACX}, 1.4, Enum.EasingStyle.Sine):Play(); task.wait(1.4)
			T(adot, {BackgroundColor3=D.ACC}, 1.4, Enum.EasingStyle.Sine):Play(); task.wait(1.4)
		end
	end)

	-- ── Title label ────────────────────────────────────────────
	N("TextLabel", self.TitleBar, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,25,0,0),
		Size     = UDim2.new(0, self.IsMobile and 155 or 210, 1, 0),
		Font     = D.FB,
		Text     = self.Title,
		TextColor3 = D.T0,
		TextSize   = self.FontTitle,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate   = Enum.TextTruncate.AtEnd,
	})

	-- ── AFK badge ──────────────────────────────────────────────
	local afkX = self.IsMobile and -88 or -114
	local afkF = N("Frame", self.TitleBar, {
		BackgroundTransparency = 1,
		Position = UDim2.new(1,afkX,.5,-7),
		Size     = UDim2.new(0,36,0,14),
	})
	local afkDot = N("Frame", afkF, {
		BackgroundColor3 = D.GRN,
		BorderSizePixel  = 0,
		Position = UDim2.new(0,0,.5,-4),
		Size     = UDim2.new(0,8,0,8),
	})
	corner(afkDot, 99)
	N("TextLabel", afkF, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,12,0,0),
		Size     = UDim2.new(0,24,1,0),
		Font     = D.FSB,
		Text     = "AFK",
		TextColor3 = D.GRN,
		TextSize   = self.FontSmall,
		TextXAlignment = Enum.TextXAlignment.Left,
	})
	self._antiAfkDot = afkDot

	-- ── macOS window controls ──────────────────────────────────
	local cS  = self.IsMobile and 16 or 18
	local gap = cS + 5

	local function mkCtrl(col, xOff, sym)
		local b = N("TextButton", self.TitleBar, {
			BackgroundColor3 = col,
			BorderSizePixel  = 0,
			Position = UDim2.new(1,xOff,.5,-cS/2),
			Size     = UDim2.new(0,cS,0,cS),
			Text     = "",
			AutoButtonColor = false,
		})
		corner(b, 99)
		stroke(b, col:Lerp(D.BG0, 0.45), 1, 0)
		local ico = N("TextLabel", b, {
			BackgroundTransparency = 1,
			Size     = UDim2.new(1,0,1,0),
			Font     = D.FB,
			Text     = sym,
			TextColor3 = col:Lerp(D.BG0, 0.5),
			TextSize   = cS-4,
			TextTransparency = 1,
		})
		b.MouseEnter:Connect(function()
			T(b,   {BackgroundColor3 = col:Lerp(Color3.new(1,1,1),.14)}, .12):Play()
			T(ico, {TextTransparency = 0}, .12):Play()
		end)
		b.MouseLeave:Connect(function()
			T(b,   {BackgroundColor3 = col}, .12):Play()
			T(ico, {TextTransparency = 1}, .12):Play()
		end)
		return b
	end

	-- Close (red)
	local closeBtn = mkCtrl(D.RED, -(cS+8), "×")
	closeBtn.MouseButton1Click:Connect(function()
		self.ScreenGui.Enabled = false
	end)

	-- Minimize (yellow)
	local minBtn = mkCtrl(D.YLW, -(cS+8+gap), "−")
	minBtn.MouseButton1Click:Connect(function()
		self._minimized = not self._minimized
		if self._minimized then
			T(self.Main,   {Size=UDim2.new(0,self.Size.X.Offset,0,self.TitleBarHeight)}, .3, Enum.EasingStyle.Quart):Play()
			T(self.Shadow, {Size=UDim2.new(0,self.Size.X.Offset+44,0,self.TitleBarHeight+44)}, .3):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = false end
		else
			T(self.Main,   {Size=self.Size}, .3, Enum.EasingStyle.Back):Play()
			T(self.Shadow, {Size=self.Size+UDim2.new(0,44,0,44)}, .3):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = true end
		end
	end)
end

