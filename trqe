	local order    = config.Order    or self._elementOrder
	local selected = config.Default  or (items[1] and items[1].name)
	local lib      = self.Library
	local btnW     = config.ButtonWidth or (lib.IsMobile and 56 or 68)
	local gridH    = lib.IsMobile and 46 or 54

	local sf = N("ScrollingFrame", W(self), {
		BackgroundTransparency = 1,
		BorderSizePixel        = 0,
		Size        = UDim2.new(1,0,0,gridH),
		LayoutOrder = order,
