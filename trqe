	BorderAccent = Color3.fromRGB(55, 70, 160),
	Accent = Color3.fromRGB(68, 88, 200),
	AccentLight = Color3.fromRGB(90, 115, 235),
	AccentGlow = Color3.fromRGB(100, 130, 255),
	TextPrimary = Color3.fromRGB(225, 225, 240),
	TextSecondary = Color3.fromRGB(140, 145, 165),
	TextMuted = Color3.fromRGB(90, 95, 115),
	Success = Color3.fromRGB(55, 178, 110),
	Error = Color3.fromRGB(235, 70, 80),
	Warning = Color3.fromRGB(240, 185, 55),
