	page.Name = "Page_" .. tabName
	page.BackgroundTransparency = 1
	page.BorderSizePixel = 0
	page.Position = UDim2.new(0, contentPad, 0, contentPad * 0.5)
	page.Size = UDim2.new(1, -contentPad * 2, 1, -contentPad)
