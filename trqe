	toggleBtn.TextSize = txtSize
	toggleBtn.Active = true
	toggleBtn.Draggable = true
	Instance.new("UICorner", toggleBtn).CornerRadius = UDim.new(1, 0)

	local stroke = Instance.new("UIStroke", toggleBtn)
	stroke.Color = Color3.fromRGB(70, 100, 200)
	stroke.Thickness = 1.5
	stroke.Transparency = 0.2

	task.spawn(function()
		while toggleGui and toggleGui.Parent do
			TweenService:Create(stroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine), { Transparency = 0.7 }):Play()
			task.wait(1.5)
			if not (toggleGui and toggleGui.Parent) then break end
			TweenService:Create(stroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine), { Transparency = 0.2 }):Play()
			task.wait(1.5)
		end
	end)

	toggleBtn.MouseButton1Click:Connect(function()
		self.ScreenGui.Enabled = not self.ScreenGui.Enabled
	end)

	return toggleGui
end

