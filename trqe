		BackgroundTransparency = 1,
		Size = UDim2.new(1,0,1,0),
		Text = "",
		Draggable = true,
	}, outer)

	-- Pulse ring
	task.spawn(function()
		while sg and sg.Parent do
			tw(outer, {BackgroundColor3 = Theme.BG3}, 1.2):Play()
			task.wait(1.2)
			tw(outer, {BackgroundColor3 = Theme.BG2}, 1.2):Play()
			task.wait(1.2)
		end
	end)

	btn.MouseButton1Click:Connect(function()
		self.SG.Enabled = not self.SG.Enabled
		tw(outer, {BackgroundColor3 = self.SG.Enabled and Theme.BG3 or Theme.BG2}, 0.2):Play()
	end)

	return sg
end

