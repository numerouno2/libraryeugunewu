	titleLabel.Text = self.Title
	titleLabel.TextColor3 = Color3.fromRGB(220, 222, 240)
	titleLabel.TextSize = self.FontTitle
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextTruncate = Enum.TextTruncate.AtEnd
	titleLabel.ZIndex = 4
end

--=============================================
-- Status Area (di title bar setelah title)
--=============================================
function UILib:_createStatusArea()
	local statusFrame = Instance.new("Frame", self.TitleBar)
	statusFrame.Name = "StatusFrame"
	statusFrame.BackgroundTransparency = 1
	statusFrame.Position = UDim2.new(0.5, 0, 0, 0)
	statusFrame.Size = UDim2.new(0.45, 0, 1, 0)
	statusFrame.ZIndex = 3

	for i = 1, 3 do
		local label = Instance.new("TextLabel", statusFrame)
		label.BackgroundTransparency = 1
		label.Position = UDim2.new(0, 0, 0, 2 + (i - 1) * 12)
		label.Size = UDim2.new(1, 0, 0, 12)
		label.Font = Enum.Font.GothamSemibold
		label.TextSize = 8
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextColor3 = Color3.fromRGB(150, 150, 175)
		label.Text = ""
		label.ZIndex = 3
		self.StatusLabels[i] = label
	end
end

function UILib:SetStatus(line, text, color)
	if self.StatusLabels[line] then
		self.StatusLabels[line].Text = text
		if color then self.StatusLabels[line].TextColor3 = color end
	end
end

--=============================================
-- Sidebar
--=============================================
function UILib:_createSidebar()
