-- UILibrary.lua
-- Modern Nexus/macOS-Inspired UI with Resizable Window & Anti-AFK

local UILib = {}
UILib.__index = UILib

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Players = game:GetService("Players")

--=============================================
-- HELPER: Detect Mobile & Get Screen Size
--=============================================
local function isMobile()
	return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

local function getScreenSize()
	local camera = workspace.CurrentCamera
	if camera then
		return camera.ViewportSize
	end
	return Vector2.new(1920, 1080)
end

local function getScale()
	local screen = getScreenSize()
	local mobile = isMobile()
	if mobile then
		local shorter = math.min(screen.X, screen.Y)
		if shorter < 400 then return 0.6 end
		if shorter < 500 then return 0.68 end
		if shorter < 700 then return 0.75 end
		return 0.82
	end
	return 1
end

--=============================================
-- FUNGSI UTAMA: Buat Window
--=============================================
function UILib.new(config)
	local self = setmetatable({}, UILib)

	self.Title = config.Title or "My Hub"
	self.Tabs = {}
	self.TabButtons = {}
	self.TabPages = {}
	self.ActiveTab = nil
	self.UpdateCallbacks = {}
	self.IsMobile = isMobile()
	self.Scale = getScale()

	-- Responsive size (Rayfield-style: lebih compact)
	local screen = getScreenSize()
	if config.Size then
		self.Size = config.Size
	else
		self.Size = UDim2.new(0, 550, 0, 600)
	end

	-- Layout dimensions (sama untuk mobile & desktop untuk konsistensi)
	self.TabBarHeight = 42
	self.TitleBarHeight = 50
	self.FontTitle = 16
	self.FontTab = 13
	self.FontElement = 13
	self.FontSmall = 11
	self.ElementHeight = 40
	self.SectionPadding = 12
	self.TabButtonWidth = 110
	self.TabButtonHeight = 36

	-- Top bar offset
	self.TopBarH = 0
	self.HeaderTotal = self.TitleBarHeight + self.TabBarHeight

	-- Resize flags
	self._resizing = false
	self._minimized = false

	-- Hapus GUI lama
	local oldGui = game.CoreGui:FindFirstChild("UILib_Main")
	if oldGui then oldGui:Destroy() end

	-- ScreenGui
	self.ScreenGui = Instance.new("ScreenGui")
	self.ScreenGui.Name = "UILib_Main"
	self.ScreenGui.Parent = game.CoreGui
	self.ScreenGui.ResetOnSpawn = false
	self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

	-- Shadow (lebih soft, macOS-style)
	self.Shadow = Instance.new("ImageLabel", self.ScreenGui)
	self.Shadow.AnchorPoint = Vector2.new(0.5, 0.5)
	self.Shadow.BackgroundTransparency = 1
	self.Shadow.Position = UDim2.new(0.5, 0, 0.5, 0)
	self.Shadow.Size = self.Size + UDim2.new(0, 40, 0, 40)
	self.Shadow.Image = "rbxassetid://5554236805"
	self.Shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
	self.Shadow.ImageTransparency = 0.3
	self.Shadow.ScaleType = Enum.ScaleType.Slice
	self.Shadow.SliceCenter = Rect.new(23, 23, 277, 277)

	-- Main Frame (modern gradient background)
	self.Main = Instance.new("Frame", self.ScreenGui)
	self.Main.Name = "Main"
	self.Main.AnchorPoint = Vector2.new(0.5, 0.5)
	self.Main.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
	self.Main.BorderSizePixel = 0
	self.Main.Position = UDim2.new(0.5, 0, 0.5, 0)
	self.Main.Size = self.Size
	self.Main.ClipsDescendants = true
	Instance.new("UICorner", self.Main).CornerRadius = UDim.new(0, 12)

	-- Gradient overlay for depth
	local gradientBg = Instance.new("Frame", self.Main)
	gradientBg.Name = "GradientOverlay"
	gradientBg.BackgroundColor3 = Color3.new(1, 1, 1)
	gradientBg.BackgroundTransparency = 1
	gradientBg.BorderSizePixel = 0
	gradientBg.Size = UDim2.new(1, 0, 1, 0)
	gradientBg.ZIndex = 0
	Instance.new("UICorner", gradientBg).CornerRadius = UDim.new(0, 12)
	
	local gradient = Instance.new("UIGradient", gradientBg)
	gradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(20, 20, 28)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(12, 12, 18))
	}
	gradient.Rotation = 135

	-- Subtle border
	local stroke = Instance.new("UIStroke", self.Main)
	stroke.Color = Color3.fromRGB(40, 40, 55)
	stroke.Thickness = 1
	stroke.Transparency = 0.4

	-- Dragging
	self:_setupDrag()

	-- Title Bar (modern, clean)
	self:_createTitleBar()

	-- Tab Bar (horizontal tabs at top)
	self:_createTabBar()

	-- Content Area (full width below tabs)
	self.ContentArea = Instance.new("Frame", self.Main)
	self.ContentArea.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
	self.ContentArea.BackgroundTransparency = 0.3
	self.ContentArea.BorderSizePixel = 0
	self.ContentArea.Position = UDim2.new(0, 0, 0, self.HeaderTotal)
	self.ContentArea.Size = UDim2.new(1, 0, 1, -self.HeaderTotal)
	Instance.new("UICorner", self.ContentArea).CornerRadius = UDim.new(0, 0)

	-- Notification Bar
	self:_createNotifyBar()

	-- Status Labels
	self.StatusLabels = {}
	self:_createStatusArea()

	-- Setup Resize Handle
	self:_setupResize()

	-- Anti-AFK Always On
	self:_startAntiAFK()

	-- Smooth open animation
	self.Main.Size = UDim2.new(0, 0, 0, 0)
	self.Shadow.ImageTransparency = 1
	TweenService:Create(self.Main, TweenInfo.new(0.6, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
		Size = self.Size
	}):Play()
	TweenService:Create(self.Shadow, TweenInfo.new(0.6), {
		ImageTransparency = 0.3
	}):Play()

	-- Start update loop
	self:_startUpdateLoop()

	return self
end

--=============================================
-- INTERNAL: Anti-AFK System (Always On)
--=============================================
function UILib:_startAntiAFK()
	local player = Players.LocalPlayer
	if player then
		local idleConn
		idleConn = player.Idled:Connect(function()
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			end)
		end)
		self._antiAfkIdleConnection = idleConn
	end

	self._antiAfkActive = true
	self._antiAfkThread = task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			task.wait(60)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F13, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F13, false, game)
			end)
		end
	end)

	self._antiAfkMouseThread = task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			task.wait(120)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendMouseMoveEvent(math.random(100, 500), math.random(100, 500), game)
			end)
		end
	end)

	self:_createAntiAfkIndicator()
end

--=============================================
-- INTERNAL: Anti-AFK Indicator (Modern)
--=============================================
function UILib:_createAntiAfkIndicator()
	local indicator = Instance.new("Frame", self.TitleBar)
	indicator.Name = "AntiAfkIndicator"
	indicator.BackgroundColor3 = Color3.fromRGB(50, 200, 120)
	indicator.BackgroundTransparency = 0.15
	indicator.BorderSizePixel = 0
	indicator.Position = UDim2.new(0, 320, 0.5, -11)
	indicator.Size = UDim2.new(0, 85, 0, 22)
	Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 11)

	local iconFrame = Instance.new("Frame", indicator)
	iconFrame.BackgroundColor3 = Color3.fromRGB(60, 255, 140)
	iconFrame.BorderSizePixel = 0
	iconFrame.Position = UDim2.new(0, 6, 0.5, -7)
	iconFrame.Size = UDim2.new(0, 14, 0, 14)
	Instance.new("UICorner", iconFrame).CornerRadius = UDim.new(1, 0)

	local dot = Instance.new("Frame", iconFrame)
	dot.Name = "Dot"
	dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	dot.BorderSizePixel = 0
	dot.Position = UDim2.new(0.5, -3, 0.5, -3)
	dot.Size = UDim2.new(0, 6, 0, 6)
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	local label = Instance.new("TextLabel", indicator)
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 24, 0, 0)
	label.Size = UDim2.new(1, -24, 1, 0)
	label.Font = Enum.Font.GothamBold
	label.Text = "Anti-AFK"
	label.TextColor3 = Color3.fromRGB(255, 255, 255)
	label.TextSize = 10
	label.TextXAlignment = Enum.TextXAlignment.Left

	self._antiAfkDot = dot
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			if dot and dot.Parent then
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {
					BackgroundTransparency = 0.6
				}):Play()
				TweenService:Create(iconFrame, TweenInfo.new(1, Enum.EasingStyle.Sine), {
					BackgroundTransparency = 0.3
				}):Play()
				task.wait(1)
				if not (dot and dot.Parent) then break end
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {
					BackgroundTransparency = 0
				}):Play()
				TweenService:Create(iconFrame, TweenInfo.new(1, Enum.EasingStyle.Sine), {
					BackgroundTransparency = 0
				}):Play()
				task.wait(1)
			else
				break
			end
		end
	end)
end

--=============================================
-- INTERNAL: Drag System
--=============================================
function UILib:_setupDrag()
	local dragging, dragInput, dragStart, startPos

	self.Main.InputBegan:Connect(function(input)
		if self._resizing then return end

		if input.UserInputType == Enum.UserInputType.MouseButton1 
		or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = self.Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.Main.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement 
		or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging and not self._resizing then
			local delta = input.Position - dragStart
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			self.Main.Position = newPos
			self.Shadow.Position = newPos
		end
	end)
end

--=============================================
-- INTERNAL: Resize System (Modern Handle)
--=============================================
function UILib:_setupResize()
	local handleSize = 20
	local minW = 400
	local minH = self.HeaderTotal + 150
	local screen = getScreenSize()
	local maxW = math.min(screen.X - 10, 1400)
	local maxH = math.min(screen.Y - 20, 1000)

	-- Modern resize handle
	local handle = Instance.new("Frame", self.Main)
	handle.Name = "ResizeHandle"
	handle.BackgroundTransparency = 1
	handle.Position = UDim2.new(1, -handleSize, 1, -handleSize)
	handle.Size = UDim2.new(0, handleSize, 0, handleSize)
	handle.ZIndex = 10

	-- Modern grip icon (3 dots diagonal)
	local gripDots = {}
	for i = 0, 2 do
		local dot = Instance.new("Frame", handle)
		dot.Name = "GripDot"
		dot.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
		dot.BackgroundTransparency = 0.5
		dot.BorderSizePixel = 0
		dot.Size = UDim2.new(0, 3, 0, 3)
		dot.Position = UDim2.new(1, -(4 + i * 5), 1, -(4 + i * 5))
		dot.AnchorPoint = Vector2.new(1, 1)
		dot.ZIndex = 10
		Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
		table.insert(gripDots, dot)
	end

	local btn = Instance.new("TextButton", handle)
	btn.Name = "ResizeBtn"
	btn.BackgroundTransparency = 1
	btn.Position = UDim2.new(0, -8, 0, -8)
	btn.Size = UDim2.new(1, 16, 1, 16)
	btn.Text = ""
	btn.ZIndex = 11
	btn.Active = true
	btn.AutoButtonColor = false

	local resizing = false
	local resizeStart, startSize, startPos

	local function setDotStyle(color, transparency)
		for _, d in ipairs(gripDots) do
			if d and d.Parent then
				TweenService:Create(d, TweenInfo.new(0.2), {
					BackgroundColor3 = color,
					BackgroundTransparency = transparency
				}):Play()
			end
		end
	end

	btn.InputBegan:Connect(function(input)
		if self._minimized then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 
		or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			self._resizing = true
			resizeStart = input.Position
			startSize = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
			startPos = self.Main.Position

			setDotStyle(Color3.fromRGB(150, 150, 200), 0)

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					resizing = false
					self._resizing = false
					setDotStyle(Color3.fromRGB(100, 100, 120), 0.5)
				end
			end)
		end
	end)

	btn.MouseEnter:Connect(function()
		if not resizing then
			setDotStyle(Color3.fromRGB(150, 150, 200), 0.2)
		end
	end)
	btn.MouseLeave:Connect(function()
		if not resizing then
			setDotStyle(Color3.fromRGB(100, 100, 120), 0.5)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement 
		or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local newW = math.clamp(startSize.X + delta.X, minW, maxW)
			local newH = math.clamp(startSize.Y + delta.Y, minH, maxH)

			local deltaW = newW - startSize.X
			local deltaH = newH - startSize.Y

			local newSize = UDim2.new(0, newW, 0, newH)
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + deltaW / 2,
				startPos.Y.Scale, startPos.Y.Offset + deltaH / 2
			)

			self.Main.Size = newSize
			self.Main.Position = newPos
			self.Size = newSize
			self.Shadow.Size = newSize + UDim2.new(0, 40, 0, 40)
			self.Shadow.Position = newPos
		end
	end)

	self.ResizeHandle = handle
end

--=============================================
-- INTERNAL: Title Bar (Modern Clean Design)
--=============================================
function UILib:_createTitleBar()
	self.TitleBar = Instance.new("Frame", self.Main)
	self.TitleBar.BackgroundColor3 = Color3.fromRGB(20, 20, 26)
	self.TitleBar.BackgroundTransparency = 0.2
	self.TitleBar.BorderSizePixel = 0
	self.TitleBar.Position = UDim2.new(0, 0, 0, 0)
	self.TitleBar.Size = UDim2.new(1, 0, 0, self.TitleBarHeight)

	-- Accent line at bottom
	local accentLine = Instance.new("Frame", self.TitleBar)
	accentLine.BackgroundColor3 = Color3.fromRGB(80, 120, 255)
	accentLine.BorderSizePixel = 0
	accentLine.Position = UDim2.new(0, 0, 1, -2)
	accentLine.Size = UDim2.new(1, 0, 0, 2)
	
	local accentGradient = Instance.new("UIGradient", accentLine)
	accentGradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 140, 255)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(120, 100, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(140, 100, 255))
	}

	-- Animated gradient
	task.spawn(function()
		while self.ScreenGui and self.ScreenGui.Parent do
			for i = 0, 1, 0.01 do
				if not self.ScreenGui.Parent then return end
				accentGradient.Offset = Vector2.new(i, 0)
				task.wait(0.03)
			end
			for i = 1, 0, -0.01 do
				if not self.ScreenGui.Parent then return end
				accentGradient.Offset = Vector2.new(i, 0)
				task.wait(0.03)
			end
		end
	end)

	-- Title text (left aligned)
	local titleLabel = Instance.new("TextLabel", self.TitleBar)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Position = UDim2.new(0, 16, 0, 0)
	titleLabel.Size = UDim2.new(0, 300, 1, 0)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.Text = self.Title
	titleLabel.TextColor3 = Color3.fromRGB(245, 245, 255)
	titleLabel.TextSize = self.FontTitle
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.TextTruncate = Enum.TextTruncate.AtEnd

	-- Control buttons (right side)
	local btnSize = 32
	local btnGap = 8

	-- Close Button
	local closeBtn = Instance.new("TextButton", self.TitleBar)
	closeBtn.BackgroundColor3 = Color3.fromRGB(255, 70, 85)
	closeBtn.BackgroundTransparency = 0.1
	closeBtn.BorderSizePixel = 0
	closeBtn.Position = UDim2.new(1, -(btnSize + 12), 0.5, -btnSize/2)
	closeBtn.Size = UDim2.new(0, btnSize, 0, btnSize)
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Text = "✕"
	closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	closeBtn.TextSize = 16
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)

	closeBtn.MouseEnter:Connect(function()
		TweenService:Create(closeBtn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(255, 90, 105),
			BackgroundTransparency = 0
		}):Play()
	end)
	closeBtn.MouseLeave:Connect(function()
		TweenService:Create(closeBtn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(255, 70, 85),
			BackgroundTransparency = 0.1
		}):Play()
	end)
	closeBtn.MouseButton1Click:Connect(function()
		self.ScreenGui.Enabled = false
	end)

	-- Minimize Button
	local minBtn = Instance.new("TextButton", self.TitleBar)
	minBtn.BackgroundColor3 = Color3.fromRGB(80, 120, 200)
	minBtn.BackgroundTransparency = 0.1
	minBtn.BorderSizePixel = 0
	minBtn.Position = UDim2.new(1, -(btnSize + 12 + btnSize + btnGap), 0.5, -btnSize/2)
	minBtn.Size = UDim2.new(0, btnSize, 0, btnSize)
	minBtn.Font = Enum.Font.GothamBold
	minBtn.Text = "—"
	minBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	minBtn.TextSize = 16
	Instance.new("UICorner", minBtn).CornerRadius = UDim.new(0, 6)

	minBtn.MouseEnter:Connect(function()
		TweenService:Create(minBtn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(100, 140, 220),
			BackgroundTransparency = 0
		}):Play()
	end)
	minBtn.MouseLeave:Connect(function()
		TweenService:Create(minBtn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(80, 120, 200),
			BackgroundTransparency = 0.1
		}):Play()
	end)

	minBtn.MouseButton1Click:Connect(function()
		self._minimized = not self._minimized
		if self._minimized then
			TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
				Size = UDim2.new(0, self.Size.X.Offset, 0, self.HeaderTotal)
			}):Play()
			TweenService:Create(self.Shadow, TweenInfo.new(0.3), {
				Size = UDim2.new(0, self.Size.X.Offset + 40, 0, self.HeaderTotal + 40)
			}):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = false end
		else
			TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {
				Size = self.Size
			}):Play()
			TweenService:Create(self.Shadow, TweenInfo.new(0.3), {
				Size = self.Size + UDim2.new(0, 40, 0, 40)
			}):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = true end
		end
	end)
end

