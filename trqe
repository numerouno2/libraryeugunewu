-- UILibrary.lua
-- Modern Apple/Nexus-Style Visual + Anti-AFK Always On + Resizable Window
-- Fixed: Rayfield-like sizing, traffic light buttons not blocked by AFK indicator

local UILib = {}
UILib.__index = UILib

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

--=============================================
-- HELPER
--=============================================
local function isMobile()
	return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

local function getScreenSize()
	local camera = workspace.CurrentCamera
	if camera then return camera.ViewportSize end
	return Vector2.new(1920, 1080)
end

local function getScale()
	local screen = getScreenSize()
	local mobile = isMobile()
	if mobile then
		local shorter = math.min(screen.X, screen.Y)
		if shorter < 400 then return 0.55 end
		if shorter < 500 then return 0.62 end
		if shorter < 700 then return 0.7 end
		return 0.78
	end
	return 1
end

--=============================================
-- FUNGSI UTAMA: Buat Window
--=============================================
function UILib.new(config)
	local self = setmetatable({}, UILib)

	self.Title = config.Title or "My Hub"
	self.Tabs = {}
	self.TabButtons = {}
	self.TabPages = {}
	self.ActiveTab = nil
	self.UpdateCallbacks = {}
	self.IsMobile = isMobile()
	self.Scale = getScale()

	-- Rayfield-like sizing: compact, centered, enak dipandang
	local screen = getScreenSize()
	if config.Size then
		self.Size = config.Size
	else
		-- Desktop: ~500x350, Mobile: responsive
		local w = math.clamp(math.floor(screen.X * 0.35), 320, 560)
		local h = math.clamp(math.floor(screen.Y * 0.42), 240, 400)
		self.Size = UDim2.new(0, w, 0, h)
	end

	-- Layout dimensions (unified mobile & desktop)
	self.SidebarWidth = math.clamp(math.floor(self.Size.X.Offset * 0.24), 85, 140)
	self.TitleBarHeight = 38
	self.FontTitle = 14
	self.FontTab = 11
	self.FontElement = 11
	self.FontSmall = 9
	self.ElementHeight = 32
	self.SectionPadding = 10
	self.TabButtonHeight = 30
	self.TabButtonSpacing = 35

	self.TopBarH = 2
	self.HeaderTotal = self.TopBarH + self.TitleBarHeight

	self._resizing = false
	self._minimized = false

	-- Hapus GUI lama
	local oldGui = game.CoreGui:FindFirstChild("UILib_Main")
	if oldGui then oldGui:Destroy() end

	-- ScreenGui
	self.ScreenGui = Instance.new("ScreenGui")
	self.ScreenGui.Name = "UILib_Main"
	self.ScreenGui.Parent = game.CoreGui
	self.ScreenGui.ResetOnSpawn = false
	self.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

	-- Shadow
	self.Shadow = Instance.new("ImageLabel", self.ScreenGui)
	self.Shadow.Name = "Shadow"
	self.Shadow.AnchorPoint = Vector2.new(0.5, 0.5)
	self.Shadow.BackgroundTransparency = 1
	self.Shadow.Position = UDim2.new(0.5, 0, 0.5, 0)
	self.Shadow.Size = self.Size + UDim2.new(0, 44, 0, 44)
	self.Shadow.Image = "rbxassetid://5554236805"
	self.Shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
	self.Shadow.ImageTransparency = 0.5
	self.Shadow.ScaleType = Enum.ScaleType.Slice
	self.Shadow.SliceCenter = Rect.new(23, 23, 277, 277)
	self.Shadow.ZIndex = 0

	-- Main Frame
	self.Main = Instance.new("Frame", self.ScreenGui)
	self.Main.Name = "Main"
	self.Main.AnchorPoint = Vector2.new(0.5, 0.5)
	self.Main.BackgroundColor3 = Color3.fromRGB(18, 18, 24)
	self.Main.BackgroundTransparency = 0
	self.Main.BorderSizePixel = 0
	self.Main.Position = UDim2.new(0.5, 0, 0.5, 0)
	self.Main.Size = self.Size
	self.Main.ClipsDescendants = true

	Instance.new("UICorner", self.Main).CornerRadius = UDim.new(0, 12)

	local outerStroke = Instance.new("UIStroke", self.Main)
	outerStroke.Color = Color3.fromRGB(50, 55, 75)
	outerStroke.Thickness = 1
	outerStroke.Transparency = 0.3

	-- Ambient top glow
	local ambientTop = Instance.new("Frame", self.Main)
	ambientTop.Name = "AmbientTop"
	ambientTop.BackgroundColor3 = Color3.fromRGB(60, 90, 200)
	ambientTop.BackgroundTransparency = 0.92
	ambientTop.Size = UDim2.new(1, 0, 0, 80)
	ambientTop.ZIndex = 0
	ambientTop.BorderSizePixel = 0
	local ambGrad = Instance.new("UIGradient", ambientTop)
	ambGrad.Transparency = NumberSequence.new{
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(1, 1)
	}
	ambGrad.Rotation = 90

	self:_setupDrag()
	self:_createAnimatedBar()
	self:_createTitleBar()
	self:_createSidebar()

	-- Content Area
	self.ContentArea = Instance.new("Frame", self.Main)
	self.ContentArea.Name = "ContentArea"
	self.ContentArea.BackgroundColor3 = Color3.fromRGB(22, 22, 30)
	self.ContentArea.BackgroundTransparency = 0
	self.ContentArea.BorderSizePixel = 0
	self.ContentArea.Position = UDim2.new(0, self.SidebarWidth, 0, self.HeaderTotal)
	self.ContentArea.Size = UDim2.new(1, -self.SidebarWidth, 1, -self.HeaderTotal)

	self:_createNotifyBar()
	self.StatusLabels = {}
	self:_createStatusArea()
	self:_setupResize()
	self:_startAntiAFK()

	-- Open animation
	self.Main.Size = UDim2.new(0, 0, 0, 0)
	self.Shadow.ImageTransparency = 1
	TweenService:Create(self.Main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
		Size = self.Size
	}):Play()
	TweenService:Create(self.Shadow, TweenInfo.new(0.5), {
		ImageTransparency = 0.5
	}):Play()

	self:_startUpdateLoop()
	return self
end

--=============================================
-- Anti-AFK System (Improved)
--=============================================
function UILib:_startAntiAFK()
	local player = Players.LocalPlayer
	if player then
		self._antiAfkIdleConnection = player.Idled:Connect(function()
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
				task.wait(0.12)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			end)
		end)
	end

	self._antiAfkActive = true

	self._antiAfkThread = task.spawn(function()
		while self._antiAfkActive do
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			task.wait(50)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F13, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F13, false, game)
			end)
		end
	end)

	self._antiAfkMouseThread = task.spawn(function()
		while self._antiAfkActive do
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			task.wait(90)
			if not self._antiAfkActive then break end
			pcall(function()
				local x, y = math.random(200, 600), math.random(200, 600)
				VirtualInputManager:SendMouseMoveEvent(x, y, game)
				task.wait(0.05)
				VirtualInputManager:SendMouseMoveEvent(x + 1, y + 1, game)
			end)
		end
	end)

	self._antiAfkHeartbeat = task.spawn(function()
		while self._antiAfkActive do
			if not (self.ScreenGui and self.ScreenGui.Parent) then break end
			task.wait(180)
			if not self._antiAfkActive then break end
			pcall(function()
				VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.RightShift, false, game)
				task.wait(0.05)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.RightShift, false, game)
			end)
		end
	end)

	self:_createAntiAfkIndicator()
end

--=============================================
-- Anti-AFK Indicator (di SIDEBAR bawah, bukan title bar)
--=============================================
function UILib:_createAntiAfkIndicator()
	-- Letakkan di bawah sidebar, BUKAN di title bar
	-- Jadi tidak menghalangi tombol close/minimize
	local indicator = Instance.new("Frame", self.Main)
	indicator.Name = "AntiAfkIndicator"
	indicator.BackgroundColor3 = Color3.fromRGB(30, 200, 100)
	indicator.BackgroundTransparency = 0.88
	indicator.Position = UDim2.new(0, 8, 1, -28)
	indicator.Size = UDim2.new(0, self.SidebarWidth - 16, 0, 20)
	indicator.BorderSizePixel = 0
	indicator.ZIndex = 5
	Instance.new("UICorner", indicator).CornerRadius = UDim.new(1, 0)

	local pillStroke = Instance.new("UIStroke", indicator)
	pillStroke.Color = Color3.fromRGB(30, 180, 90)
	pillStroke.Thickness = 1
	pillStroke.Transparency = 0.6

	local dotSize = 5
	local dot = Instance.new("Frame", indicator)
	dot.Name = "Dot"
	dot.BackgroundColor3 = Color3.fromRGB(50, 255, 120)
	dot.BorderSizePixel = 0
	dot.Position = UDim2.new(0, 6, 0.5, -dotSize / 2)
	dot.Size = UDim2.new(0, dotSize, 0, dotSize)
	dot.ZIndex = 6
	Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)

	local label = Instance.new("TextLabel", indicator)
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, dotSize + 10, 0, 0)
	label.Size = UDim2.new(1, -(dotSize + 14), 1, 0)
	label.Font = Enum.Font.GothamBold
	label.Text = "AFK"
	label.TextColor3 = Color3.fromRGB(50, 255, 120)
	label.TextSize = 8
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 6

	self._antiAfkDot = dot
	task.spawn(function()
		while self._antiAfkActive and self.ScreenGui and self.ScreenGui.Parent do
			if dot and dot.Parent then
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {
					BackgroundTransparency = 0.7
				}):Play()
				task.wait(1)
				if not (dot and dot.Parent) then break end
				TweenService:Create(dot, TweenInfo.new(1, Enum.EasingStyle.Sine), {
					BackgroundTransparency = 0
				}):Play()
				task.wait(1)
			else
				break
			end
		end
	end)
end

--=============================================
-- Drag System
--=============================================
function UILib:_setupDrag()
	local dragging, dragInput, dragStart, startPos

	self.Main.InputBegan:Connect(function(input)
		if self._resizing then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = self.Main.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	self.Main.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging and not self._resizing then
			local delta = input.Position - dragStart
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + delta.X,
				startPos.Y.Scale, startPos.Y.Offset + delta.Y
			)
			self.Main.Position = newPos
			self.Shadow.Position = newPos
		end
	end)
end

--=============================================
-- Resize System
--=============================================
function UILib:_setupResize()
	local handleSize = 24
	local dotSize = 2
	local dotGap = 4

	local minW = self.SidebarWidth + 120
	local minH = self.HeaderTotal + 80
	local screen = getScreenSize()
	local maxW = math.min(screen.X - 10, 1200)
	local maxH = math.min(screen.Y - 20, 800)

	local handle = Instance.new("Frame", self.Main)
	handle.Name = "ResizeHandle"
	handle.BackgroundTransparency = 1
	handle.Position = UDim2.new(1, -handleSize, 1, -handleSize)
	handle.Size = UDim2.new(0, handleSize, 0, handleSize)
	handle.ZIndex = 10

	local gripDots = {}
	for row = 0, 2 do
		for col = 0, 2 - row do
			local dot = Instance.new("Frame", handle)
			dot.BackgroundColor3 = Color3.fromRGB(65, 70, 110)
			dot.BackgroundTransparency = 0.35
			dot.BorderSizePixel = 0
			dot.Size = UDim2.new(0, dotSize, 0, dotSize)
			dot.Position = UDim2.new(1, -(3 + col * (dotSize + dotGap)), 1, -(3 + row * (dotSize + dotGap)))
			dot.AnchorPoint = Vector2.new(1, 1)
			dot.ZIndex = 10
			Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
			table.insert(gripDots, dot)
		end
	end

	local hitPad = 10
	local btn = Instance.new("TextButton", handle)
	btn.BackgroundTransparency = 1
	btn.Position = UDim2.new(0, -hitPad, 0, -hitPad)
	btn.Size = UDim2.new(1, hitPad * 2, 1, hitPad * 2)
	btn.Text = ""
	btn.ZIndex = 11
	btn.Active = true
	btn.AutoButtonColor = false

	local resizing = false
	local resizeStart, startSize, startPos

	local function setDotStyle(color, trans)
		for _, d in ipairs(gripDots) do
			if d and d.Parent then
				TweenService:Create(d, TweenInfo.new(0.2), {
					BackgroundColor3 = color, BackgroundTransparency = trans
				}):Play()
			end
		end
	end

	btn.InputBegan:Connect(function(input)
		if self._minimized then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			resizing = true
			self._resizing = true
			resizeStart = input.Position
			startSize = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
			startPos = self.Main.Position
			setDotStyle(Color3.fromRGB(140, 170, 255), 0)
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					resizing = false
					self._resizing = false
					setDotStyle(Color3.fromRGB(65, 70, 110), 0.35)
				end
			end)
		end
	end)

	btn.MouseEnter:Connect(function()
		if not resizing then setDotStyle(Color3.fromRGB(110, 140, 255), 0) end
	end)
	btn.MouseLeave:Connect(function()
		if not resizing then setDotStyle(Color3.fromRGB(65, 70, 110), 0.35) end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			local delta = input.Position - resizeStart
			local newW = math.clamp(startSize.X + delta.X, minW, maxW)
			local newH = math.clamp(startSize.Y + delta.Y, minH, maxH)
			local deltaW = newW - startSize.X
			local deltaH = newH - startSize.Y
			local newSize = UDim2.new(0, newW, 0, newH)
			local newPos = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + deltaW / 2,
				startPos.Y.Scale, startPos.Y.Offset + deltaH / 2
			)
			self.Main.Size = newSize
			self.Main.Position = newPos
			self.Size = newSize
			self.Shadow.Size = newSize + UDim2.new(0, 44, 0, 44)
			self.Shadow.Position = newPos
		end
	end)

	self.ResizeHandle = handle
end

--=============================================
-- Animated Bar
--=============================================
function UILib:_createAnimatedBar()
	local bar = Instance.new("Frame", self.Main)
	bar.Name = "AccentBar"
	bar.BackgroundColor3 = Color3.new(1, 1, 1)
	bar.BorderSizePixel = 0
	bar.Size = UDim2.new(1, 0, 0, self.TopBarH)
	bar.ZIndex = 5

	local gradient = Instance.new("UIGradient", bar)
	gradient.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(90, 130, 255)),
		ColorSequenceKeypoint.new(0.35, Color3.fromRGB(160, 100, 255)),
		ColorSequenceKeypoint.new(0.65, Color3.fromRGB(255, 80, 180)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(90, 130, 255))
	}

	task.spawn(function()
		local t = 0
		while self.ScreenGui and self.ScreenGui.Parent do
			t = t + 0.005
			if t > 1 then t = 0 end
			gradient.Offset = Vector2.new(t, 0)
			RunService.RenderStepped:Wait()
		end
	end)
end

