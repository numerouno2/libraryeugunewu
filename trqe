	closeBtn.Name = "CloseBtn"
	closeBtn.BackgroundColor3 = Color3.fromRGB(255, 95, 86)
	closeBtn.BorderSizePixel = 0
	closeBtn.Position = UDim2.new(0, dotStartX, 0, dotY - dotR)
	closeBtn.Size = UDim2.new(0, dotD, 0, dotD)
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Text = ""
	closeBtn.TextColor3 = Color3.fromRGB(80, 0, 0)
	closeBtn.TextSize = 9
	closeBtn.AutoButtonColor = false
	closeBtn.ZIndex = 6
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(1, 0)

	closeBtn.MouseEnter:Connect(function()
		closeBtn.Text = "✕"
		TweenService:Create(closeBtn, TweenInfo.new(0.12), {
			BackgroundColor3 = Color3.fromRGB(255, 70, 60)
		}):Play()
	end)
	closeBtn.MouseLeave:Connect(function()
		closeBtn.Text = ""
		TweenService:Create(closeBtn, TweenInfo.new(0.12), {
			BackgroundColor3 = Color3.fromRGB(255, 95, 86)
		}):Play()
	end)
	closeBtn.MouseButton1Click:Connect(function()
		self.ScreenGui.Enabled = false
	end)

	-- Minimize (yellow)
	local minBtn = Instance.new("TextButton", self.TitleBar)
	minBtn.Name = "MinBtn"
	minBtn.BackgroundColor3 = Color3.fromRGB(255, 189, 46)
	minBtn.BorderSizePixel = 0
	minBtn.Position = UDim2.new(0, dotStartX + dotD + dotGap, 0, dotY - dotR)
	minBtn.Size = UDim2.new(0, dotD, 0, dotD)
	minBtn.Font = Enum.Font.GothamBold
	minBtn.Text = ""
	minBtn.TextColor3 = Color3.fromRGB(120, 80, 0)
	minBtn.TextSize = 10
	minBtn.AutoButtonColor = false
	minBtn.ZIndex = 6
	Instance.new("UICorner", minBtn).CornerRadius = UDim.new(1, 0)

	minBtn.MouseEnter:Connect(function()
		minBtn.Text = "—"
		TweenService:Create(minBtn, TweenInfo.new(0.12), {
			BackgroundColor3 = Color3.fromRGB(255, 170, 30)
		}):Play()
	end)
	minBtn.MouseLeave:Connect(function()
		minBtn.Text = ""
		TweenService:Create(minBtn, TweenInfo.new(0.12), {
			BackgroundColor3 = Color3.fromRGB(255, 189, 46)
		}):Play()
	end)
	minBtn.MouseButton1Click:Connect(function()
		self._minimized = not self._minimized
		if self._minimized then
			TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Size = UDim2.new(0, self.Size.X.Offset, 0, self.HeaderTotal)
			}):Play()
			TweenService:Create(self.Shadow, TweenInfo.new(0.3), {
				Size = UDim2.new(0, self.Size.X.Offset + 44, 0, self.HeaderTotal + 44)
			}):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = false end
		else
			TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
				Size = self.Size
			}):Play()
			TweenService:Create(self.Shadow, TweenInfo.new(0.3), {
				Size = self.Size + UDim2.new(0, 44, 0, 44)
			}):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = true end
		end
