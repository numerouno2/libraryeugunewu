-- ┌─────────────────────────────────────┐
-- │  HELPERS (internal)                 │
-- └─────────────────────────────────────┘
local function isMobile()
	return UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
end

local function getScreenSize()
	local cam = workspace.CurrentCamera
	return cam and cam.ViewportSize or Vector2.new(1920, 1080)
end

local function getScale()
	local screen = getScreenSize()
	if isMobile() then
		local s = math.min(screen.X, screen.Y)
		if s < 400 then return 0.55 end
		if s < 500 then return 0.62 end
		if s < 700 then return 0.70 end
		return 0.78
	end
	return 1
end

-- Tween shorthand
local function T(obj, props, t, style, dir)
	return TweenService:Create(obj,
		TweenInfo.new(t or .2, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out),
		props)
end

-- Instance shorthand
local function N(cls, parent, props)
	local i = Instance.new(cls)
	if parent then i.Parent = parent end
	for k, v in pairs(props or {}) do i[k] = v end
	return i
end

local function corner(p, r) N("UICorner", p, {CornerRadius = UDim.new(0, r or 7)}) end
local function stroke(p, col, thick, tr)
	N("UIStroke", p, {Color=col or D.BD, Thickness=thick or 1, Transparency=tr or 0})
end
local function padI(p, l, r, t, b)
	N("UIPadding", p, {
		PaddingLeft  =UDim.new(0,l or 0), PaddingRight =UDim.new(0,r or 0),
		PaddingTop   =UDim.new(0,t or 0), PaddingBottom=UDim.new(0,b or 0),
	})
end
local function vList(p, gap)
	N("UIListLayout", p, {Padding=UDim.new(0,gap or 0), SortOrder=Enum.SortOrder.LayoutOrder})
end
local function hList(p, gap)
	N("UIListLayout", p, {
		Padding=UDim.new(0,gap or 0),
		FillDirection=Enum.FillDirection.Horizontal,
		SortOrder=Enum.SortOrder.LayoutOrder,
	})
end

-- ┌─────────────────────────────────────┐
-- │  UILib.new(config)                  │
-- └─────────────────────────────────────┘
function UILib.new(config)
	local self = setmetatable({}, UILib)

	-- ── public state (same names as original) ──────────────────
	self.Title           = config.Title or "My Hub"
	self.Tabs            = {}
	self.TabButtons      = {}
	self.TabPages        = {}
	self.ActiveTab       = nil
	self.UpdateCallbacks = {}
	self.IsMobile        = isMobile()
	self.Scale           = getScale()
	self.StatusLabels    = {}
	self._resizing       = false
	self._minimized      = false

	-- ── responsive size (same logic as original) ───────────────
	local screen = getScreenSize()
	if config.Size then
		self.Size = config.Size
	elseif self.IsMobile then
		self.Size = UDim2.new(0, math.min(screen.X-16, 420), 0, math.min(screen.Y-60, 310))
	else
		self.Size = UDim2.new(0, 490, 0, 295)
	end

	-- ── layout metrics (compact, same names as original) ───────
	if self.IsMobile then
		self.SidebarWidth      = 108
		self.TitleBarHeight    = 38
		self.FontTitle         = 11
		self.FontTab           = 10
		self.FontElement       = 10
		self.FontSmall         = 8
		self.ElementHeight     = 28
		self.SectionPadding    = 7
		self.TabButtonHeight   = 28
		self.TabButtonSpacing  = 32
	else
		self.SidebarWidth      = 130
		self.TitleBarHeight    = 44
		self.FontTitle         = 13
		self.FontTab           = 11
		self.FontElement       = 11
		self.FontSmall         = 9
		self.ElementHeight     = 32
		self.SectionPadding    = 9
		self.TabButtonHeight   = 30
		self.TabButtonSpacing  = 34
	end

	-- TopBarH kept as 0 — replaced by subtle inner glow (no animated bar)
	self.TopBarH    = 0
	self.HeaderTotal = self.TopBarH + self.TitleBarHeight

	-- ── destroy old ────────────────────────────────────────────
	local old = game.CoreGui:FindFirstChild("UILib_Main")
	if old then old:Destroy() end

	-- ── ScreenGui ──────────────────────────────────────────────
	self.ScreenGui = N("ScreenGui", game.CoreGui, {
		Name           = "UILib_Main",
		ResetOnSpawn   = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	})

	-- ── Drop shadow ────────────────────────────────────────────
	self.Shadow = N("ImageLabel", self.ScreenGui, {
		AnchorPoint          = Vector2.new(.5,.5),
		BackgroundTransparency = 1,
		Position             = UDim2.new(.5,0,.5,0),
		Size                 = self.Size + UDim2.new(0,44,0,44),
		Image                = "rbxassetid://5554236805",
		ImageColor3          = D.BG0,
		ImageTransparency    = 0.44,
		ScaleType            = Enum.ScaleType.Slice,
		SliceCenter          = Rect.new(23,23,277,277),
	})

	-- ── Main frame ─────────────────────────────────────────────
	self.Main = N("Frame", self.ScreenGui, {
		Name               = "Main",
		AnchorPoint        = Vector2.new(.5,.5),
		BackgroundColor3   = D.BG1,
		BorderSizePixel    = 0,
		Position           = UDim2.new(.5,0,.5,0),
		Size               = self.Size,
		ClipsDescendants   = true,
	})
	corner(self.Main, self.IsMobile and 11 or 13)
	stroke(self.Main, D.BDL, 1, 0.42)

	-- Subtle inner luminance (replaces animated rainbow bar — cleaner)
	local glow = N("Frame", self.Main, {
		BackgroundColor3      = Color3.new(1,1,1),
		BackgroundTransparency = 0.965,
		BorderSizePixel       = 0,
		Size                  = UDim2.new(1,0,.42,0),
	})
	N("UIGradient", glow, {
		Color    = ColorSequence.new{
			ColorSequenceKeypoint.new(0, Color3.fromRGB(120,100,255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(0,160,255)),
		},
		Rotation = 132,
	})

	-- ── build pieces ───────────────────────────────────────────
	self:_setupDrag()
	self:_createAnimatedBar()   -- preserved for compat (now no-op/invisible)
	self:_createTitleBar()
	self:_createSidebar()

	-- Content Area
	self.ContentArea = N("Frame", self.Main, {
		BackgroundColor3 = D.BG1,
		BorderSizePixel  = 0,
		Position = UDim2.new(0, self.SidebarWidth, 0, self.HeaderTotal),
		Size     = UDim2.new(1,-self.SidebarWidth,1,-self.HeaderTotal),
	})

	self:_createNotifyBar()
	self:_createStatusArea()
	self:_setupResize()
	self:_startAntiAFK()

	-- ── open animation ─────────────────────────────────────────
	self.Main.Size               = UDim2.new(0,0,0,0)
	self.Main.BackgroundTransparency = 1
	self.Shadow.ImageTransparency = 1
	T(self.Main, {Size=self.Size, BackgroundTransparency=0}, .48, Enum.EasingStyle.Back):Play()
	T(self.Shadow, {ImageTransparency=0.44}, .48):Play()

	self:_startUpdateLoop()
	return self
end

