function UILib:_setupDragAndMinimize()
	local dragging
	local offset = UDim2.new(-0.5, 0, -0.5, 0)
	local startpos, startsize

	-- Minimized State Check in Input
	UserInputService.InputBegan:Connect(function(input, gp)
		if gp then return end 
		if input.KeyCode == Enum.KeyCode.Backspace then -- Shortcut to hide/show
			self.ScreenGui.Enabled = not self.ScreenGui.Enabled
		end
	end)

	self.Main.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if self._minimized then return end
			if self._resizing then return end
			
			dragging = true
			startpos = self.Main.Position
			offset = Vector2.new(input.Position.X - startpos.X.Offset, input.Position.Y - startpos.Y.Offset)
			
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if dragging then
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
				local newPos = Vector2.new(input.Position.X - offset.X, input.Position.Y - offset.Y)
				self.Main.Position = UDim2.new(0.5, 0, 0.5, 0) -- Reset anchor to avoid drift
				self.Main.Position = UDim2.new((newPos.X / workspace.CurrentCamera.ViewportSize.X), newPos.X % 1, (newPos.Y / workspace.CurrentCamera.ViewportSize.Y), newPos.Y % 1)
				-- Simpler approach for center anchor: calculate raw pixel pos then convert to scaled
				-- However, keeping standard scale 0 for simplicity:
				-- self.Main.Position = UDim2.new(0, newPos.X, 0, newPos.Y) -- Requires different anchoring
				-- Correct Way for 0.5 anchor:
				self.Main.Position = UDim2.new((newPos.X/self.Size.X.Offset*0.5), 0, (newPos.Y/self.Size.Y.Offset*0.5), 0)
				self.Shadow.Position = self.Main.Position
			end
		end
	end)

	-- Title Button Logic moved here to share state
end

function UILib:_createTitleBar()
	self.TitleBar = Instance.new("Frame", self.Main)
	self.TitleBar.Name = "TitleBar"
	self.TitleBar.BackgroundColor3 = THEME.Header
	self.TitleBar.BorderSizePixel = 0
	self.TitleBar.Size = UDim2.new(1, 0, 0, self.Margins.Title)
	Instance.new("UICorner", self.TitleBar).CornerRadius = UDim.new(0, 16)
	Instance.new("UICorner", self.TitleBar).CornerRadius = UDim.new(0, 16, 0, 16, 0, 0, 0, 0) -- Top corners only
	
	self.TitleLabel = Instance.new("TextLabel", self.TitleBar)
	self.TitleLabel.BackgroundTransparency = 1
	self.TitleLabel.Position = UDim2.new(0, 20, 0, 0)
	self.TitleLabel.Size = UDim2.new(1, -100, 1, 0)
	self.TitleLabel.Font = Enum.Font.GothamBold
	self.TitleLabel.Text = self.Title
	self.TitleLabel.TextColor3 = THEME.TextPrimary
	self.TitleLabel.TextSize = self.Font.Title
	self.TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

	local controlSize = self.IsMobile and 32 or 36
	local gap = 10

	-- Minimize Button
	local minBtn = Instance.new("TextButton", self.TitleBar)
	minBtn.BackgroundTransparency = 1
	minBtn.Size = UDim2.new(0, controlSize, 0, controlSize)
	minBtn.Position = UDim2.new(1, -(controlSize + 15), 0.5, 0)
	minBtn.Text = "—"
	minBtn.TextColor3 = THEME.TextSecondary
	minBtn.Font = Enum.Font.GothamBold
	minBtn.TextSize = 16
	minBtn.AutoButtonColor = false
	Instance.new("UICorner", minBtn).CornerRadius = UDim.new(0, 6)

	minBtn.MouseButton1Click:Connect(function()
		if self._minimized then
			-- Expand
			self._minimized = false
			TweenService:Create(self.Main, TweenInfo.new(0.3), {Size = self.Size}):Play()
			TweenService:Create(self.Shadow, TweenInfo.new(0.3), {Size = self.Size + UDim2.new(0, 40, 0, 40)}):Play()
			if self.ResizeHandleObj then self.ResizeHandleObj.Visible = true end
			self.TitleBar.ZIndex = 100
		else
			-- Collapse
			self._minimized = true
			TweenService:Create(self.Main, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, self.Size.X.Offset, 0, self.Margins.Title + 10)}):Play()
			TweenService:Create(self.Shadow, TweenInfo.new(0.3), {Size = UDim2.new(0, self.Size.X.Offset + 40, 0, self.Margins.Title + 40)}):Play()
			if self.ResizeHandleObj then self.ResizeHandleObj.Visible = false end
			self.TitleBar.ZIndex = 1
		end
	end)

	-- Close Button
	local closeBtn = Instance.new("TextButton", self.TitleBar)
	closeBtn.BackgroundTransparency = 1
	closeBtn.Size = UDim2.new(0, controlSize, 0, controlSize)
	closeBtn.Position = UDim2.new(1, -15, 0.5, 0)
	closeBtn.Text = "✕"
	closeBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.TextSize = 14
	closeBtn.AutoButtonColor = false
	Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0, 6)

	closeBtn.MouseEnter:Connect(function() closeBtn.TextColor3 = Color3.fromRGB(255, 50, 50) end)
	closeBtn.MouseLeave:Connect(function() closeBtn.TextColor3 = Color3.fromRGB(255, 80, 80) end)
	
	closeBtn.MouseButton1Click:Connect(function()
		self.ScreenGui.Enabled = false
	end)
end

function UILib:_createAnimatedTopLine()
	local line = Instance.new("Frame", self.Main)
	line.Name = "Line"
	line.BackgroundColor3 = THEME.Accent
	line.BorderSizePixel = 0
	line.Size = UDim2.new(1, 0, 0, 4)
	line.ZIndex = 10

	local gradient = Instance.new("UIGradient", line)
	gradient.Rotation = 90
	gradient.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0, 0.7), NumberSequenceKeypoint.new(1, 0)}
	
	task.spawn(function()
		while self.ScreenGui and self.ScreenGui.Parent do
			for t = 0, 1, 0.01 do
				if not self.ScreenGui.Parent then return end
				gradient.Offset = Vector2.new(t, 0)
				task.wait(0.02)
			end
			for t = 1, 0, -0.01 do
				if not self.ScreenGui.Parent then return end
				gradient.Offset = Vector2.new(t, 0)
				task.wait(0.02)
			end
		end
	end)
end

