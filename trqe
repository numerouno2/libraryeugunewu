			TextTruncate = Enum.TextTruncate.AtEnd,
		}, b)

		btns[item.name] = b

		b.MouseButton1Click:Connect(function()
			sel = item.name
			for n2, b2 in pairs(btns) do
				local it2; for _, x in ipairs(items) do if x.name==n2 then it2=x; break end end
				local c2 = it2 and (it2.color or Theme.Accent) or Theme.Accent
				local act = (n2 == sel)
				tw(b2, {BackgroundColor3 = act and c2 or Theme.BG4, BackgroundTransparency = act and 0.15 or 0}, 0.2):Play()
				local ic2 = b2:GetChildren()[1]
				local lb2 = b2:GetChildren()[2]
				if ic2 then tw(ic2, {TextColor3 = act and c2 or Theme.Text2}, 0.2):Play() end
				if lb2 then tw(lb2, {TextColor3 = act and Theme.Text0 or Theme.Text2}, 0.2):Play() end
			end
			cb(item)
		end)
	end

	return {Frame=sf, Buttons=btns, GetSelected=function() return sel end}
