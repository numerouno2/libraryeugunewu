--=============================================
UILib._SectionMethods = {}

function UILib._SectionMethods:AddToggle(config)
	self._elementOrder = self._elementOrder + 1
	local lib = self.Library

	local frame = Instance.new("Frame", self.Frame)
	frame.BackgroundColor3 = Color3.fromRGB(35, 35, 48)
	frame.BorderSizePixel = 0
	frame.Size = UDim2.new(1, 0, 0, lib.ElementHeight)
	frame.LayoutOrder = config.Order or self._elementOrder
	Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

	local label = Instance.new("TextLabel", frame)
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 12, 0, 0)
	label.Size = UDim2.new(1, -70, 1, 0)
	label.Font = Enum.Font.GothamSemibold
	label.Text = config.Text or "Toggle"
	label.TextColor3 = Color3.fromRGB(210, 210, 230)
	label.TextSize = lib.FontElement
	label.TextXAlignment = Enum.TextXAlignment.Left

	local bg = Instance.new("Frame", frame)
	bg.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
	bg.BorderSizePixel = 0
	bg.Position = UDim2.new(1, -58, 0.5, -13)
	bg.Size = UDim2.new(0, 46, 0, 26)
	Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

	local knob = Instance.new("Frame", bg)
	knob.BackgroundColor3 = Color3.fromRGB(180, 180, 200)
	knob.BorderSizePixel = 0
	knob.Position = UDim2.new(0, 3, 0.5, -10)
	knob.Size = UDim2.new(0, 20, 0, 20)
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

	local active = config.Default or false

	local function update()
		if active then
			TweenService:Create(bg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(100, 180, 140)}):Play()
			TweenService:Create(knob, TweenInfo.new(0.3), {
				Position = UDim2.new(1, -23, 0.5, -10),
				BackgroundColor3 = Color3.new(1, 1, 1)
			}):Play()
		else
			TweenService:Create(bg, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(50, 50, 70)}):Play()
			TweenService:Create(knob, TweenInfo.new(0.3), {
				Position = UDim2.new(0, 3, 0.5, -10),
				BackgroundColor3 = Color3.fromRGB(180, 180, 200)
			}):Play()
		end
	end

	local btn = Instance.new("TextButton", frame)
	btn.BackgroundTransparency = 1
	btn.Size = UDim2.new(1, 0, 1, 0)
	btn.Text = ""
	btn.MouseButton1Click:Connect(function()
		active = not active
		update()
		if config.Callback then config.Callback(active) end
	end)

	if active then update() end

	return {
		SetValue = function(_, val) active = val; update() end,
		GetValue = function() return active end
	}
end

function UILib._SectionMethods:AddButton(config)
	self._elementOrder = self._elementOrder + 1
	local lib = self.Library

	local btn = Instance.new("TextButton", self.Frame)
	btn.BackgroundColor3 = Color3.fromRGB(80, 120, 200)
	btn.BorderSizePixel = 0
	btn.Size = UDim2.new(1, 0, 0, lib.ElementHeight)
	btn.Font = Enum.Font.GothamBold
	btn.Text = config.Text or "Button"
	btn.TextColor3 = Color3.new(1, 1, 1)
	btn.TextSize = 14
	btn.LayoutOrder = config.Order or self._elementOrder
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

	btn.MouseEnter:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(100, 140, 220)}):Play()
	end)
	btn.MouseLeave:Connect(function()
		TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(80, 120, 200)}):Play()
	end)
	btn.MouseButton1Click:Connect(function()
		if config.Callback then config.Callback() end
	end)

	return btn
end

