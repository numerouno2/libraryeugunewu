-- ─────────────────────────────────────────────
-- THEME SYSTEM
-- ─────────────────────────────────────────────
local Theme = {
	-- Backgrounds (layered glass effect)
	BG0      = Color3.fromRGB(8,   8,  12),   -- deepest bg
	BG1      = Color3.fromRGB(14,  14, 20),   -- main window
	BG2      = Color3.fromRGB(20,  20, 30),   -- sidebar
	BG3      = Color3.fromRGB(26,  26, 38),   -- card/section
	BG4      = Color3.fromRGB(34,  34, 50),   -- element hover

	-- Accent (electric indigo → cyan)
	Accent   = Color3.fromRGB(99,  102, 241), -- indigo-500
	AccentLt = Color3.fromRGB(129, 140, 248), -- indigo-400
	Cyan     = Color3.fromRGB(34,  211, 238), -- cyan-400
	Green    = Color3.fromRGB(52,  211, 153), -- emerald-400
	Red      = Color3.fromRGB(251,  82,  82), -- red
	Yellow   = Color3.fromRGB(251, 191,  36), -- amber

	-- Text
	Text0    = Color3.fromRGB(248, 248, 255), -- primary
	Text1    = Color3.fromRGB(180, 182, 206), -- secondary
	Text2    = Color3.fromRGB(100, 102, 130), -- muted
	TextDim  = Color3.fromRGB(60,  62,  90),  -- dimmer

	-- Borders
	Border   = Color3.fromRGB(38,  40,  62),
	BorderLt = Color3.fromRGB(55,  58,  88),

	-- Fonts
	FontH    = Enum.Font.GothamBold,
	FontM    = Enum.Font.GothamSemibold,
	FontR    = Enum.Font.Gotham,
