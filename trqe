function UILib:_createNotifyBar()
	local margin = self.IsMobile and 5 or 8
	local h = self.IsMobile and 19 or 23

	self._notifyFrame = N("Frame", self.Main, {
		BackgroundColor3   = Color3.fromRGB(14,22,50),
		BackgroundTransparency = 1,
		BorderSizePixel    = 0,
		Position = UDim2.new(0, self.SidebarWidth+margin, 1, -(h+7)),
		Size     = UDim2.new(1, -(self.SidebarWidth+margin*2), 0, h),
		ClipsDescendants   = true,
	})
	corner(self._notifyFrame, 6)

	self.NotifyBar = N("TextLabel", self._notifyFrame, {
		BackgroundTransparency = 1,
		Size    = UDim2.new(1,0,1,0),
		Font    = D.FSB,
		Text    = "",
		TextColor3 = D.T0,
		TextSize   = self.FontSmall + 1,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTransparency = 1,
		TextTruncate = Enum.TextTruncate.AtEnd,
	})
	padI(self.NotifyBar, 10)
	self._notifyDebounce = false
end

function UILib:Notify(msg, color)
	if self._notifyDebounce then return end
	self._notifyDebounce = true

	local col = color or D.GRN
	self.NotifyBar.Text            = "  " .. msg
	self.NotifyBar.TextColor3      = col
	self.NotifyBar.TextTransparency = 0
	T(self._notifyFrame, {BackgroundTransparency=0.1}, .18):Play()

	-- Left accent line
	local line = N("Frame", self._notifyFrame, {
		BackgroundColor3 = col,
		BorderSizePixel  = 0,
		Position = UDim2.new(0,0,0,0),
		Size     = UDim2.new(0,2,1,0),
	})
	corner(line, 99)

	task.delay(2, function()
		T(self._notifyFrame, {BackgroundTransparency=1}, .35):Play()
		T(self.NotifyBar,    {TextTransparency=1},       .35):Play()
		task.delay(.35, function()
			pcall(function() line:Destroy() end)
			self._notifyDebounce = false
		end)
	end)
end

