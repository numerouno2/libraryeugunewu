	sep.BackgroundTransparency = 0.4
	sep.BorderSizePixel = 0
	sep.Position = UDim2.new(0, 0, 1, -1)
	sep.Size = UDim2.new(1, 0, 0, 1)

	-- macOS traffic light buttons di KIRI
	local dotR = 6
	local dotD = dotR * 2
	local dotGap = 8
	local dotStartX = 14
	local dotY = math.floor(self.TitleBarHeight / 2)

	-- Close (red) - paling kiri
