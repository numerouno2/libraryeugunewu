	label.Position = UDim2.new(0, 12, 0, 0)
	label.Size = UDim2.new(1, -16, 1, 0)
	label.Font = Enum.Font.GothamSemibold
	label.Text = icon .. "  " .. text
	label.TextColor3 = Color3.fromRGB(240, 240, 240)
	label.TextSize = 11
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.TextTruncate = Enum.TextTruncate.AtEnd

	return frame
end

function UILib._SectionMethods:AddButtonGrid(config)
	self._elementOrder = self._elementOrder + 1
	local items = config.Items or {}
	local callback = config.Callback or function() end
	local order = config.Order or self._elementOrder
	local selected = config.Default or (items[1] and items[1].name)
	local lib = self.Library
	local btnW = config.ButtonWidth or 68
	local gridH = 48

	local gridFrame = Instance.new("ScrollingFrame", self.Frame)
	gridFrame.Name = "ButtonGrid"
	gridFrame.BackgroundTransparency = 1
	gridFrame.Size = UDim2.new(1, 0, 0, gridH)
	gridFrame.LayoutOrder = order
	gridFrame.ScrollBarThickness = 2
	gridFrame.ScrollBarImageColor3 = Color3.fromRGB(100, 100, 100)
	gridFrame.AutomaticCanvasSize = Enum.AutomaticSize.X
	gridFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	gridFrame.BorderSizePixel = 0

	local gridLayout = Instance.new("UIListLayout", gridFrame)
	gridLayout.FillDirection = Enum.FillDirection.Horizontal
	gridLayout.Padding = UDim.new(0, 5)
	gridLayout.SortOrder = Enum.SortOrder.LayoutOrder

	local buttons = {}

	for i, item in ipairs(items) do
		local btn = Instance.new("TextButton", gridFrame)
		btn.BackgroundColor3 = (item.name == selected) and Color3.fromRGB(210, 210, 210) or Color3.fromRGB(35, 35, 35)
		btn.BorderSizePixel = 0
		btn.Size = UDim2.new(0, btnW, 0, gridH - 4)
		btn.Text = ""
		btn.AutoButtonColor = false
		btn.LayoutOrder = i
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)

		local bStroke = Instance.new("UIStroke", btn)
		bStroke.Color = Color3.fromRGB(85, 85, 85)
		bStroke.Thickness = 1
		bStroke.Transparency = (item.name == selected) and 1 or 0

		local iconLabel = Instance.new("TextLabel", btn)
		iconLabel.BackgroundTransparency = 1
		iconLabel.Size = UDim2.new(1, 0, 0, 24)
		iconLabel.Text = item.icon or "📦"
		iconLabel.TextSize = 16
		iconLabel.Font = Enum.Font.GothamBold

		local nameLabel = Instance.new("TextLabel", btn)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Position = UDim2.new(0, 0, 0, 24)
		nameLabel.Size = UDim2.new(1, 0, 0, 16)
		nameLabel.Text = item.label or item.name
		nameLabel.TextColor3 = (item.name == selected) and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(240, 240, 240)
		nameLabel.TextSize = 8
		nameLabel.Font = Enum.Font.GothamSemibold
		nameLabel.TextTruncate = Enum.TextTruncate.AtEnd

		buttons[item.name] = btn

		btn.MouseButton1Click:Connect(function()
			selected = item.name
			for bName, bBtn in pairs(buttons) do
				local bItem
				for _, it in ipairs(items) do if it.name == bName then bItem = it; break end end
				local isSelected = (bName == selected)
				local bNameLabel = bBtn:FindFirstChildOfClass("TextLabel")
				-- find name label (second one)
				local children = bBtn:GetChildren()
				for _, c in ipairs(children) do
					if c:IsA("TextLabel") and c.Position.Y.Offset == 24 then
						TweenService:Create(c, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
							TextColor3 = isSelected and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(240, 240, 240)
						}):Play()
					end
				end
				TweenService:Create(bBtn, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
					BackgroundColor3 = isSelected and Color3.fromRGB(210, 210, 210) or Color3.fromRGB(35, 35, 35)
				}):Play()
				local bStroke2 = bBtn:FindFirstChildOfClass("UIStroke")
				if bStroke2 then
					TweenService:Create(bStroke2, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
						Transparency = isSelected and 1 or 0
					}):Play()
				end
			end
			callback(item)
		end)
	end

	return {
		Frame = gridFrame,
		Buttons = buttons,
		GetSelected = function() return selected end,
		SetSelected = function(_, name)
			selected = name
			for bName, bBtn in pairs(buttons) do
				local isSelected = (bName == selected)
				TweenService:Create(bBtn, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
					BackgroundColor3 = isSelected and Color3.fromRGB(210, 210, 210) or Color3.fromRGB(35, 35, 35)
				}):Play()
			end
		end
	}
end

function UILib._SectionMethods:AddTextBox(config)
	self._elementOrder = self._elementOrder + 1
	local placeholder = config.Placeholder or "Type here..."
	local default = config.Default or ""
	local callback = config.Callback or function() end
	local order = config.Order or self._elementOrder
	local lib = self.Library
	local h = 36

	local frame = Instance.new("Frame", self.Frame)
	frame.Name = "Input"
	frame.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
	frame.BorderSizePixel = 0
	frame.Size = UDim2.new(1, 0, 0, h)
	frame.LayoutOrder = order
	Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 8)

	local elStroke = Instance.new("UIStroke", frame)
	elStroke.Color = Color3.fromRGB(50, 50, 50)
	elStroke.Thickness = 1

	-- Input frame (inner box, right side)
	local inputFrame = Instance.new("Frame", frame)
	inputFrame.Name = "InputFrame"
	inputFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	inputFrame.BorderSizePixel = 0
	inputFrame.AnchorPoint = Vector2.new(1, 0.5)
	inputFrame.Position = UDim2.new(1, -8, 0.5, 0)
	inputFrame.Size = UDim2.new(0, 120, 0, 26)
	Instance.new("UICorner", inputFrame).CornerRadius = UDim.new(0, 5)

	local inputStroke = Instance.new("UIStroke", inputFrame)
	inputStroke.Color = Color3.fromRGB(65, 65, 65)
	inputStroke.Thickness = 1

	local textbox = Instance.new("TextBox", inputFrame)
	textbox.Name = "InputBox"
	textbox.BackgroundTransparency = 1
	textbox.Position = UDim2.new(0, 8, 0, 0)
	textbox.Size = UDim2.new(1, -16, 1, 0)
	textbox.Font = Enum.Font.Gotham
	textbox.PlaceholderText = placeholder
	textbox.PlaceholderColor3 = Color3.fromRGB(178, 178, 178)
	textbox.Text = default
	textbox.TextColor3 = Color3.fromRGB(240, 240, 240)
	textbox.TextSize = 12
	textbox.TextXAlignment = Enum.TextXAlignment.Left

	-- Hover
	frame.MouseEnter:Connect(function()
		TweenService:Create(frame, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
			BackgroundColor3 = Color3.fromRGB(40, 40, 40)
		}):Play()
	end)
	frame.MouseLeave:Connect(function()
		TweenService:Create(frame, TweenInfo.new(0.6, Enum.EasingStyle.Quint), {
			BackgroundColor3 = Color3.fromRGB(35, 35, 35)
		}):Play()
	end)

	-- Auto-resize input frame
	textbox:GetPropertyChangedSignal("Text"):Connect(function()
		TweenService:Create(inputFrame, TweenInfo.new(0.55, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = UDim2.new(0, math.clamp(textbox.TextBounds.X + 24, 80, 200), 0, 26)
		}):Play()
	end)

	textbox.FocusLost:Connect(function()
		callback(textbox.Text)
	end)

	return textbox
end

function UILib._SectionMethods:AddQuantitySelector(config)
	self._elementOrder = self._elementOrder + 1
	local amounts = config.Amounts or { 1, 5, 10, 50, 100 }
	local default = config.Default or amounts[3] or 10
	local callback = config.Callback or function() end
	local order = config.Order or self._elementOrder
	local lib = self.Library
	local btnW = 56
	local btnH = 30

	local gridFrame = Instance.new("ScrollingFrame", self.Frame)
	gridFrame.Name = "QuantitySelector"
	gridFrame.BackgroundTransparency = 1
	gridFrame.Size = UDim2.new(1, 0, 0, btnH + 4)
	gridFrame.LayoutOrder = order
	gridFrame.ScrollBarThickness = 2
	gridFrame.AutomaticCanvasSize = Enum.AutomaticSize.X
	gridFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	gridFrame.BorderSizePixel = 0

	local gridLayout = Instance.new("UIListLayout", gridFrame)
	gridLayout.FillDirection = Enum.FillDirection.Horizontal
	gridLayout.Padding = UDim.new(0, 5)

	local selected = default
	local buttons = {}

	for _, amt in ipairs(amounts) do
		local btn = Instance.new("TextButton", gridFrame)
		local isSelected = (amt == default)
		btn.BackgroundColor3 = isSelected and Color3.fromRGB(210, 210, 210) or Color3.fromRGB(35, 35, 35)
		btn.BorderSizePixel = 0
		btn.Size = UDim2.new(0, btnW, 0, btnH)
		btn.Font = Enum.Font.GothamBold
		btn.Text = "x" .. amt
		btn.TextColor3 = isSelected and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(240, 240, 240)
		btn.TextSize = 11
		btn.AutoButtonColor = false
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

		local bStroke = Instance.new("UIStroke", btn)
		bStroke.Color = Color3.fromRGB(85, 85, 85)
		bStroke.Thickness = 1
		bStroke.Transparency = isSelected and 1 or 0

		buttons[amt] = btn

		btn.MouseButton1Click:Connect(function()
			selected = amt
			for a, b in pairs(buttons) do
				local isSel = (a == amt)
				TweenService:Create(b, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
					BackgroundColor3 = isSel and Color3.fromRGB(210, 210, 210) or Color3.fromRGB(35, 35, 35),
					TextColor3 = isSel and Color3.fromRGB(50, 50, 50) or Color3.fromRGB(240, 240, 240)
				}):Play()
				local s = b:FindFirstChildOfClass("UIStroke")
				if s then
					TweenService:Create(s, TweenInfo.new(0.7, Enum.EasingStyle.Quint), {
						Transparency = isSel and 1 or 0
					}):Play()
				end
			end
			callback(amt)
		end)
	end

	return {
		Frame = gridFrame,
		GetValue = function() return selected end
	}
end

return UILib
