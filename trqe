--=============================================
-- PUBLIC: Destroy (cleanup all connections)
--=============================================
function UILib:Destroy()
	self._antiAfkActive = false

	-- Disconnect all anti-afk connections
	for _, conn in ipairs(self._antiAfkConnections) do
		if conn and typeof(conn) == "RBXScriptConnection" then
			pcall(function() conn:Disconnect() end)
		end
	end
	self._antiAfkConnections = {}

	if self.ScreenGui then self.ScreenGui:Destroy() end
	local toggle = game.CoreGui:FindFirstChild("UILib_Toggle")
	if toggle then toggle:Destroy() end
end

