		SortOrder = Enum.SortOrder.LayoutOrder,
	}, page)

	self.TabButtons[name] = btn
	self.TabPages[name]   = page

	btn.MouseButton1Click:Connect(function() self:SwitchTab(name) end)

	btn.MouseEnter:Connect(function()
		if self.ActiveTab ~= name then
			tw(btn, {BackgroundTransparency=0.85}, 0.15):Play()
		end
	end)
	btn.MouseLeave:Connect(function()
		if self.ActiveTab ~= name then
			tw(btn, {BackgroundTransparency=1}, 0.15):Play()
		end
	end)

	if idx == 1 then task.defer(function() self:SwitchTab(name) end) end

	local tab = {Name=name, Page=page, Lib=self, _order=0}
	setmetatable(tab, {__index = NexusLib._TabMethods})
	table.insert(self.Tabs, tab)
	return tab
end

-- ─────────────────────────────────────────────
-- PUBLIC: SwitchTab
-- ─────────────────────────────────────────────
function NexusLib:SwitchTab(name)
	if self.ActiveTab == name then return end
	self.ActiveTab = name

	for n, btn in pairs(self.TabButtons) do
		local lbl  = btn:FindFirstChild("Label")
		local ico  = btn:FindFirstChild("Icon")
		local ind  = btn:FindFirstChildWhichIsA("Frame")
		local active = (n == name)

		tw(btn, {BackgroundTransparency = active and 0.88 or 1}, 0.2):Play()
		if lbl then tw(lbl, {TextColor3 = active and Theme.Text0 or Theme.Text2}, 0.2):Play() end
		if ico then tw(ico, {TextColor3 = active and Theme.AccentLt or Theme.Text2}, 0.2):Play() end

		-- find Indicator
		for _, ch in ipairs(btn:GetChildren()) do
			if ch:IsA("Frame") and ch.Name ~= "Icon" then
				tw(ch, {BackgroundTransparency = active and 0 or 1}, 0.2):Play()
			end
		end
	end

	for n, pg in pairs(self.TabPages) do
		pg.Visible = (n == name)
	end
end

-- ─────────────────────────────────────────────
-- PUBLIC: Notify
-- ─────────────────────────────────────────────
function NexusLib:Notify(msg, color, icon)
	if self._notifyBusy then return end
	self._notifyBusy = true

	local c = color or Theme.Green
	local ic = icon or "◆"
	self.NotifyLabel.Text = ic .. "  " .. msg
	self.NotifyLabel.TextColor3 = c

	tw(self.NotifyFrame, {BackgroundTransparency=0.08}, 0.2):Play()
	tw(self.NotifyLabel, {TextTransparency=0}, 0.2):Play()

	-- left accent line
	local line = make("Frame", {
		BackgroundColor3 = c,
		BorderSizePixel = 0,
		Position = UDim2.new(0,0,0,0),
		Size = UDim2.new(0,3,1,0),
	}, self.NotifyFrame)
	corner(line, 99)

	task.delay(2.5, function()
		tw(self.NotifyFrame, {BackgroundTransparency=1}, 0.4):Play()
		tw(self.NotifyLabel, {TextTransparency=1}, 0.4):Play()
		task.delay(0.4, function()
			line:Destroy()
			self._notifyBusy = false
		end)
	end)
end

