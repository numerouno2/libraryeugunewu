	}, sg)
	corner(outer, 14)
	stroke(outer, Theme.Accent, 1, 0.3)

	make("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1,0,1,0),
		Font = Theme.FontH,
		Text = icon,
		TextSize = self.IsMobile and 20 or 24,
	}, outer)

