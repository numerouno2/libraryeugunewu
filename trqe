function UILib:_createStatusArea()
	if self.IsMobile then return end
	local sf = N("Frame", self.TitleBar, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,230,0,0),
		Size     = UDim2.new(0,180,1,0),
	})
	for i=1,3 do
		self.StatusLabels[i] = N("TextLabel", sf, {
			BackgroundTransparency = 1,
			Position = UDim2.new(0,0,0,3+(i-1)*14),
			Size     = UDim2.new(1,0,0,14),
			Font     = D.FSB,
			TextSize = 9,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextColor3 = D.T2,
			Text = "",
		})
	end
end

function UILib:SetStatus(line, text, color)
	if self.StatusLabels[line] then
		self.StatusLabels[line].Text = text
		if color then self.StatusLabels[line].TextColor3 = color end
	end
end

