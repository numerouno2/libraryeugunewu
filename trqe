local VIM  = game:GetService("VirtualInputManager")
local PLR  = game:GetService("Players")

-- ─────────────────────────────────────
-- THEME
-- ─────────────────────────────────────
local T = {
	BG0   = Color3.fromRGB(8,   8,  12),
	BG1   = Color3.fromRGB(13,  13, 19),   -- main window
	BG2   = Color3.fromRGB(17,  17, 25),   -- sidebar
	BG3   = Color3.fromRGB(22,  22, 34),   -- section / card
	BG4   = Color3.fromRGB(30,  30, 45),   -- element bg
	BG5   = Color3.fromRGB(38,  38, 56),   -- hover / active elem

	Acc   = Color3.fromRGB(99,  102, 241),
	AccLt = Color3.fromRGB(139, 142, 255),
	Cyan  = Color3.fromRGB(34,  211, 238),
	Green = Color3.fromRGB(52,  211, 153),
	Red   = Color3.fromRGB(248,  82,  82),
	Yel   = Color3.fromRGB(251, 191,  36),
	Pink  = Color3.fromRGB(236, 100, 180),

	TX0   = Color3.fromRGB(245, 245, 255),
	TX1   = Color3.fromRGB(175, 177, 210),
	TX2   = Color3.fromRGB(100, 103, 140),
	TXD   = Color3.fromRGB(55,  57,  85),

	Bdr   = Color3.fromRGB(32,  34,  52),
	BdrL  = Color3.fromRGB(50,  52,  78),

	FH = Enum.Font.GothamBold,
	FM = Enum.Font.GothamSemibold,
	FR = Enum.Font.Gotham,
}

-- ─────────────────────────────────────
-- HELPERS
-- ─────────────────────────────────────
local function mobile()
	return UIS.TouchEnabled and not UIS.KeyboardEnabled
end

local function screen()
	local c = workspace.CurrentCamera
	return c and c.ViewportSize or Vector2.new(1920,1080)
end

local function tw(o,p,t,s,d)
	return TS:Create(o,TweenInfo.new(t or .2, s or Enum.EasingStyle.Quint, d or Enum.EasingDirection.Out),p)
end

local function inst(cls, parent, props)
	local i = Instance.new(cls)
	for k,v in pairs(props or {}) do i[k]=v end
	if parent then i.Parent = parent end
	return i
end

local function corner(p, r)
	inst("UICorner", p, {CornerRadius = UDim.new(0, r or 7)})
end

local function stroke(p, col, thick, trans)
	inst("UIStroke", p, {
		Color = col or T.Bdr,
		Thickness = thick or 1,
		Transparency = trans or 0,
	})
end

local function listLayout(p, pad, fill)
	inst("UIListLayout", p, {
		Padding = UDim.new(0, pad or 0),
		SortOrder = Enum.SortOrder.LayoutOrder,
		FillDirection = fill or Enum.FillDirection.Vertical,
	})
end

-- ─────────────────────────────────────
-- CONSTRUCTOR
-- ─────────────────────────────────────
function NexusLib.new(cfg)
	local self = setmetatable({}, NexusLib)
	cfg = cfg or {}

	self.Title    = cfg.Title    or "Nexus Hub"
	self.Subtitle = cfg.Subtitle or ""
	self.Tabs     = {}
	self.TBtns    = {}   -- tab buttons
	self.TPages   = {}   -- tab pages
	self.Active   = nil
	self.CBs      = {}
	self.Mobile   = mobile()
	self._min     = false
	self._rsz     = false

	-- ── Compact responsive size ──────────────
	local sc = screen()
	if cfg.Size then
		self.Size = cfg.Size
	elseif self.Mobile then
		-- Mobile: gunakan hampir full screen, sisakan margin kecil
		local mw = math.min(sc.X - 16, 420)
		local mh = math.min(sc.Y - 80, 300)
		self.Size = UDim2.new(0, mw, 0, mh)
	else
		-- Desktop: compact, mirip screenshot
		self.Size = UDim2.new(0, 490, 0, 295)
	end

	-- ── Layout metrics ────────────────────────
	-- Semua diperkecil dari versi lama
	local M = self.Mobile
	self.SW   = M and 105  or 130    -- sidebar width
	self.TH   = M and 38   or 44     -- title bar height
	self.EH   = M and 28   or 32     -- element height
	self.TBH  = M and 28   or 30     -- tab button height
	self.TBG  = M and 32   or 34     -- tab button gap
	self.FS = {
		title = M and 11 or 13,
		tab   = M and 10 or 11,
		elem  = M and 10 or 11,
		sec   = M and  9 or  9,
		small = M and  8 or  9,
	}
	self.CP = M and 7 or 9    -- content padding

	-- ── Destroy old ──────────────────────────
	local old = game.CoreGui:FindFirstChild("NexusLib_GUI")
	if old then old:Destroy() end

	-- ── ScreenGui ────────────────────────────
	self.SG = inst("ScreenGui", game.CoreGui, {
		Name = "NexusLib_GUI",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
	})

	-- ── Shadow ───────────────────────────────
	self.Shadow = inst("ImageLabel", self.SG, {
		AnchorPoint = Vector2.new(.5,.5),
		BackgroundTransparency = 1,
		Position = UDim2.new(.5,0,.5,0),
		Size = self.Size + UDim2.new(0,40,0,40),
		Image = "rbxassetid://5554236805",
		ImageColor3 = T.BG0,
		ImageTransparency = 0.45,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(23,23,277,277),
	})

	-- ── Main ─────────────────────────────────
	self.Main = inst("Frame", self.SG, {
		Name = "NexusMain",
		AnchorPoint = Vector2.new(.5,.5),
		BackgroundColor3 = T.BG1,
		BorderSizePixel = 0,
		Position = UDim2.new(.5,0,.5,0),
		Size = self.Size,
		ClipsDescendants = true,
	})
	corner(self.Main, 12)
	stroke(self.Main, T.BdrL, 1, 0.45)

	-- Subtle top gradient
	local gf = inst("Frame", self.Main, {
		BackgroundColor3 = Color3.fromRGB(255,255,255),
		BackgroundTransparency = 0.965,
		BorderSizePixel = 0,
		Size = UDim2.new(1,0,.45,0),
	})
	inst("UIGradient", gf, {
		Color = ColorSequence.new{
			ColorSequenceKeypoint.new(0, Color3.fromRGB(140,120,255)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(0,180,255)),
		},
		Rotation = 135,
	})

	self:_drag()
	self:_titleBar()
	self:_sidebar()
	self:_contentArea()
	self:_notifyBar()
	self:_resize()
	self:_antiAFK()
	self:_updateLoop()

	-- Open animation
	self.Main.Size = UDim2.new(0,0,0,0)
	self.Main.BackgroundTransparency = 1
	self.Shadow.ImageTransparency = 1
	tw(self.Main, {Size=self.Size, BackgroundTransparency=0}, .45, Enum.EasingStyle.Back):Play()
	tw(self.Shadow, {ImageTransparency=0.45}, .45):Play()

	return self
end

-- ─────────────────────────────────────
-- TITLE BAR
-- ─────────────────────────────────────
function NexusLib:_titleBar()
	local bar = inst("Frame", self.Main, {
		BackgroundColor3 = T.BG2,
		BorderSizePixel = 0,
		Size = UDim2.new(1,0,0,self.TH),
	})
	-- bottom separator
	inst("Frame", bar, {
		BackgroundColor3 = T.Bdr,
		BorderSizePixel = 0,
		Position = UDim2.new(0,0,1,-1),
		Size = UDim2.new(1,0,0,1),
	})

	-- accent dot
	local dot = inst("Frame", bar, {
		BackgroundColor3 = T.Acc,
		BorderSizePixel = 0,
		Position = UDim2.new(0,12,.5,-4),
		Size = UDim2.new(0,7,0,7),
	})
	corner(dot, 99)

	-- title
	inst("TextLabel", bar, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,26,0,0),
		Size = UDim2.new(0,200,1,0),
		Font = T.FH,
		Text = self.Title,
		TextColor3 = T.TX0,
		TextSize = self.FS.title,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextTruncate = Enum.TextTruncate.AtEnd,
	})

	-- ── AFK badge
	local afkF = inst("Frame", bar, {
		BackgroundTransparency = 1,
		Position = UDim2.new(1,-115,.5,-7),
		Size = UDim2.new(0,36,0,14),
	})
	local afkDot = inst("Frame", afkF, {
		BackgroundColor3 = T.Green,
		BorderSizePixel = 0,
		Position = UDim2.new(0,0,.5,-4),
		Size = UDim2.new(0,8,0,8),
	})
	corner(afkDot, 99)
	inst("TextLabel", afkF, {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,12,0,0),
		Size = UDim2.new(0,24,1,0),
		Font = T.FM,
		Text = "AFK",
		TextColor3 = T.Green,
		TextSize = self.FS.small,
		TextXAlignment = Enum.TextXAlignment.Left,
	})
	self._afkDot = afkDot

	-- ── macOS window controls
	local cS  = self.Mobile and 16 or 18
	local cGap = cS + 5

	local function mkCtrl(col, xoff)
		local b = inst("TextButton", bar, {
			BackgroundColor3 = col,
			BorderSizePixel = 0,
			Position = UDim2.new(1, xoff, .5, -cS/2),
			Size = UDim2.new(0,cS,0,cS),
			Text = "",
			AutoButtonColor = false,
		})
		corner(b, 99)
		stroke(b, col:lerp(T.BG0, 0.4), 1, 0)
		return b
	end

	local closeBtn = mkCtrl(T.Red,   -(cS + 8))
	local minBtn   = mkCtrl(T.Yel,   -(cS + 8 + cGap))

	-- icons on hover
	local function hoverCtrl(btn, sym, symCol)
		local lbl = inst("TextLabel", btn, {
			BackgroundTransparency = 1,
			Size = UDim2.new(1,0,1,0),
			Font = T.FH,
			Text = sym,
			TextColor3 = symCol,
			TextSize = cS - 4,
			TextTransparency = 1,
		})
		btn.MouseEnter:Connect(function()
			tw(btn,{BackgroundColor3 = btn.BackgroundColor3:lerp(Color3.new(1,1,1),.15)},.12):Play()
			tw(lbl,{TextTransparency=0},.12):Play()
		end)
		btn.MouseLeave:Connect(function()
			tw(btn,{BackgroundColor3 = btn.BackgroundColor3:lerp(T.BG0,.12)},.12):Play()
			tw(lbl,{TextTransparency=1},.12):Play()
		end)
	end
	hoverCtrl(closeBtn,"×", Color3.fromRGB(80,20,20))
	hoverCtrl(minBtn,  "−", Color3.fromRGB(90,60,0))

	closeBtn.MouseButton1Click:Connect(function()
		tw(self.Main,{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1},.3,Enum.EasingStyle.Quint):Play()
		tw(self.Shadow,{ImageTransparency=1},.3):Play()
		task.delay(.32,function() self.SG.Enabled=false end)
	end)

	minBtn.MouseButton1Click:Connect(function()
		self._min = not self._min
		if self._min then
			tw(self.Main,{Size=UDim2.new(0,self.Size.X.Offset,0,self.TH)},.28,Enum.EasingStyle.Quint):Play()
			tw(self.Shadow,{Size=UDim2.new(0,self.Size.X.Offset+40,0,self.TH+40)},.28):Play()
			if self.RH then self.RH.Visible=false end
		else
			tw(self.Main,{Size=self.Size},.32,Enum.EasingStyle.Back):Play()
			tw(self.Shadow,{Size=self.Size+UDim2.new(0,40,0,40)},.32):Play()
			if self.RH then self.RH.Visible=true end
		end
	end)

	self.TitleBar = bar
end

