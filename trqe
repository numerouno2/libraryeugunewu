-- INTERNAL UTILITY (accessible to sections)
-- ─────────────────────────────────────────────
function NexusLib:_lighten(color, amt)
	local h,s,v = Color3.toHSV(color)
	return Color3.fromHSV(h, math.clamp(s-amt,0,1), math.clamp(v+amt,0,1))
end
-- Expose to section methods via Lib reference
NexusLib._TabMethods._lighten = NexusLib._lighten
NexusLib._SectionMethods._lighten = NexusLib._lighten

return NexusLib
