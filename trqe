function NexusLib._SecM:AddToggle(cfg)
	self._e=self._e+1
	local lib=self.Lib
	local val=cfg.Default or false
	local cb=cfg.Callback or function()end

	local row=inst("Frame",self.W,{
		BackgroundTransparency=1,
		BorderSizePixel=0,
		Size=UDim2.new(1,0,0,lib.EH),
		LayoutOrder=cfg.Order or self._e,
