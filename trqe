-- ─────────────────────────────────────────────
-- DRAG
-- ─────────────────────────────────────────────
function NexusLib:_setupDrag()
	local dragging, dragIn, dragStart, startPos

	self.Main.InputBegan:Connect(function(inp)
		if self._resizing then return end
		if inp.UserInputType == Enum.UserInputType.MouseButton1
		or inp.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = inp.Position
			startPos  = self.Main.Position
			inp.Changed:Connect(function()
				if inp.UserInputState == Enum.UserInputState.End then dragging = false end
			end)
		end
	end)
	self.Main.InputChanged:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseMovement
		or inp.UserInputType == Enum.UserInputType.Touch then
			dragIn = inp
		end
	end)
	UserInputService.InputChanged:Connect(function(inp)
		if inp == dragIn and dragging and not self._resizing then
			local d = inp.Position - dragStart
			local p = UDim2.new(startPos.X.Scale, startPos.X.Offset+d.X, startPos.Y.Scale, startPos.Y.Offset+d.Y)
			self.Main.Position   = p
			self.Shadow.Position = p
		end
	end)
end

-- ─────────────────────────────────────────────
-- RESIZE
-- ─────────────────────────────────────────────
function NexusLib:_setupResize()
	local screen = getScreen()
	local minW = self.SideW + (self.IsMobile and 120 or 200)
	local minH = self.TitleH + (self.IsMobile and 80 or 100)
	local maxW = math.min(screen.X - 10, 1600)
	local maxH = math.min(screen.Y - 20, 1000)

	local hs = self.IsMobile and 28 or 24

	local handle = make("Frame", {
		BackgroundTransparency = 1,
		Position = UDim2.new(1,-hs,1,-hs),
		Size     = UDim2.new(0,hs,0,hs),
		ZIndex   = 20,
	}, self.Main)

	-- Dots grip (3×3 diagonal)
	local dots = {}
	for r = 0,2 do for c = 0, 2-r do
		local d = make("Frame", {
			BackgroundColor3 = Theme.BorderLt,
			BackgroundTransparency = 0.2,
			BorderSizePixel = 0,
			Size = UDim2.new(0,3,0,3),
			AnchorPoint = Vector2.new(1,1),
			Position = UDim2.new(1,-(3+c*6), 1,-(3+r*6)),
			ZIndex = 21,
		}, handle)
		corner(d, 99)
		dots[#dots+1] = d
	end end

	local hitPad = self.IsMobile and 12 or 8
	local btn = make("TextButton", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,-hitPad,0,-hitPad),
		Size     = UDim2.new(1,hitPad*2,1,hitPad*2),
		Text     = "",
		ZIndex   = 22,
		AutoButtonColor = false,
	}, handle)

	local resizing, rsStart, ssz, sp = false

	local function dotColor(c, t)
		for _, d in ipairs(dots) do tw(d,{BackgroundColor3=c,BackgroundTransparency=t},0.15):Play() end
	end

	btn.InputBegan:Connect(function(inp)
		if self._minimized then return end
		if inp.UserInputType == Enum.UserInputType.MouseButton1
		or inp.UserInputType == Enum.UserInputType.Touch then
			resizing = true; self._resizing = true
			rsStart = inp.Position
			ssz = Vector2.new(self.Main.Size.X.Offset, self.Main.Size.Y.Offset)
			sp  = self.Main.Position
			dotColor(Theme.AccentLt, 0)
			inp.Changed:Connect(function()
				if inp.UserInputState == Enum.UserInputState.End then
					resizing = false; self._resizing = false
					dotColor(Theme.BorderLt, 0.2)
				end
			end)
		end
	end)
	btn.MouseEnter:Connect(function() if not resizing then dotColor(Theme.Accent, 0) end end)
	btn.MouseLeave:Connect(function() if not resizing then dotColor(Theme.BorderLt, 0.2) end end)

	UserInputService.InputChanged:Connect(function(inp)
		if resizing and (inp.UserInputType == Enum.UserInputType.MouseMovement
		or inp.UserInputType == Enum.UserInputType.Touch) then
			local d = inp.Position - rsStart
			local nw = math.clamp(ssz.X+d.X, minW, maxW)
			local nh = math.clamp(ssz.Y+d.Y, minH, maxH)
			local dw, dh = nw-ssz.X, nh-ssz.Y
			local ns  = UDim2.new(0,nw,0,nh)
			local np  = UDim2.new(sp.X.Scale, sp.X.Offset+dw/2, sp.Y.Scale, sp.Y.Offset+dh/2)
			self.Main.Size     = ns
			self.Main.Position = np
			self.Size          = ns
			self.Shadow.Size   = ns + UDim2.new(0,60,0,60)
			self.Shadow.Position = np
		end
	end)

	self.ResizeHandle = handle
end

-- ─────────────────────────────────────────────
-- ANTI-AFK
-- ─────────────────────────────────────────────
function NexusLib:_startAntiAFK()
	local player = Players.LocalPlayer
	if player then
		self._idleConn = player.Idled:Connect(function()
			pcall(function()
				VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Space, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
			end)
		end)
	end

	self._afkActive = true

	task.spawn(function()
		while self._afkActive and self.SG and self.SG.Parent do
			task.wait(60)
			pcall(function()
				VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.F13, false, game)
				task.wait(0.1)
				VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F13, false, game)
			end)
		end
	end)

	task.spawn(function()
		while self._afkActive and self.SG and self.SG.Parent do
			task.wait(120)
			pcall(function()
				VirtualInputManager:SendMouseMoveEvent(math.random(100,500), math.random(100,500), game)
			end)
		end
	end)

	-- Animate AFK dot
	task.spawn(function()
		while self._afkActive and self.SG and self.SG.Parent do
			if self._afkDot and self._afkDot.Parent then
				tw(self._afkDot, {BackgroundTransparency=0.7}, 0.9):Play()
				task.wait(0.9)
				tw(self._afkDot, {BackgroundTransparency=0}, 0.9):Play()
				task.wait(0.9)
			else break end
		end
	end)
end

-- ─────────────────────────────────────────────
-- UPDATE LOOP
-- ─────────────────────────────────────────────
function NexusLib:_startUpdateLoop()
	task.spawn(function()
		while self.SG and self.SG.Parent do
			for _, cb in ipairs(self.UpdateCBs) do pcall(cb) end
			task.wait(0.5)
		end
	end)
end

