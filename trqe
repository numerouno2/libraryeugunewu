		BackgroundColor3 = Theme.BG2,
		BorderSizePixel  = 0,
		Size = UDim2.new(1,0,0,self.TitleH),
	}, self.Main)

	-- Separator line at bottom of titlebar
	make("Frame", {
		BackgroundColor3 = Theme.Border,
		BorderSizePixel = 0,
		Position = UDim2.new(0,0,1,-1),
		Size = UDim2.new(1,0,0,1),
	}, bar)

	-- Accent dot
	local dot = make("Frame", {
		BackgroundColor3 = Theme.Accent,
		BorderSizePixel  = 0,
		Position = UDim2.new(0, 16, 0.5, -4),
		Size = UDim2.new(0, 8, 0, 8),
	}, bar)
	corner(dot, 99)

	-- Title text
	make("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0, 32, 0, 0),
		Size     = UDim2.new(0, 220, 1, 0),
		Font     = Theme.FontH,
		Text     = self.Title,
		TextColor3 = Theme.Text0,
		TextSize   = self.FS.title,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, bar)

	-- Subtitle
	if self.Subtitle ~= "" then
		make("TextLabel", {
			BackgroundTransparency = 1,
			Position = UDim2.new(0, 34, 0.5, 0),
			Size     = UDim2.new(0, 180, 0, 14),
			Font     = Theme.FontR,
			Text     = self.Subtitle,
			TextColor3 = Theme.Text2,
			TextSize   = self.FS.small,
			TextXAlignment = Enum.TextXAlignment.Left,
		}, bar)
	end

	-- AFK Indicator
	local afkFrame = make("Frame", {
		BackgroundTransparency = 1,
		Position = UDim2.new(1, self.IsMobile and -100 or -130, 0.5, -8),
		Size     = UDim2.new(0, 40, 0, 16),
	}, bar)

	local afkDot = make("Frame", {
		BackgroundColor3 = Theme.Green,
		BorderSizePixel  = 0,
		Position = UDim2.new(0,0,0.5,-4),
		Size     = UDim2.new(0,8,0,8),
	}, afkFrame)
	corner(afkDot, 99)

	make("TextLabel", {
		BackgroundTransparency = 1,
		Position = UDim2.new(0,12,0,0),
		Size     = UDim2.new(0,28,1,0),
		Font     = Theme.FontM,
		Text     = "AFK",
		TextColor3 = Theme.Green,
		TextSize   = self.FS.small,
		TextXAlignment = Enum.TextXAlignment.Left,
	}, afkFrame)

	self._afkDot = afkDot

	-- ── Window Controls (macOS style)
	local ctrlW  = self.IsMobile and 22 or 26
	local ctrlGap = ctrlW + (self.IsMobile and 4 or 6)

	-- Minimize
	local minBtn = make("TextButton", {
		BackgroundColor3 = Theme.Yellow,
		BorderSizePixel  = 0,
		Position = UDim2.new(1, -(ctrlW + 10 + ctrlGap), 0.5, -ctrlW/2),
		Size     = UDim2.new(0, ctrlW, 0, ctrlW),
		Text     = "",
		AutoButtonColor = false,
	}, bar)
	corner(minBtn, 99)
	stroke(minBtn, Color3.fromRGB(200, 150, 20), 1, 0.5)

	-- Close
	local closeBtn = make("TextButton", {
		BackgroundColor3 = Theme.Red,
		BorderSizePixel  = 0,
		Position = UDim2.new(1, -(ctrlW + 10), 0.5, -ctrlW/2),
		Size     = UDim2.new(0, ctrlW, 0, ctrlW),
		Text     = "",
		AutoButtonColor = false,
	}, bar)
	corner(closeBtn, 99)
	stroke(closeBtn, Color3.fromRGB(200, 60, 60), 1, 0.5)

	-- Hover labels
	local minIcon = make("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1,0,1,0),
		Font = Theme.FontH,
		Text = "−",
		TextColor3 = Color3.fromRGB(100,60,0),
		TextSize   = self.IsMobile and 12 or 14,
		TextTransparency = 1,
	}, minBtn)

	local closeIcon = make("TextLabel", {
		BackgroundTransparency = 1,
		Size = UDim2.new(1,0,1,0),
		Font = Theme.FontH,
		Text = "×",
		TextColor3 = Color3.fromRGB(100,20,20),
		TextSize   = self.IsMobile and 12 or 14,
		TextTransparency = 1,
	}, closeBtn)

	closeBtn.MouseEnter:Connect(function()
		tw(closeBtn, {BackgroundColor3 = Color3.fromRGB(255,100,100)}, 0.15):Play()
		tw(closeIcon, {TextTransparency = 0}, 0.15):Play()
	end)
	closeBtn.MouseLeave:Connect(function()
		tw(closeBtn, {BackgroundColor3 = Theme.Red}, 0.15):Play()
		tw(closeIcon, {TextTransparency = 1}, 0.15):Play()
	end)
	closeBtn.MouseButton1Click:Connect(function()
		tw(self.Main, {Size=UDim2.new(0,0,0,0), BackgroundTransparency=1}, 0.3, Enum.EasingStyle.Quint):Play()
		tw(self.Shadow, {ImageTransparency=1}, 0.3):Play()
		task.delay(0.35, function() self.SG.Enabled = false end)
	end)

	minBtn.MouseEnter:Connect(function()
		tw(minBtn, {BackgroundColor3 = Color3.fromRGB(255,220,80)}, 0.15):Play()
		tw(minIcon, {TextTransparency = 0}, 0.15):Play()
	end)
	minBtn.MouseLeave:Connect(function()
		tw(minBtn, {BackgroundColor3 = Theme.Yellow}, 0.15):Play()
		tw(minIcon, {TextTransparency = 1}, 0.15):Play()
	end)
	minBtn.MouseButton1Click:Connect(function()
		self._minimized = not self._minimized
		if self._minimized then
			tw(self.Main, {Size = UDim2.new(0, self.Size.X.Offset, 0, self.TitleH)}, 0.3, Enum.EasingStyle.Quint):Play()
			tw(self.Shadow, {Size = UDim2.new(0, self.Size.X.Offset+60, 0, self.TitleH+60)}, 0.3):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = false end
		else
			tw(self.Main, {Size = self.Size}, 0.35, Enum.EasingStyle.Back):Play()
			tw(self.Shadow, {Size = self.Size + UDim2.new(0,60,0,60)}, 0.35):Play()
			if self.ResizeHandle then self.ResizeHandle.Visible = true end
		end
	end)

	self.TitleBar = bar
end

