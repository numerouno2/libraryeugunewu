		PlaceholderColor3 = Theme.TextDim,
		Text      = def,
		TextColor3 = Theme.Text0,
		TextSize   = lib.FS.elem,
		TextXAlignment = Enum.TextXAlignment.Left,
		ClearTextOnFocus = false,
	}, wrap)

	tb.Focused:Connect(function()    tw(s,{Color=Theme.Accent},0.2):Play() end)
	tb.FocusLost:Connect(function()  tw(s,{Color=Theme.Border},0.2):Play(); cb(tb.Text) end)

	return tb
end

-- ── QuantitySelector
function NexusLib._SectionMethods:AddQuantitySelector(config)
	self._eo = self._eo + 1
	local lib    = self.Lib
	local amounts = config.Amounts or {1,5,10,50,100}
	local def    = config.Default or amounts[3] or 10
	local cb     = config.Callback or function() end
	local bW = lib.IsMobile and 50 or 66
	local bH = lib.IsMobile and 28 or 34

	local sf = make("ScrollingFrame", {
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		Size = UDim2.new(1,0,0,bH+4),
		ScrollBarThickness = 2,
		AutomaticCanvasSize = Enum.AutomaticSize.X,
		CanvasSize = UDim2.new(0,0,0,0),
		LayoutOrder = config.Order or self._eo,
	}, self.Wrap)

	make("UIListLayout", {
		FillDirection = Enum.FillDirection.Horizontal,
		Padding = UDim.new(0, lib.IsMobile and 4 or 6),
	}, sf)

	local sel = def
	local btns = {}

	for _, amt in ipairs(amounts) do
		local isActive = (amt == def)
		local b = make("TextButton", {
			BackgroundColor3 = isActive and Theme.Green or Theme.BG4,
			BackgroundTransparency = isActive and 0.1 or 0,
			BorderSizePixel = 0,
			Size = UDim2.new(0,bW,0,bH),
			Font = Theme.FontM,
			Text = "×"..amt,
			TextColor3 = isActive and Theme.Text0 or Theme.Text2,
			TextSize   = lib.FS.elem,
			AutoButtonColor = false,
		}, sf)
		corner(b, 8)
		btns[amt] = b

		b.MouseButton1Click:Connect(function()
			sel = amt
			for a2, b2 in pairs(btns) do
				local act = (a2 == sel)
				tw(b2, {
					BackgroundColor3 = act and Theme.Green or Theme.BG4,
					BackgroundTransparency = act and 0.1 or 0,
					TextColor3 = act and Theme.Text0 or Theme.Text2
				}, 0.2):Play()
			end
			cb(amt)
		end)
	end

	return {Frame=sf, GetValue=function() return sel end}
end

